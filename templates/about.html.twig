{% extends "base.html.twig" %}

{% block title %}{{ trans('about.title') }} — Minoo{% endblock %}

{% block content %}
  <div class="flow-lg">
    <section class="hero">
      <h1 class="hero__title">{{ trans('about.title') }}</h1>
      <p class="hero__subtitle">{{ trans('about.subtitle') }}</p>
    </section>

    <section class="portal-section flow">
      <h2>{{ trans('about.name_heading') }}</h2>
      <p>{{ trans('about.name_definition') }}</p>
    </section>

    <section class="portal-section flow">
      <h2>{{ trans('about.what_heading') }}</h2>
      <p>{{ trans('about.what_intro') }}</p>
      <p>{{ trans('about.what_intro2') }}</p>
      <ul>
        <li>{{ trans('about.what_list_1') }}</li>
        <li>{{ trans('about.what_list_2') }}</li>
        <li>{{ trans('about.what_list_3') }}</li>
        <li>{{ trans('about.what_list_4') }}</li>
      </ul>
    </section>

    <section class="portal-section flow">
      <h2>{{ trans('about.for_heading') }}</h2>
      <p>{{ trans('about.for_intro') }}</p>
      <ul>
        <li>{{ trans('about.for_list_1') }}</li>
        <li>{{ trans('about.for_list_2') }}</li>
        <li>{{ trans('about.for_list_3') }}</li>
        <li>{{ trans('about.for_list_4') }}</li>
        <li>{{ trans('about.for_list_5') }}</li>
      </ul>
    </section>

    <section class="portal-section flow">
      <h2>{{ trans('about.how_heading') }}</h2>
      <p>{{ trans('about.how_desc1') }}</p>
      <p>{{ trans('about.how_desc2') }}</p>
    </section>

    <section class="portal-section flow">
      <h2>{{ trans('about.community_heading') }}</h2>
      <p>{{ trans('about.community_desc1') }}</p>
      <p>{{ trans('about.community_desc2') }}</p>
    </section>

    <section class="portal-section flow">
      <h2>{{ trans('about.vision_heading') }}</h2>
      <p>{{ trans('about.vision_desc') }}</p>
    </section>
  </div>
{% endblock %}
