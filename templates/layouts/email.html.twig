<!DOCTYPE html>
<html lang="{% block lang %}en{% endblock %}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Minoo{% endblock %}</title>
  {% block head %}{% endblock %}
</head>
<body style="margin: 0; padding: 0; background-color: #f5f5f0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  {% block body %}{% endblock %}
</body>
</html>
