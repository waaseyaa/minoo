{% extends "base.html.twig" %}

{% block title %}
  {%- if path == '/events' -%}
    Events — Minoo
  {%- elseif event is defined and event -%}
    {{ event.get('title') }} — Minoo
  {%- else -%}
    Event Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if path == '/events' %}
    <div class="flow-lg">
      <h1>Events</h1>
      <p class="hero__subtitle">Powwows, gatherings, ceremonies, and community events happening across the region. Come learn, celebrate, and connect.</p>

      {% if events is defined and events|length > 0 %}
        <div class="card-grid">
          {% for e in events %}
            {% include "components/event-card.html.twig" with {
              title: e.get('title'),
              type: e.get('type')|default('')|capitalize,
              date: e.get('starts_at')|default(''),
              location: e.get('location')|default(''),
              excerpt: e.get('description')|default('')|split("\n\n")|first|length > 120 ? e.get('description')|default('')|split("\n\n")|first|slice(0, 120) ~ '…' : e.get('description')|default('')|split("\n\n")|first,
              url: "/events/" ~ e.get('slug')
            } %}
          {% endfor %}
        </div>
      {% else %}
        {% include "components/empty-state.html.twig" with {
          heading: "No events scheduled yet",
          body: "Powwows, gatherings, ceremonies, and community events will appear here as they're added. In the meantime, explore what's happening in your community.",
          action_url: "/communities",
          action_label: "Explore communities"
        } %}
      {% endif %}
    </div>
  {% elseif event is defined and event %}
    <div class="flow-lg detail">
      <a href="/events" class="detail__back">Events</a>
      <div class="detail__header">
        <span class="card__badge card__badge--event">{{ event.get('type')|default('')|capitalize }}</span>
        <h1>{{ event.get('title') }}</h1>
        <div class="detail__meta">
          {% if event.get('starts_at') %}
            <span class="card__date">{{ event.get('starts_at') }}{% if event.get('ends_at') %} – {{ event.get('ends_at') }}{% endif %}</span>
          {% endif %}
          {% if event.get('location') %}
            <span>{{ event.get('location') }}</span>
          {% endif %}
        </div>
      </div>
      <div class="detail__body flow">
        {% for paragraph in event.get('description')|default('')|split("\n\n") %}
          <p>{{ paragraph }}</p>
        {% endfor %}
      </div>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>Event Not Found</h1>
      <p>The event at <code>{{ path }}</code> could not be found.</p>
      <p><a href="/events">Browse all events</a></p>
    </div>
  {% endif %}
{% endblock %}
