{% extends "base.html.twig" %}

{% block title %}
  {%- if path == '/events' -%}
    {{ trans('events.title') }} — Minoo
  {%- elseif event is defined and event -%}
    {{ event.get('title') }} — Minoo
  {%- else -%}
    {{ trans('events.not_found') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block og_type %}{% if path starts with '/events/' and event is defined %}article{% else %}website{% endif %}{% endblock %}
{% block og_description %}{% if path starts with '/events/' and event is defined %}{{ event.get('description')|default('')|striptags|slice(0, 160) }}{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block content %}
  {% if path == '/events' %}
    <div class="flow-lg">
      <div class="listing-hero">
        <h1>{{ trans('events.title') }}</h1>
        <p class="listing-hero__subtitle">{{ trans('events.subtitle') }}</p>
      </div>

      {% if filters is defined %}
        {% include "components/event-filters.html.twig" with { filters: filters, feed: feed|default(null), location: location|default(null) } %}
      {% endif %}

      {% if filters is defined and filters.view == 'calendar' and feed is defined and feed.calendarMonth %}
        {% include "components/event-calendar.html.twig" with {
          calendarMonth: feed.calendarMonth,
          filters: filters
        } %}
      {% elseif (filters is defined and filters.view == 'list') or (feed is defined and feed.flatList|length > 0) %}
        {% include "components/event-list.html.twig" with {
          events: (feed is defined and feed.flatList is defined) ? feed.flatList : (events|default([])),
          pagination: (feed is defined and feed.pagination is defined) ? feed.pagination : null,
          filters: filters,
          communities: communities
        } %}
      {% elseif feed is defined %}
        {% include "components/event-feed.html.twig" with { feed: feed, communities: communities } %}
      {% else %}
        {% include "components/empty-state.html.twig" with {
          heading: trans('events.empty_heading'),
          body: trans('events.empty_body'),
          action_url: lang_url('/communities'),
          action_label: trans('events.explore_button')
        } %}
      {% endif %}
    </div>
  {% elseif event is defined and event %}
    <div class="flow-lg detail">
      {% include "components/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: trans('breadcrumb.home'), url: '/'},
          {label: trans('events.title'), url: lang_url('/events')},
          {label: event.get('title')}
        ]
      } %}
      {% include "components/hero-image.html.twig" with {
        image_url: image_url|default(''),
        alt: event.get('title'),
        credit: image_credit|default('')
      } %}
      <div class="detail-hero">
        <a href="{{ lang_url('/events') }}" class="detail-hero__back">{{ trans('events.detail_back') }}</a>
        {% if event.get('slug') %}
          <a href="/events/{{ event.get('slug') }}.ics" class="btn btn--secondary detail-hero__ics" download>{{ trans('events.add_to_calendar') }}</a>
        {% endif %}
        {% if event.get('type') is not empty %}
          <span class="detail-hero__badge">{{ event.get('type')|capitalize }}</span>
        {% endif %}
        <h1 class="detail-hero__title">{{ event.get('title') }}</h1>

        {% set now = "now"|date("U") %}
        {% set start = event.get('starts_at') ? event.get('starts_at')|date("U") : null %}
        {% set end_date = event.get('ends_at') ? event.get('ends_at')|date("U") : null %}

        {% if start and end_date and now >= start and now <= end_date %}
          <span class="event-status event-status--active">{{ trans('events.status_happening') }}</span>
        {% elseif start and now < start %}
          <span class="event-status event-status--upcoming">{{ trans('events.status_upcoming') }}</span>
        {% elseif end_date and now > end_date %}
          <span class="event-status event-status--past">{{ trans('events.status_past') }}</span>
        {% endif %}

        <div class="detail__meta">
          {% if event.get('starts_at') %}
            <span class="card__date">{{ event.get('starts_at')|date('F j, Y') }}{% if event.get('ends_at') %} – {{ event.get('ends_at')|date('F j, Y') }}{% endif %}</span>
          {% endif %}
          {% if event.get('location') %}
            <span>{{ event.get('location') }}</span>
          {% endif %}
        </div>
      </div>
      <div class="content-well">
        <div class="detail__body flow">
          {% for paragraph in event.get('description')|default('')|split("\n\n") %}
            <p>{{ paragraph }}</p>
          {% endfor %}
        </div>
      </div>{# .content-well #}

      {% if related_teachings is defined and related_teachings|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('events.related_teachings') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for teaching in related_teachings %}
              <a href="/teachings/{{ teaching.get('slug') }}" class="card card--compact">
                <span class="card__badge card__badge--teaching">{{ teaching.get('type')|default('')|capitalize }}</span>
                <h3 class="card__title">{{ teaching.get('title') }}</h3>
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if connected_people is defined and connected_people|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('events.people_connected') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for person in connected_people %}
              <a href="/people/{{ person.get('slug') }}" class="card card--compact">
                <h3 class="card__title">{{ person.get('name') }}</h3>
                {% if person.get('community') %}
                  <span class="card__meta">{{ person.get('community') }}</span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if host_community is defined and host_community %}
        <section class="related-section">
          <h2>{{ trans('events.host_community') }}</h2>
          <a href="/communities/{{ host_community.get('slug') }}" class="community-link">
            {{ host_community.get('name') }}
          </a>
        </section>
      {% endif %}
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('events.not_found') }}</h1>
      <p>{{ trans('events.not_found_message') }}</p>
      <p><a href="{{ lang_url('/events') }}">{{ trans('events.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
