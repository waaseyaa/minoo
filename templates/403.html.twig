{% extends "layouts/base.html.twig" %}

{% block title %}{{ status_code }} {{ title }} — Minoo{% endblock %}

{% block content %}
  <div class="flow-lg">
    <h1>{{ title }}</h1>
    <p>{{ detail }}</p>
    <p><a href="{{ lang_url('/login') }}?redirect={{ request_path|url_encode }}">{{ trans('error.403_signin') }}</a>, <a href="{{ lang_url('/') }}">{{ trans('error.403_home') }}</a>.</p>
  </div>
{% endblock %}
