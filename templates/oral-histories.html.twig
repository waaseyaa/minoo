{% extends "base.html.twig" %}

{% block title %}
  {%- if path == '/oral-histories' -%}
    Our Stories — Minoo
  {%- elseif collection is defined and collection -%}
    {{ collection.title }} — Minoo
  {%- elseif story is defined and story -%}
    {{ story.title }} — Minoo
  {%- else -%}
    Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block og_type %}{% if story is defined and story %}article{% else %}website{% endif %}{% endblock %}
{% block og_description %}{% if story is defined and story %}{{ story.summary|default('')|striptags|slice(0, 160) }}{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block content %}
  {% if path == '/oral-histories' %}
    {# ── Listing ── #}
    <div class="flow-lg">
      <div class="listing-hero">
        <h1>{{ trans('oral_histories.title') }}</h1>
        <p class="listing-hero__subtitle">{{ trans('oral_histories.subtitle') }}</p>
      </div>

      {% if collections is defined and collections|length > 0 %}
        <section>
          <h2>{{ trans('oral_histories.collections') }}</h2>
          <div class="card-grid">
            {% for c in collections %}
              {% include "components/collection-card.html.twig" with {
                title: c.title,
                slug: c.slug,
                description: c.description|default(''),
                season: c.season|default('all'),
                protocol_level: c.protocol_level|default('open'),
                story_count: c.story_count|default(0),
                curator_name: c.curator_name|default('')
              } %}
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if stories is defined and stories|length > 0 %}
        <section>
          <h2>{{ trans('oral_histories.stories') }}</h2>
          <div class="card-grid">
            {% for s in stories %}
              {% include "components/oral-history-card.html.twig" with {
                title: s.get('title'),
                url: '/oral-histories/' ~ s.get('slug'),
                type: s.get('oral_history_type')|default(''),
                is_living_record: s.get('is_living_record')|default(false),
                narrator_name: s.get('narrator_name')|default(''),
                community_name: s.get('community_name')|default(''),
                media_format: s.get('media_format')|default(''),
                media_duration: s.get('media_duration')|default(0),
                summary: s.get('summary')|default('')
              } %}
            {% endfor %}
          </div>
        </section>
      {% else %}
        {% include "components/empty-state.html.twig" with {
          heading: 'Stories are being gathered',
          body: 'Our community members and Knowledge Keepers are sharing their stories. Check back soon.',
          action_url: '/teachings',
          action_label: 'Explore Teachings'
        } %}
      {% endif %}
    </div>

  {% elseif collection is defined and collection %}
    {# ── Collection detail ── #}
    <div class="flow-lg detail">
      {% include "components/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: 'Home', url: '/'},
          {label: 'Oral Histories', url: '/oral-histories'},
          {label: collection.title}
        ]
      } %}

      <div class="detail-hero">
        <a href="/oral-histories" class="detail-hero__back">Back to Oral Histories</a>
        <h1 class="detail-hero__title">{{ collection.title }}</h1>
        {% if collection.description is defined and collection.description %}
          <p class="detail-hero__meta">{{ collection.description }}</p>
        {% endif %}
        <div class="detail-hero__badges">
          {% if collection.season is defined and collection.season and collection.season != 'all' %}
            <span class="badge">
              {% if collection.season == 'winter' %}❄️{% elseif collection.season == 'spring' %}🌱{% elseif collection.season == 'summer' %}☀️{% elseif collection.season == 'fall' %}🍂{% endif %}
              {{ collection.season|capitalize }}
            </span>
          {% endif %}
          {% if collection.protocol_level is defined and collection.protocol_level != 'open' %}
            <span class="badge">{{ collection.protocol_level|replace({'_': ' '})|capitalize }}</span>
          {% endif %}
        </div>
      </div>

      {% include "components/protocol-notice.html.twig" with { entity: collection } %}

      {% if collection_stories is defined and collection_stories|length > 0 %}
        {% set is_sequential = collection.story_cycle_order_type|default('') == 'sequential' %}
        {% if is_sequential %}
          <ol class="flow">
            {% for s in collection_stories %}
              <li>
                {% include "components/oral-history-card.html.twig" with {
                  title: s.get('title'),
                  url: '/oral-histories/' ~ s.get('slug'),
                  type: s.get('oral_history_type')|default(''),
                  is_living_record: s.get('is_living_record')|default(false),
                  narrator_name: s.get('narrator_name')|default(''),
                  community_name: s.get('community_name')|default(''),
                  media_format: s.get('media_format')|default(''),
                  media_duration: s.get('media_duration')|default(0),
                  summary: s.get('summary')|default('')
                } %}
              </li>
            {% endfor %}
          </ol>
        {% else %}
          <div class="card-grid">
            {% for s in collection_stories %}
              {% include "components/oral-history-card.html.twig" with {
                title: s.get('title'),
                url: '/oral-histories/' ~ s.get('slug'),
                type: s.get('oral_history_type')|default(''),
                is_living_record: s.get('is_living_record')|default(false),
                narrator_name: s.get('narrator_name')|default(''),
                community_name: s.get('community_name')|default(''),
                media_format: s.get('media_format')|default(''),
                media_duration: s.get('media_duration')|default(0),
                summary: s.get('summary')|default('')
              } %}
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}

      {% if collection.curator_name is defined and collection.curator_name %}
        <div class="teaching-source">
          <span class="teaching-source__label">Curated by</span>
          <span>{{ collection.curator_name }}</span>
        </div>
      {% endif %}
    </div>

  {% elseif story is defined and story and story.get('is_living_record') %}
    {# ── Living record detail ── #}
    <div class="flow-lg detail">
      {% include "components/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: 'Home', url: '/'},
          {label: 'Oral Histories', url: '/oral-histories'},
          {label: story.get('title')}
        ]
      } %}

      <div class="detail-hero">
        <a href="/oral-histories" class="detail-hero__back">Back to Oral Histories</a>
        <span class="detail-hero__badge card__badge--living-record">Living Record</span>
        <h1 class="detail-hero__title">{{ story.get('title') }}</h1>
      </div>

      {% include "components/protocol-notice.html.twig" with { entity: story } %}

      {% if story.get('summary') %}
        <div class="content-well">
          <div class="detail__body flow">
            <p>{{ story.get('summary') }}</p>
          </div>
        </div>
      {% endif %}

      {% if prev_story is defined or next_story is defined %}
        <nav class="detail-nav">
          {% if prev_story is defined and prev_story %}
            <a href="/oral-histories/{{ prev_story.get('slug') }}" class="detail-nav__prev">← {{ prev_story.get('title') }}</a>
          {% endif %}
          {% if next_story is defined and next_story %}
            <a href="/oral-histories/{{ next_story.get('slug') }}" class="detail-nav__next">{{ next_story.get('title') }} →</a>
          {% endif %}
        </nav>
      {% endif %}
    </div>

  {% elseif story is defined and story %}
    {# ── Story detail ── #}
    <div class="flow-lg detail">
      {% include "components/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: 'Home', url: '/'},
          {label: 'Oral Histories', url: '/oral-histories'},
          story_collection is defined and story_collection ? {label: story_collection.title, url: '/oral-histories/collections/' ~ story_collection.slug} : null,
          {label: story.get('title')}
        ]|filter(b => b is not null)
      } %}

      <div class="detail-hero">
        <a href="/oral-histories" class="detail-hero__back">Back to Oral Histories</a>
        {% if story.get('oral_history_type') %}
          <span class="detail-hero__badge">{{ story.get('oral_history_type')|capitalize }}</span>
        {% endif %}
        <h1 class="detail-hero__title">{{ story.get('title') }}</h1>

        <div class="detail-hero__meta">
          {% if contributor is defined and contributor %}
            {% if contributor.consent_public == 1 %}
              <p>Told by <a href="/contributors/{{ contributor.slug }}">{{ contributor.name }}</a></p>
            {% else %}
              <p>Told by {{ contributor.name }}</p>
            {% endif %}
          {% elseif story.get('narrator_name') %}
            <p>Told by {{ story.get('narrator_name') }}</p>
          {% endif %}

          {% if story.get('community_name') %}
            <p>{{ story.get('community_name') }}</p>
          {% endif %}

          {% if story.get('recorded_date') %}
            <p>Recorded {{ story.get('recorded_date')|date('F j, Y') }}</p>
          {% endif %}
        </div>
      </div>

      {% include "components/protocol-notice.html.twig" with { entity: story } %}

      {% if story.get('media_format') and not story.get('is_living_record') %}
        <div class="audio-player">
          {% if story.get('media_type') == 'self_hosted' and story.get('media_path') %}
            {% if story.get('media_format') == 'audio' %}
              <audio controls preload="metadata">
                <source src="/{{ story.get('media_path') }}">
              </audio>
            {% elseif story.get('media_format') == 'video' %}
              <video controls preload="metadata">
                <source src="/{{ story.get('media_path') }}">
              </video>
            {% endif %}
          {% elseif story.get('media_type') == 'external' and story.get('media_url') %}
            <iframe src="{{ story.get('media_url') }}" title="{{ story.get('title') }}" allowfullscreen></iframe>
          {% endif %}
        </div>
      {% endif %}

      {% if story.get('transcript') %}
        <div class="content-well">
          <div class="detail__body flow">
            {% for paragraph in story.get('transcript')|split("\n\n") %}
              <p>{{ paragraph }}</p>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {% if prev_story is defined or next_story is defined %}
        <nav class="detail-nav">
          {% if prev_story is defined and prev_story %}
            <a href="/oral-histories/{{ prev_story.get('slug') }}" class="detail-nav__prev">← {{ prev_story.get('title') }}</a>
          {% endif %}
          {% if next_story is defined and next_story %}
            <a href="/oral-histories/{{ next_story.get('slug') }}" class="detail-nav__next">{{ next_story.get('title') }} →</a>
          {% endif %}
        </nav>
      {% endif %}
    </div>

  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('oral_histories.not_found') }}</h1>
      <p>{{ trans('oral_histories.not_found_message') }}</p>
      <p><a href="/oral-histories">{{ trans('oral_histories.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
