      <ul class="how-it-works__list">
        <li>{{ trans('data.never_list_1') }}</li>
        <li>{{ trans('data.never_list_2') }}</li>
        <li>{{ trans('data.never_list_3') }}</li>
        <li>{{ trans('data.never_list_4') }}</li>
        <li>{{ trans('data.never_list_5') }}</li>
