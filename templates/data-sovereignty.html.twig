    <section class="flow">
      <h2>{{ trans('data.what_heading') }}</h2>
      <p>{{ trans('data.what_intro') }}</p>
      <ul class="how-it-works__list">
        <li>{{ trans('data.what_list_1') }}</li>
        <li>{{ trans('data.what_list_2') }}</li>
        <li>{{ trans('data.what_list_3') }}</li>
        <li>{{ trans('data.what_list_4') }}</li>
        <li>{{ trans('data.what_list_5') }}</li>
        <li>{{ trans('data.what_list_6') }}</li>
