{% extends "base.html.twig" %}

{% block title %}
  {%- if path == '/communities' -%}
    Communities — Minoo
  {%- elseif community is defined and community -%}
    {{ community.get('name') }} — Minoo
  {%- else -%}
    Community Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if path == '/communities' %}
    <div class="flow-lg">
      <h1>Communities</h1>
      <p class="hero__subtitle">The First Nations and municipalities of northern Ontario.{% if location is defined and location.hasLocation() %} Showing communities nearest to {{ location.communityName }}.{% endif %}</p>

      <div class="communities__filters">
        <a href="/communities" class="btn btn--sm{% if type_filter == '' %} btn--active{% endif %}">All</a>
        <a href="/communities?type=first_nation" class="btn btn--sm{% if type_filter == 'first_nation' %} btn--active{% endif %}">First Nations</a>
        <a href="/communities?type=municipality" class="btn btn--sm{% if type_filter == 'municipality' %} btn--active{% endif %}">Municipalities</a>
      </div>

      {% if location is defined and location.hasLocation() %}
        <p class="text-secondary">Sorted by distance from {{ location.communityName }}.</p>
      {% endif %}

      {% if communities is defined and communities|length > 0 %}
        <div class="card-grid">
          {% set province_names = {ON: 'Ontario', BC: 'British Columbia', AB: 'Alberta', SK: 'Saskatchewan', MB: 'Manitoba', QC: 'Quebec', NB: 'New Brunswick', NS: 'Nova Scotia', PE: 'Prince Edward Island', NL: 'Newfoundland & Labrador', YT: 'Yukon', NT: 'Northwest Territories', NU: 'Nunavut'} %}
          {% for c in communities %}
            <a href="/communities/{{ c.get('slug') }}" class="card card--community{% if location is defined and location.hasLocation() and loop.first %} card--nearest{% endif %}">
              <div class="card__body">
                {% set type_labels = {first_nation: 'First Nation', municipality: 'Municipality', town: 'Town', region: 'Region', city: 'City', settlement: 'Settlement'} %}
                <span class="card__badge card__badge--{{ c.get('community_type') }}">
                  {{ type_labels[c.get('community_type')] | default(c.get('community_type')|replace({'_': ' '})|capitalize) }}
                </span>
                <h3 class="card__title">{{ c.get('name') }}</h3>
                <div class="card__details">
                  {% if c.get('province') %}
                    <span>{{ province_names[c.get('province')] | default(c.get('province')) }}</span>
                  {% endif %}
                  {% if c.get('treaty') %}
                    <span>{{ c.get('treaty') }}</span>
                  {% endif %}
                  {% if c.get('language_group') %}
                    <span>{{ c.get('language_group') }}</span>
                  {% endif %}
                </div>
                {% if c.get('population') or c.get('website') %}
                  <div class="card__indicators">
                    {% if c.get('population') %}
                      <span class="card__indicator">Pop. {{ c.get('population')|number_format }}</span>
                    {% endif %}
                    {% if c.get('website') %}
                      <span class="card__indicator card__indicator--web">Web</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        {% include "components/empty-state.html.twig" with {
          heading: "No communities found",
          body: "No communities match your current filters. Try adjusting your search or removing filters.",
          action_url: "/communities",
          action_label: "View all communities"
        } %}
      {% endif %}
    </div>
  {% elseif community is defined and community %}
    {% set province_names = {ON: 'Ontario', BC: 'British Columbia', AB: 'Alberta', SK: 'Saskatchewan', MB: 'Manitoba', QC: 'Quebec', NB: 'New Brunswick', NS: 'Nova Scotia', PE: 'Prince Edward Island', NL: 'Newfoundland & Labrador', YT: 'Yukon', NT: 'Northwest Territories', NU: 'Nunavut'} %}
    <div class="flow-lg detail">
      <a href="/communities" class="detail__back">Communities</a>

      {# --- Header --- #}
      <div class="detail__header">
        {% set type_labels = {first_nation: 'First Nation', municipality: 'Municipality', town: 'Town', region: 'Region', city: 'City', settlement: 'Settlement'} %}
        <span class="card__badge card__badge--{{ community.get('community_type') }}">
          {{ type_labels[community.get('community_type')] | default(community.get('community_type')|replace({'_': ' '})|capitalize) }}
        </span>
        <h1>{{ community.get('name') }}</h1>
        <div class="detail__meta">
          {% if community.get('nation') %}
            <span>{{ community.get('nation') }}</span>
          {% endif %}
          {% if community.get('language_group') %}
            <span>{{ community.get('language_group') }}</span>
          {% endif %}
          {% if community.get('treaty') %}
            <span>{{ community.get('treaty') }}</span>
          {% endif %}
          {% if community.get('province') %}
            <span>{{ province_names[community.get('province')] | default(community.get('province')) }}</span>
          {% endif %}
        </div>
      </div>

      {# --- Website & digital presence --- #}
      {% if community.get('website') %}
        <div class="community__web">
          <a href="{{ community.get('website') }}" target="_blank" rel="noopener" class="community__website">
            {{ community.get('website')|replace({'https://': '', 'http://': '', 'www.': ''})|trim('/') }}
          </a>
        </div>
      {% endif %}

      {# --- Stat grid --- #}
      {% set has_stats = community.get('population') or community.get('treaty') or community.get('language_group') or community.get('reserve_name') or community.get('inac_id') %}
      {% if has_stats %}
        <div class="community__stats">
          {% if community.get('population') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('population')|number_format }}</span>
              <span class="community__stat-label">Population{% if community.get('population_year') %} ({{ community.get('population_year') }}){% endif %}</span>
            </div>
          {% endif %}

          {% if community.get('treaty') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('treaty') }}</span>
              <span class="community__stat-label">Treaty</span>
            </div>
          {% endif %}

          {% if community.get('language_group') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('language_group') }}</span>
              <span class="community__stat-label">Language Group</span>
            </div>
          {% endif %}

          {% if community.get('reserve_name') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('reserve_name') }}</span>
              <span class="community__stat-label">Reserve</span>
            </div>
          {% endif %}

          {% if community.get('inac_id') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('inac_id') }}</span>
              <span class="community__stat-label">INAC Band #</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# --- Leadership --- #}
      {% if people is defined and people and people|length > 0 %}
        <section class="community__section community__leadership">
          <h2 class="community__section-title">Leadership</h2>

          {% if people|filter(p => p.verified is defined and not p.verified)|length > 0 %}
            <p class="community__unverified">This information was sourced from community websites and may not be current.</p>
          {% endif %}

          {% set chief = null %}
          {% set councillors = [] %}
          {% for person in people %}
            {% if person.role == 'chief' and chief is null %}
              {% set chief = person %}
            {% else %}
              {% set councillors = councillors|merge([person]) %}
            {% endif %}
          {% endfor %}

          {% if chief %}
            <div class="community__chief">
              <div class="community__person">
                <span class="community__person-role">{{ chief.role_title|default('Chief') }}</span>
                <span class="community__person-name">{{ chief.name }}</span>
                {% if chief.email is defined and chief.email %}
                  <a href="mailto:{{ chief.email }}" class="community__person-contact">{{ chief.email }}</a>
                {% endif %}
                {% if chief.phone is defined and chief.phone %}
                  <a href="tel:{{ chief.phone }}" class="community__person-contact">{{ chief.phone }}</a>
                {% endif %}
              </div>
            </div>
          {% endif %}

          {% if councillors|length > 0 %}
            <div class="community__councillors">
              {% for person in councillors %}
                <div class="community__person">
                  <span class="community__person-role">{{ person.role_title|default(person.role|capitalize) }}</span>
                  <span class="community__person-name">{{ person.name }}</span>
                  {% if person.email is defined and person.email %}
                    <a href="mailto:{{ person.email }}" class="community__person-contact">{{ person.email }}</a>
                  {% endif %}
                  {% if person.phone is defined and person.phone %}
                    <a href="tel:{{ person.phone }}" class="community__person-contact">{{ person.phone }}</a>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </section>
      {% endif %}

      {# --- Band Office --- #}
      {% if band_office is defined and band_office %}
        <section class="community__section community__band-office">
          <h2 class="community__section-title">Band Office</h2>

          {% if band_office.verified is defined and not band_office.verified %}
            <p class="community__unverified">This information was sourced from community websites and may not be current.</p>
          {% endif %}

          {% set has_address = band_office.address_line1 is defined and band_office.address_line1 %}
          {% if has_address %}
            <address class="community__address">
              {{ band_office.address_line1 }}<br>
              {% if band_office.address_line2 is defined and band_office.address_line2 %}
                {{ band_office.address_line2 }}<br>
              {% endif %}
              {% if band_office.city is defined and band_office.city %}{{ band_office.city }}{% endif %}{% if band_office.province is defined and band_office.province %}, {{ band_office.province }}{% endif %}
              {% if band_office.postal_code is defined and band_office.postal_code %}  {{ band_office.postal_code }}{% endif %}
            </address>
            <a href="https://www.google.com/maps/search/{{ (band_office.address_line1 ~ ', ' ~ (band_office.city|default('')) ~ ', ' ~ (band_office.province|default('')))|url_encode }}"
               target="_blank" rel="noopener" class="community__maps-link">
              View on Google Maps
            </a>
          {% endif %}

          <div class="community__contact-grid">
            {% if band_office.phone is defined and band_office.phone %}
              <div class="community__contact-item">
                <span class="community__contact-label">Phone</span>
                <a href="tel:{{ band_office.phone }}">{{ band_office.phone }}</a>
              </div>
            {% endif %}
            {% if band_office.toll_free is defined and band_office.toll_free %}
              <div class="community__contact-item">
                <span class="community__contact-label">Toll-Free</span>
                <a href="tel:{{ band_office.toll_free }}">{{ band_office.toll_free }}</a>
              </div>
            {% endif %}
            {% if band_office.fax is defined and band_office.fax %}
              <div class="community__contact-item">
                <span class="community__contact-label">Fax</span>
                <span>{{ band_office.fax }}</span>
              </div>
            {% endif %}
            {% if band_office.email is defined and band_office.email %}
              <div class="community__contact-item">
                <span class="community__contact-label">Email</span>
                <a href="mailto:{{ band_office.email }}">{{ band_office.email }}</a>
              </div>
            {% endif %}
          </div>

          {% if band_office.office_hours is defined and band_office.office_hours %}
            <div class="community__office-hours">
              <span class="community__contact-label">Office Hours</span>
              <span>{{ band_office.office_hours }}</span>
            </div>
          {% endif %}
        </section>
      {% endif %}

      {# --- Location --- #}
      {% if community.get('latitude') and community.get('longitude') %}
        <section class="community__section">
          <h2 class="community__section-title">Location</h2>
          <p class="community__coords">
            {{ community.get('latitude')|number_format(4) }}° N, {{ community.get('longitude')|abs|number_format(4) }}° W
          </p>
          <a href="https://www.openstreetmap.org/?mlat={{ community.get('latitude') }}&mlon={{ community.get('longitude') }}#map=12/{{ community.get('latitude') }}/{{ community.get('longitude') }}"
             target="_blank" rel="noopener" class="community__map-link">
            View on OpenStreetMap
          </a>
        </section>
      {% endif %}

      {# --- Nearby communities --- #}
      {% if nearby is defined and nearby|length > 0 %}
        <section class="community__section">
          <h2 class="community__section-title">Nearby Communities</h2>
          <div class="community__nearby">
            {% for item in nearby %}
              {% set nc = item.community %}
              <a href="/communities/{{ nc.get('slug') }}" class="community__nearby-card">
                <span class="community__nearby-name">{{ nc.get('name') }}</span>
                <span class="community__nearby-distance">{{ item.distanceKm|number_format(0) }} km</span>
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

    </div>
  {% else %}
    <div class="flow-lg">
      <h1>Community Not Found</h1>
      <p>We couldn't find this community. It may have been removed or the link may be outdated.</p>
      <p><a href="/communities">Browse all communities</a></p>
    </div>
  {% endif %}
{% endblock %}
