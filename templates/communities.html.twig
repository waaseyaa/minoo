{% extends "base.html.twig" %}

{% block title %}
  {%- if path == '/communities' -%}
    Communities — Minoo
  {%- elseif community is defined and community -%}
    {{ community.get('name') }} — Minoo
  {%- else -%}
    Community Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if path == '/communities' %}
    <div class="flow-lg">
      <h1>Communities</h1>
      <p class="hero__subtitle">The First Nations and municipalities of northern Ontario. Each community has its own history, language, and treaty relationships. {% if location is defined and location.hasLocation() %}Showing communities nearest to {{ location.communityName }}.{% else %}Set your location to see what's nearby.{% endif %}</p>

      <div class="communities__filters">
        <a href="/communities" class="btn btn--sm{% if type_filter == '' %} btn--active{% endif %}">All</a>
        <a href="/communities?type=first_nation" class="btn btn--sm{% if type_filter == 'first_nation' %} btn--active{% endif %}">First Nations</a>
        <a href="/communities?type=municipality" class="btn btn--sm{% if type_filter == 'municipality' %} btn--active{% endif %}">Municipalities</a>
      </div>

      {% if location is defined and location.hasLocation() %}
        <p class="text-secondary">Sorted by distance from {{ location.communityName }}.</p>
      {% endif %}

      {% if communities is defined and communities|length > 0 %}
        <div class="card-grid">
          {% set province_names = {ON: 'Ontario', BC: 'British Columbia', AB: 'Alberta', SK: 'Saskatchewan', MB: 'Manitoba', QC: 'Quebec', NB: 'New Brunswick', NS: 'Nova Scotia', PE: 'Prince Edward Island', NL: 'Newfoundland & Labrador', YT: 'Yukon', NT: 'Northwest Territories', NU: 'Nunavut'} %}
          {% for c in communities %}
            <a href="/communities/{{ c.get('slug') }}" class="card card--community{% if location is defined and location.hasLocation() and loop.first %} card--nearest{% endif %}">
              <div class="card__body">
                {% set type_labels = {first_nation: 'First Nation', municipality: 'Municipality', town: 'Town', region: 'Region', city: 'City', settlement: 'Settlement'} %}
                <span class="card__badge card__badge--{{ c.get('community_type') }}">
                  {{ type_labels[c.get('community_type')] | default(c.get('community_type')|replace({'_': ' '})|capitalize) }}
                </span>
                <h3 class="card__title">{{ c.get('name') }}</h3>
                <div class="card__details">
                  {% if c.get('province') %}
                    <span>{{ province_names[c.get('province')] | default(c.get('province')) }}</span>
                  {% endif %}
                  {% if c.get('treaty') %}
                    <span>{{ c.get('treaty') }}</span>
                  {% endif %}
                  {% if c.get('language_group') %}
                    <span>{{ c.get('language_group') }}</span>
                  {% endif %}
                </div>
                {% if c.get('population') or c.get('website') %}
                  <div class="card__indicators">
                    {% if c.get('population') %}
                      <span class="card__indicator">Pop. {{ c.get('population')|number_format }}</span>
                    {% endif %}
                    {% if c.get('website') %}
                      <span class="card__indicator card__indicator--web">Web</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <p>No communities found.</p>
      {% endif %}
    </div>
  {% elseif community is defined and community %}
    {% set province_names = {ON: 'Ontario', BC: 'British Columbia', AB: 'Alberta', SK: 'Saskatchewan', MB: 'Manitoba', QC: 'Quebec', NB: 'New Brunswick', NS: 'Nova Scotia', PE: 'Prince Edward Island', NL: 'Newfoundland & Labrador', YT: 'Yukon', NT: 'Northwest Territories', NU: 'Nunavut'} %}
    <div class="flow-lg detail">
      <a href="/communities" class="detail__back">Communities</a>

      {# --- Header --- #}
      <div class="detail__header">
        {% set type_labels = {first_nation: 'First Nation', municipality: 'Municipality', town: 'Town', region: 'Region', city: 'City', settlement: 'Settlement'} %}
        <span class="card__badge card__badge--{{ community.get('community_type') }}">
          {{ type_labels[community.get('community_type')] | default(community.get('community_type')|replace({'_': ' '})|capitalize) }}
        </span>
        <h1>{{ community.get('name') }}</h1>
        <div class="detail__meta">
          {% if community.get('nation') %}
            <span>{{ community.get('nation') }}</span>
          {% endif %}
          {% if community.get('language_group') %}
            <span>{{ community.get('language_group') }}</span>
          {% endif %}
          {% if community.get('treaty') %}
            <span>{{ community.get('treaty') }}</span>
          {% endif %}
          {% if community.get('province') %}
            <span>{{ province_names[community.get('province')] | default(community.get('province')) }}</span>
          {% endif %}
        </div>
      </div>

      {# --- Website & digital presence --- #}
      {% if community.get('website') %}
        <div class="community__web">
          <a href="{{ community.get('website') }}" target="_blank" rel="noopener" class="community__website">
            {{ community.get('website')|replace({'https://': '', 'http://': '', 'www.': ''})|trim('/') }}
          </a>
        </div>
      {% endif %}

      {# --- Stat grid --- #}
      {% set has_stats = community.get('population') or community.get('treaty') or community.get('language_group') or community.get('reserve_name') or community.get('inac_id') %}
      {% if has_stats %}
        <div class="community__stats">
          {% if community.get('population') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('population')|number_format }}</span>
              <span class="community__stat-label">Population{% if community.get('population_year') %} ({{ community.get('population_year') }}){% endif %}</span>
            </div>
          {% endif %}

          {% if community.get('treaty') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('treaty') }}</span>
              <span class="community__stat-label">Treaty</span>
            </div>
          {% endif %}

          {% if community.get('language_group') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('language_group') }}</span>
              <span class="community__stat-label">Language Group</span>
            </div>
          {% endif %}

          {% if community.get('reserve_name') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('reserve_name') }}</span>
              <span class="community__stat-label">Reserve</span>
            </div>
          {% endif %}

          {% if community.get('inac_id') %}
            <div class="community__stat">
              <span class="community__stat-value">{{ community.get('inac_id') }}</span>
              <span class="community__stat-label">INAC Band #</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# --- Location --- #}
      {% if community.get('latitude') and community.get('longitude') %}
        <section class="community__section">
          <h2 class="community__section-title">Location</h2>
          <p class="community__coords">
            {{ community.get('latitude')|number_format(4) }}° N, {{ community.get('longitude')|abs|number_format(4) }}° W
          </p>
          <a href="https://www.openstreetmap.org/?mlat={{ community.get('latitude') }}&mlon={{ community.get('longitude') }}#map=12/{{ community.get('latitude') }}/{{ community.get('longitude') }}"
             target="_blank" rel="noopener" class="community__map-link">
            View on OpenStreetMap
          </a>
        </section>
      {% endif %}

      {# --- Nearby communities --- #}
      {% if nearby is defined and nearby|length > 0 %}
        <section class="community__section">
          <h2 class="community__section-title">Nearby Communities</h2>
          <div class="community__nearby">
            {% for item in nearby %}
              {% set nc = item.community %}
              <a href="/communities/{{ nc.get('slug') }}" class="community__nearby-card">
                <span class="community__nearby-name">{{ nc.get('name') }}</span>
                <span class="community__nearby-distance">{{ item.distanceKm|number_format(0) }} km</span>
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

    </div>
  {% else %}
    <div class="flow-lg">
      <h1>Community Not Found</h1>
      <p>The community at <code>{{ path }}</code> could not be found.</p>
      <p><a href="/communities">Browse all communities</a></p>
    </div>
  {% endif %}
{% endblock %}
