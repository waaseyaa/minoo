{% extends "layouts/base.html.twig" %}

{% block title %}
  {%- if path == '/contributors' -%}
    Contributors — Minoo
  {%- elseif contributor is defined and contributor -%}
    {{ contributor.get('name') }} — Minoo
  {%- else -%}
    Contributor Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if path == '/contributors' %}
    <div class="flow-lg">
      <div class="listing-hero">
        <h1>{{ trans('contributors.title') }}</h1>
        <p class="listing-hero__subtitle">{{ trans('contributors.subtitle') }}</p>
      </div>

      {% if contributors is defined and contributors|length > 0 %}
        <div class="card-grid">
          {% for c in contributors %}
            <a href="/contributors/{{ c.get('slug') }}" class="card">
              <h3 class="card__title">{{ c.get('name') }}</h3>
              {% if c.get('role') is not empty %}
                <span class="card__badge">{{ c.get('role')|capitalize }}</span>
              {% endif %}
              {% if c.get('bio') is not empty %}
                <p class="card__excerpt">{{ c.get('bio')|striptags|slice(0, 120) }}{% if c.get('bio')|length > 120 %}&hellip;{% endif %}</p>
              {% endif %}
            </a>
          {% endfor %}
        </div>
      {% else %}
        {% include "components/shared/feedback/empty-state.html.twig" with {
          heading: trans('contributors.empty_heading'),
          body: trans('contributors.empty_body'),
          action_url: lang_url('/language'),
          action_label: trans('contributors.explore_language')
        } %}
      {% endif %}
    </div>
  {% elseif contributor is defined and contributor %}
    <div class="flow-lg detail">
      {% include "components/shared/layout/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: 'Home', url: '/'},
          {label: 'Contributors', url: lang_url('/contributors')},
          {label: contributor.get('name')}
        ]
      } %}
      <div class="detail-hero">
        <a href="{{ lang_url('/contributors') }}" class="detail-hero__back">{{ trans('contributors.all_contributors') }}</a>
        {% if contributor.get('role') is not empty %}
          <span class="detail-hero__badge">{{ contributor.get('role')|capitalize }}</span>
        {% endif %}
        <h1 class="detail-hero__title">{{ contributor.get('name') }}</h1>
      </div>
      <div class="content-well">
        <div class="detail__body flow">
          {% for paragraph in contributor.get('bio')|default('')|split("\n\n") %}
            <p>{{ paragraph }}</p>
          {% endfor %}
        </div>
      </div>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('contributors.not_found') }}</h1>
      <p>{{ trans('contributors.not_found_message') }}</p>
      <p><a href="{{ lang_url('/contributors') }}">{{ trans('contributors.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
