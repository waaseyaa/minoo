{% extends "layouts/base.html.twig" %}

{% block title %}{{ trans('how.title') }} — Minoo{% endblock %}

{% block content %}
  <div class="content-well content-well--full">
  <div class="content-section flow-lg">
    <div>
      <h1>{{ trans('how.title') }}</h1>
      <p class="text-secondary">{{ trans('how.subtitle') }}</p>
    </div>

    <section class="flow">
      <h2>{{ trans('how.elders_heading') }}</h2>
      <ol class="how-it-works__list">
        <li>{{ trans('how.elders_list_1') }}</li>
        <li>{{ trans('how.elders_list_2') }}</li>
        <li>{{ trans('how.elders_list_3') }}</li>
        <li>{{ trans('how.elders_list_4') }}</li>
      </ol>
      <p><a href="{{ lang_url('/elders') }}" class="btn btn--primary">{{ trans('how.request_button') }}</a></p>
    </section>

    <section class="flow">
      <h2>{{ trans('how.volunteers_heading') }}</h2>
      <ol class="how-it-works__list">
        <li>{{ trans('how.volunteers_list_1') }}</li>
        <li>{{ trans('how.volunteers_list_2') }}</li>
        <li>{{ trans('how.volunteers_list_3') }}</li>
        <li>{{ trans('how.volunteers_list_4') }}</li>
      </ol>
      <p><a href="{{ lang_url('/volunteer') }}" class="btn btn--secondary">{{ trans('how.volunteer_button') }}</a></p>
    </section>

    <section class="flow">
      <h2>{{ trans('how.behalf_heading') }}</h2>
      <p>{{ trans('how.behalf_intro') }}</p>
      <ul class="how-it-works__list">
        <li>{{ trans('how.behalf_list_1') }}</li>
        <li>{{ trans('how.behalf_list_2') }}</li>
        <li>{{ trans('how.behalf_list_3') }}</li>
      </ul>
      <p>{{ trans('how.behalf_note') }}</p>
    </section>

    <section class="flow">
      <h2>{{ trans('how.faq_heading') }}</h2>
      <div class="flow">
        <div>
          <h3>{{ trans('how.faq_cost') }}</h3>
          <p>{{ trans('how.faq_cost_answer') }}</p>
        </div>
        <div>
          <h3>{{ trans('how.faq_screening') }}</h3>
          <p>{{ trans('how.faq_screening_answer') }}</p>
        </div>
        <div>
          <h3>{{ trans('how.faq_urgent') }}</h3>
          <p>{{ trans('how.faq_urgent_answer') }}</p>
        </div>
        <div>
          <h3>{{ trans('how.faq_cancel') }}</h3>
          <p>{{ trans('how.faq_cancel_answer') }}</p>
        </div>
      </div>
    </section>
  </div>
  </div>
{% endblock %}
