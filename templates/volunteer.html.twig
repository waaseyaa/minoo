{% extends "base.html.twig" %}

{% block title %}{{ trans('volunteer_page.title') }} — Minoo{% endblock %}

{% block content %}
  <div class="flow-lg">
    <section class="hero">
      <h1 class="hero__title">{{ trans('volunteer_page.title') }}</h1>
      <p class="hero__subtitle">{{ trans('volunteer_page.subtitle') }}</p>
      <div class="hero__actions">
        <a href="{{ lang_url('/elders/volunteer') }}" class="btn btn--primary btn--lg">{{ trans('volunteer_page.signup_button') }}</a>
        <a href="{{ lang_url('/login') }}" class="btn btn--secondary btn--lg">{{ trans('volunteer_page.login_button') }}</a>
      </div>
    </section>

    <section class="portal-section flow">
      <h2>{{ trans('volunteer_page.why_heading') }}</h2>
      <div class="how-it-works">
        <div class="how-it-works__step flow">
          <h3>{{ trans('volunteer_page.reason1_title') }}</h3>
          <p>{{ trans('volunteer_page.reason1_text') }}</p>
        </div>
        <div class="how-it-works__step flow">
          <h3>{{ trans('volunteer_page.reason2_title') }}</h3>
          <p>{{ trans('volunteer_page.reason2_text') }}</p>
        </div>
        <div class="how-it-works__step flow">
          <h3>{{ trans('volunteer_page.reason3_title') }}</h3>
          <p>{{ trans('volunteer_page.reason3_text') }}</p>
        </div>
      </div>
    </section>

    <section class="portal-section flow">
      <h2>{{ trans('volunteer_page.how_heading') }}</h2>
      <ol class="how-it-works__list">
        <li>{{ trans('volunteer_page.how_step1') }}</li>
        <li>{{ trans('volunteer_page.how_step2') }}</li>
        <li>{{ trans('volunteer_page.how_step3') }}</li>
        <li>{{ trans('volunteer_page.how_step4') }}</li>
      </ol>
      <p><a href="{{ lang_url('/how-it-works') }}">{{ trans('volunteer_page.learn_more') }}</a></p>
    </section>

    <div class="safety-callout flow">
      <h2>{{ trans('volunteer_page.safety_heading') }}</h2>
      <p>{{ trans('volunteer_page.safety_text') }}</p>
      <p><a href="{{ lang_url('/safety') }}">{{ trans('volunteer_page.safety_link') }}</a></p>
    </div>
  </div>
{% endblock %}
