{% extends "layouts/base.html.twig" %}

{% block title %}
  {%- if path == '/groups' -%}
    {{ trans('groups.title') }} — Minoo
  {%- elseif group is defined and group -%}
    {{ group.get('name') }} — Minoo
  {%- else -%}
    {{ trans('groups.not_found') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block og_type %}{% if path starts with '/groups/' and group is defined %}article{% else %}website{% endif %}{% endblock %}
{% block og_description %}{% if path starts with '/groups/' and group is defined %}{{ group.get('description')|default('')|striptags|slice(0, 160) }}{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block content %}
  {% if path == '/groups' %}
    <div class="flow-lg">
      <div class="listing-hero">
        <h1>{{ trans('groups.title') }}</h1>
        <p class="listing-hero__subtitle">{{ trans('groups.subtitle') }}</p>
      </div>

      {% if groups is defined and groups|length > 0 %}
        <div class="card-grid">
          {% for g in groups %}
            {% set comm = communities[g.get('community_id')]|default({}) %}
            {% include "components/domain/groups/card.html.twig" with {
              name: g.get('name'),
              type: g.get('type')|default('')|capitalize,
              region: g.get('region')|default(''),
              excerpt: g.get('description')|default('')|split("\n\n")|first|length > 120 ? g.get('description')|default('')|split("\n\n")|first|slice(0, 120) ~ '…' : g.get('description')|default('')|split("\n\n")|first,
              url: "/groups/" ~ g.get('slug'),
              community_name: comm.name|default(''),
              community_slug: comm.slug|default('')
            } %}
          {% endfor %}
        </div>
      {% else %}
        {% include "components/shared/feedback/empty-state.html.twig" with {
          heading: trans('groups.empty_heading'),
          body: trans('groups.empty_body'),
          action_url: lang_url('/communities'),
          action_label: trans('groups.explore_button')
        } %}
      {% endif %}
    </div>
  {% elseif group is defined and group %}
    <div class="flow-lg detail">
      {% include "components/shared/layout/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: trans('breadcrumb.home'), url: '/'},
          {label: trans('groups.title'), url: lang_url('/groups')},
          {label: group.get('name')}
        ]
      } %}
      <div class="detail-hero">
        <a href="{{ lang_url('/groups') }}" class="detail-hero__back">{{ trans('groups.detail_back') }}</a>
        {% if group.get('type') is not empty %}
          <span class="detail-hero__badge">{{ group.get('type')|capitalize }}</span>
        {% endif %}
        <h1 class="detail-hero__title">{{ group.get('name') }}</h1>
        <div class="detail__meta">
          {% if group.get('region') %}
            <span>{{ group.get('region') }}</span>
          {% endif %}
        </div>
      </div>
      <div class="content-well">
        <div class="detail__body flow">
          {% for paragraph in group.get('description')|default('')|split("\n\n") %}
            <p>{{ paragraph }}</p>
          {% endfor %}
        </div>
      </div>{# .content-well #}

      {% if related_people is defined and related_people|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('groups.related_people') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for person in related_people %}
              <a href="/people/{{ person.get('slug') }}" class="card card--compact">
                <h3 class="card__title">{{ person.get('name') }}</h3>
                {% if person.get('community') %}
                  <span class="card__meta">{{ person.get('community') }}</span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if related_events is defined and related_events|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('groups.related_events') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for event in related_events %}
              <a href="/events/{{ event.get('slug') }}" class="card card--compact">
                <h3 class="card__title">{{ event.get('title') }}</h3>
                {% if event.get('starts_at') %}
                  <span class="card__meta">{{ event.get('starts_at')|date('F j, Y') }}</span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if related_teachings is defined and related_teachings|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('groups.related_teachings') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for teaching in related_teachings %}
              <a href="/teachings/{{ teaching.get('slug') }}" class="card card--compact">
                <h3 class="card__title">{{ teaching.get('title') }}</h3>
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('groups.not_found') }}</h1>
      <p>{{ trans('groups.not_found_message') }}</p>
      <p><a href="{{ lang_url('/groups') }}">{{ trans('groups.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
