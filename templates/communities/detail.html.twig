{% extends 'base.html.twig' %}

{% block title %}{{ community.get('name') }} — Minoo{% endblock %}

{% block head %}
  <link rel="stylesheet" href="/css/leaflet.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="/css/leaflet.css"></noscript>
{% endblock %}

{% block content %}
  {% include "components/breadcrumb.html.twig" with {
    breadcrumbs: [
      {label: trans('breadcrumb.home'), url: '/'},
      {label: trans('communities.all_communities'), url: lang_url('/communities')},
      {label: community.get('name')}
    ]
  } %}

  {# --- Hero --- #}
  <div class="community-detail-hero">
    <div class="community-detail-hero__badge">
      {{ community.get('is_municipality') ? trans('community.municipality') : trans('community.first_nation') }}
    </div>
    <h1 class="community-detail-hero__name">{{ community.get('name') }}</h1>
    <div class="community-detail-hero__subtitle">
      {% set subtitle_parts = [] %}
      {% if community.get('nation') %}{% set subtitle_parts = subtitle_parts|merge([community.get('nation')]) %}{% endif %}
      {% if community.get('treaty') %}{% set subtitle_parts = subtitle_parts|merge([community.get('treaty')]) %}{% endif %}
      {% set subtitle_parts = subtitle_parts|merge([community.get('province')]) %}
      {{ subtitle_parts|join(' · ') }}
      {% if community.get('population') %}
        <span class="community-detail-hero__sep">·</span>
        <span>{{ trans('community.pop') }} {{ community.get('population')|number_format }}</span>
      {% endif %}
      {% if distance_from_user %}
        <span class="community-detail-hero__sep">·</span>
        <span>{{ distance_from_user|number_format(0) }} {{ trans('community.km_away') }}</span>
      {% endif %}
    </div>
    {# Inline metadata when About would be sparse #}
    {% if community.get('inac_id') or community.get('reserve_name') or community.get('language_group') or community.get('website') %}
    <div class="community-detail-hero__inline-meta">
      {% if community.get('language_group') %}<span>{{ community.get('language_group') }}</span>{% endif %}
      {% if community.get('reserve_name') %}<span>{{ community.get('reserve_name') }}</span>{% endif %}
      {% if community.get('inac_id') %}<span>Band #{{ community.get('inac_id') }}</span>{% endif %}
      {% if community.get('website') %}<a href="{{ community.get('website') }}" target="_blank" rel="noopener">{{ community.get('website')|replace({'https://': '', 'http://': ''})|trim('/') }}</a>{% endif %}
    </div>
    {% endif %}
  </div>

  {% include "components/domain/communities/contact-card.html.twig" with {
    people: people,
    band_office: band_office
  } %}

  {# --- The Land --- #}
  {% if community.get('latitude') and community.get('longitude') %}
  <div class="community-section">
    <div class="community-section__label">{{ trans('community.the_land') }}</div>
    <div id="atlas-detail-map" class="community-detail-map"></div>
    <div class="community-detail-coords">
      <span>{{ community.get('latitude')|number_format(4) }}° {{ community.get('latitude') >= 0 ? 'N' : 'S' }}, {{ community.get('longitude')|abs|number_format(4) }}° {{ community.get('longitude') < 0 ? 'W' : 'E' }}</span>
      <a href="https://www.openstreetmap.org/?mlat={{ community.get('latitude') }}&mlon={{ community.get('longitude') }}#map=13/{{ community.get('latitude') }}/{{ community.get('longitude') }}" target="_blank" rel="noopener">{{ trans('community.openstreetmap') }}</a>
      <a href="https://www.google.com/maps?q={{ community.get('latitude') }},{{ community.get('longitude') }}" target="_blank" rel="noopener">{{ trans('community.google_maps') }}</a>
    </div>
  </div>
  {% endif %}

  {# --- Local Events --- #}
  {% if local_events is defined and local_events|length > 0 %}
  <div class="community-section">
    <div class="community-section__label">{{ trans('community.local_events') }}</div>
    <div class="card-grid card-grid--compact">
      {% for event in local_events %}
        <a href="{{ lang_url('/events/' ~ event.get('slug')) }}" class="card card--compact">
          <h3 class="card__title">{{ event.get('title') }}</h3>
          {% if event.get('starts_at') %}
            <span class="card__meta">{{ event.get('starts_at')|date('F j, Y') }}</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# --- Local Teachings --- #}
  {% if local_teachings is defined and local_teachings|length > 0 %}
  <div class="community-section">
    <div class="community-section__label">{{ trans('community.local_teachings') }}</div>
    <div class="card-grid card-grid--compact">
      {% for teaching in local_teachings %}
        <a href="{{ lang_url('/teachings/' ~ teaching.get('slug')) }}" class="card card--compact">
          <h3 class="card__title">{{ teaching.get('title') }}</h3>
        </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# --- Local Businesses --- #}
  {% if local_businesses is defined and local_businesses|length > 0 %}
  <div class="community-section">
    <div class="community-section__label">{{ trans('community.local_businesses') }}</div>
    <div class="card-grid card-grid--compact">
      {% for business in local_businesses %}
        <a href="{{ lang_url('/businesses/' ~ business.get('slug')) }}" class="card card--compact">
          <h3 class="card__title">{{ business.get('name') }}</h3>
        </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# --- Local People --- #}
  {% if local_people is defined and local_people|length > 0 %}
  <div class="community-section">
    <div class="community-section__label">{{ trans('community.local_people') }}</div>
    <div class="card-grid card-grid--compact">
      {% for person in local_people %}
        <a href="{{ lang_url('/people/' ~ person.get('slug')) }}" class="card card--compact">
          <h3 class="card__title">{{ person.get('name') }}</h3>
        </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# --- Nearby Communities --- #}
  {% if nearby is not empty %}
  <div class="community-section">
    <div class="community-section__label">{{ trans('community.nearby_communities') }}</div>
    <div class="community-nearby-grid">
      {% for item in nearby %}
      <a href="{{ lang_url('/communities/' ~ item.community.get('slug')) }}" class="card card--compact card--community">
        <div class="card__title">{{ item.community.get('name') }}</div>
        <div class="card__meta">
          {{ item.community.get('is_municipality') ? trans('community.municipality') : item.community.get('nation') ?: trans('community.first_nation') }}
          · {{ item.distanceKm|number_format(0) }} {{ trans('community.km_away') }}
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

{% endblock %}

{% block scripts %}
{% if community.get('latitude') and community.get('longitude') %}
<script>
  window.__atlas_detail = {
    lat: {{ community.get('latitude') }},
    lng: {{ community.get('longitude') }},
    name: {{ community.get('name')|json_encode|raw }},
    nearby: [
      {% for item in nearby %}
      { lat: {{ item.community.get('latitude') }}, lng: {{ item.community.get('longitude') }}, name: {{ item.community.get('name')|json_encode|raw }}, slug: {{ item.community.get('slug')|json_encode|raw }} }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  };
</script>
<script src="/js/leaflet.js"></script>
<script src="/js/atlas-detail.js"></script>
{% endif %}
{% endblock %}
