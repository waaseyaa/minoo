{% extends "base.html.twig" %}

{% set page_path = path|default('/legal') %}

{% block title %}
  {%- if page_path == '/legal/privacy' -%}
    {{ trans('legal.privacy_title') }} — Minoo
  {%- elseif page_path == '/legal/terms' -%}
    {{ trans('legal.terms_title') }} — Minoo
  {%- elseif page_path == '/legal/accessibility' -%}
    {{ trans('legal.accessibility_title') }} — Minoo
  {%- else -%}
    {{ trans('legal.main_title') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  <div class="content-well content-well--full">
  <div class="content-section flow-lg">

    {% if page_path == '/legal/privacy' %}
      <div>
        <h1>{{ trans('legal.privacy_title') }}</h1>
        <p class="text-secondary">{{ trans('legal.privacy_updated') }}</p>
      </div>

      <section class="flow">
        <h2>{{ trans('legal.privacy_collect_heading') }}</h2>
        <p>{{ trans('legal.privacy_collect_intro') }}</p>
        <ul class="how-it-works__list">
          <li>{{ trans('legal.privacy_collect_contact') }}</li>
          <li>{{ trans('legal.privacy_collect_community') }}</li>
          <li>{{ trans('legal.privacy_collect_location') }}</li>
          <li>{{ trans('legal.privacy_collect_request') }}</li>
          <li>{{ trans('legal.privacy_collect_volunteer') }}</li>
        </ul>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.privacy_use_heading') }}</h2>
        <ul class="how-it-works__list">
          <li>{{ trans('legal.privacy_use_connect') }}</li>
          <li>{{ trans('legal.privacy_use_coordinators') }}</li>
          <li>{{ trans('legal.privacy_use_display') }}</li>
        </ul>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.privacy_location_heading') }}</h2>
        <p>{{ trans('legal.privacy_location_intro') }}</p>
        <ul class="how-it-works__list">
          <li>{{ trans('legal.privacy_location_nearest') }}</li>
          <li>{{ trans('legal.privacy_location_sort') }}</li>
          <li>{{ trans('legal.privacy_location_homepage') }}</li>
        </ul>
        <p>{{ trans('legal.privacy_location_optional') }}</p>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.privacy_storage_heading') }}</h2>
        <p>{{ trans('legal.privacy_storage_desc') }}</p>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.privacy_rights_heading') }}</h2>
        <p>{{ trans('legal.privacy_rights_desc') }}</p>
      </section>

    {% elseif page_path == '/legal/terms' %}
      <div>
        <h1>{{ trans('legal.terms_title') }}</h1>
        <p class="text-secondary">{{ trans('legal.terms_updated') }}</p>
      </div>

      <section class="flow">
        <h2>{{ trans('legal.terms_about_heading') }}</h2>
        <p>{{ trans('legal.terms_about_desc') }}</p>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.terms_responsibilities_heading') }}</h2>
        <ul class="how-it-works__list">
          <li>{{ trans('legal.terms_responsibilities_accurate') }}</li>
          <li>{{ trans('legal.terms_responsibilities_respect') }}</li>
          <li>{{ trans('legal.terms_responsibilities_safety') }}</li>
          <li>{{ trans('legal.terms_responsibilities_report') }}</li>
        </ul>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.terms_coordinator_heading') }}</h2>
        <p>{{ trans('legal.terms_coordinator_desc') }}</p>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.terms_liability_heading') }}</h2>
        <p>{{ trans('legal.terms_liability_desc') }}</p>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.terms_changes_heading') }}</h2>
        <p>{{ trans('legal.terms_changes_desc') }}</p>
      </section>

    {% elseif page_path == '/legal/accessibility' %}
      <div>
        <h1>{{ trans('legal.accessibility_title') }}</h1>
        <p class="text-secondary">{{ trans('legal.accessibility_updated') }}</p>
      </div>

      <section class="flow">
        <h2>{{ trans('legal.accessibility_commitment_heading') }}</h2>
        <p>{{ trans('legal.accessibility_commitment_desc') }}</p>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.accessibility_features_heading') }}</h2>
        <ul class="how-it-works__list">
          <li>{{ trans('legal.accessibility_features_semantic') }}</li>
          <li>{{ trans('legal.accessibility_features_skip') }}</li>
          <li>{{ trans('legal.accessibility_features_aria') }}</li>
          <li>{{ trans('legal.accessibility_features_contrast') }}</li>
          <li>{{ trans('legal.accessibility_features_forms') }}</li>
          <li>{{ trans('legal.accessibility_features_responsive') }}</li>
        </ul>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.accessibility_phone_heading') }}</h2>
        <p>{{ trans('legal.accessibility_phone_desc') }}</p>
      </section>

      <section class="flow">
        <h2>{{ trans('legal.accessibility_feedback_heading') }}</h2>
        <p>{{ trans('legal.accessibility_feedback_desc') }}</p>
      </section>

    {% else %}
      <div>
        <h1>{{ trans('legal.main_title') }}</h1>
        <p class="text-secondary">{{ trans('legal.main_subtitle') }}</p>
      </div>

      <div class="card-grid">
        <a href="{{ lang_url('/legal/privacy') }}" class="card">
          <div class="card__body">
            <h2 class="card__title">{{ trans('legal.main_privacy_title') }}</h2>
            <p class="card__meta">{{ trans('legal.main_privacy_desc') }}</p>
          </div>
        </a>
        <a href="{{ lang_url('/legal/terms') }}" class="card">
          <div class="card__body">
            <h2 class="card__title">{{ trans('legal.main_terms_title') }}</h2>
            <p class="card__meta">{{ trans('legal.main_terms_desc') }}</p>
          </div>
        </a>
        <a href="{{ lang_url('/legal/accessibility') }}" class="card">
          <div class="card__body">
            <h2 class="card__title">{{ trans('legal.main_accessibility_title') }}</h2>
            <p class="card__meta">{{ trans('legal.main_accessibility_desc') }}</p>
          </div>
        </a>
      </div>
    {% endif %}

  </div>
  </div>
{% endblock %}
