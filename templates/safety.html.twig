{% extends "base.html.twig" %}

{% block title %}{{ trans('safety.title') }} — Minoo{% endblock %}

{% block content %}
  <div class="content-section flow-lg">
    <div>
      <h1>{{ trans('safety.title') }}</h1>
      <p class="text-secondary">{{ trans('safety.subtitle') }}</p>
    </div>

    <section class="flow">
      <h2>{{ trans('safety.elders_heading') }}</h2>
      <ul class="how-it-works__list">
        <li>{{ trans('safety.elders_list_1') }}</li>
        <li>{{ trans('safety.elders_list_2') }}</li>
        <li>{{ trans('safety.elders_list_3') }}</li>
        <li>{{ trans('safety.elders_list_4') }}</li>
        <li>{{ trans('safety.elders_list_5') }}</li>
      </ul>
    </section>

    <section class="flow">
      <h2>{{ trans('safety.volunteers_heading') }}</h2>
      <ul class="how-it-works__list">
        <li>{{ trans('safety.volunteers_list_1') }}</li>
        <li>{{ trans('safety.volunteers_list_2') }}</li>
        <li>{{ trans('safety.volunteers_list_3') }}</li>
        <li>{{ trans('safety.volunteers_list_4') }}</li>
        <li>{{ trans('safety.volunteers_list_5') }}</li>
        <li>{{ trans('safety.volunteers_list_6') }}</li>
      </ul>
    </section>

    <section class="flow">
      <h2>{{ trans('safety.expect_heading') }}</h2>
      <p>{{ trans('safety.expect_intro') }}</p>
      <ul class="how-it-works__list">
        <li>{{ trans('safety.expect_list_1') }}</li>
        <li>{{ trans('safety.expect_list_2') }}</li>
        <li>{{ trans('safety.expect_list_3') }}</li>
        <li>{{ trans('safety.expect_list_4') }}</li>
      </ul>
    </section>

    <section class="flow">
      <h2>{{ trans('safety.concerns_heading') }}</h2>
      <p>{{ trans('safety.concerns_desc') }}</p>
      <div class="safety-callout">
        <p><strong>{{ trans('safety.emergency') }}</strong></p>
        <p>{{ trans('safety.emergency_note') }}</p>
      </div>
    </section>

    <div class="hero__actions">
      <a href="{{ lang_url('/elders') }}" class="btn btn--primary">{{ trans('safety.request_button') }}</a>
      <a href="{{ lang_url('/volunteer') }}" class="btn btn--secondary">{{ trans('safety.volunteer_button') }}</a>
    </div>
  </div>
{% endblock %}
