{% extends "base.html.twig" %}

{% block title %}
  {%- if path == '/teachings' -%}
    Teachings — Minoo
  {%- elseif teaching is defined and teaching -%}
    {{ teaching.get('title') }} — Minoo
  {%- else -%}
    Teaching Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if path == '/teachings' %}
    <div class="flow-lg">
      <h1>Teachings</h1>
      <p class="hero__subtitle">Living knowledge passed down through generations — culture, history, and language Teachings that guide how we live, relate, and care for the land. These aren't lessons from the past. They're wisdom for right now.</p>

      {% if teachings is defined and teachings|length > 0 %}
        <div class="card-grid">
          {% for t in teachings %}
            {% include "components/teaching-card.html.twig" with {
              title: t.get('title'),
              type: t.get('type')|default('')|capitalize,
              author: '',
              excerpt: t.get('content')|default('')|split("\n\n")|first|length > 120 ? t.get('content')|default('')|split("\n\n")|first|slice(0, 120) ~ '…' : t.get('content')|default('')|split("\n\n")|first,
              tags: [],
              url: "/teachings/" ~ t.get('slug')
            } %}
          {% endfor %}
        </div>
      {% else %}
        <p>No teachings available yet. Check back soon.</p>
      {% endif %}
    </div>
  {% elseif teaching is defined and teaching %}
    <div class="flow-lg detail">
      <a href="/teachings" class="detail__back">Teachings</a>
      <div class="detail__header">
        <span class="card__badge card__badge--teaching">{{ teaching.get('type')|default('')|capitalize }}</span>
        <h1>{{ teaching.get('title') }}</h1>
      </div>
      <div class="detail__body flow">
        {% for paragraph in teaching.get('content')|default('')|split("\n\n") %}
          <p>{{ paragraph }}</p>
        {% endfor %}
      </div>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>Teaching Not Found</h1>
      <p>The teaching at <code>{{ path }}</code> could not be found.</p>
      <p><a href="/teachings">Browse all teachings</a></p>
    </div>
  {% endif %}
{% endblock %}
