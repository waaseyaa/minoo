{% extends "base.html.twig" %}

{% block title %}
  {%- if path == '/teachings' -%}
    {{ trans('teachings.title') }} — Minoo
  {%- elseif teaching is defined and teaching -%}
    {{ teaching.get('title') }} — Minoo
  {%- else -%}
    {{ trans('teachings.not_found') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block og_type %}{% if path starts with '/teachings/' and teaching is defined %}article{% else %}website{% endif %}{% endblock %}
{% block og_description %}{% if path starts with '/teachings/' and teaching is defined %}{{ teaching.get('content')|default('')|striptags|slice(0, 160) }}{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block content %}
  {% if path == '/teachings' %}
    <div class="flow-lg">
      <div class="listing-hero">
        <h1>{{ trans('teachings.title') }}</h1>
        <p class="listing-hero__subtitle">{{ trans('teachings.subtitle') }}</p>
      </div>

      {% if teachings is defined and teachings|length > 0 %}
        <div class="card-grid">
          {% for t in teachings %}
            {% set comm = communities[t.get('community_id')]|default({}) %}
            {% include "components/teaching-card.html.twig" with {
              title: t.get('title'),
              type: t.get('type')|default('')|capitalize,
              author: '',
              excerpt: t.get('content')|default('')|split("\n\n")|first|length > 120 ? t.get('content')|default('')|split("\n\n")|first|slice(0, 120) ~ '…' : t.get('content')|default('')|split("\n\n")|first,
              tags: [],
              url: "/teachings/" ~ t.get('slug'),
              community_name: comm.name|default(''),
              community_slug: comm.slug|default('')
            } %}
          {% endfor %}
        </div>
      {% else %}
        {% include "components/empty-state.html.twig" with {
          heading: trans('teachings.empty_heading'),
          body: trans('teachings.empty_body'),
          action_url: lang_url('/language'),
          action_label: trans('teachings.explore_language')
        } %}
      {% endif %}
    </div>
  {% elseif teaching is defined and teaching %}
    <div class="flow-lg detail">
      {% include "components/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: trans('breadcrumb.home'), url: '/'},
          {label: trans('teachings.title'), url: lang_url('/teachings')},
          {label: teaching.get('title')}
        ]
      } %}
      <div class="detail-hero">
        <a href="{{ lang_url('/teachings') }}" class="detail-hero__back">{{ trans('teachings.detail_back') }}</a>
        {% if teaching.get('type') is not empty %}
          <span class="detail-hero__badge">{{ teaching.get('type')|capitalize }}</span>
        {% endif %}
        <h1 class="detail-hero__title">{{ teaching.get('title') }}</h1>
      </div>
      <div class="content-well">
        <div class="detail__body flow">
          {% for paragraph in teaching.get('content')|default('')|split("\n\n") %}
            <p>{{ paragraph }}</p>
          {% endfor %}
        </div>
      </div>{# .content-well #}

      {% if teaching.get('source') is not empty %}
        <div class="teaching-source">
          <span class="teaching-source__label">{{ trans('teachings.source_label') }}</span>
          <span>{{ teaching.get('source') }}</span>
        </div>
      {% endif %}

      {% if related_events is defined and related_events|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('teachings.related_events') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for event in related_events %}
              <a href="/events/{{ event.get('slug') }}" class="card card--compact">
                <span class="card__badge card__badge--event">{{ event.get('type')|default('')|capitalize }}</span>
                <h3 class="card__title">{{ event.get('title') }}</h3>
                {% if event.get('starts_at') %}
                  <span class="card__meta">{{ event.get('starts_at')|date('F j, Y') }}</span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if knowledge_keepers is defined and knowledge_keepers|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('teachings.knowledge_keepers') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for person in knowledge_keepers %}
              <a href="/people/{{ person.get('slug') }}" class="card card--compact">
                <h3 class="card__title">{{ person.get('name') }}</h3>
                {% if person.get('community') %}
                  <span class="card__meta">{{ person.get('community') }}</span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('teachings.not_found') }}</h1>
      <p>{{ trans('teachings.not_found_message') }}</p>
      <p><a href="{{ lang_url('/teachings') }}">{{ trans('teachings.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
