{% extends "layouts/base.html.twig" %}

{% block title %}{{ trans('account.welcome') }} — Minoo{% endblock %}

{% block content %}
<section class="account-home flow-lg">
  <div>
    <h1>{{ trans('account.welcome') }}{% if account is defined and account.getName() %}, {{ account.getName() }}{% endif %}</h1>
    <p class="text-secondary">{{ trans('account.subtitle') }}</p>
  </div>

  <div class="actions">
    <h2>{{ trans('account.profile') }}</h2>
    <ul class="links">
      <li><a href="{{ lang_url('/logout') }}" class="btn btn--outline">{{ trans('account.logout') }}</a></li>
    </ul>
  </div>

  <div class="actions">
    <h2>{{ trans('account.elder_status') }}</h2>
    {% if is_elder %}
      <p class="text-secondary">{{ trans('account.elder_identified') }}</p>
      <form method="post" action="/account/elder-toggle">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
        <button type="submit" class="btn btn--outline">{{ trans('account.elder_remove') }}</button>
      </form>
    {% else %}
      <p class="text-secondary">{{ trans('account.elder_question') }}</p>
      <form method="post" action="/account/elder-toggle">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
        <button type="submit" class="btn btn--primary">{{ trans('account.elder_identify') }}</button>
      </form>
    {% endif %}
  </div>

  {% if 'volunteer' in roles %}
  <div class="actions">
    <h2>{{ trans('account.elder_support') }}</h2>
    <p class="text-secondary">{{ trans('account.volunteer_text') }}</p>
    <ul class="links">
      <li><a href="{{ lang_url('/dashboard/volunteer') }}">{{ trans('account.my_assignments') }}</a></li>
    </ul>
  </div>
  {% endif %}

  {% if 'elder_coordinator' in roles %}
  <div class="actions">
    <h2>{{ trans('account.coordination') }}</h2>
    <p class="text-secondary">{{ trans('account.coordinator_text') }}</p>
    <ul class="links">
      <li><a href="{{ lang_url('/dashboard/coordinator') }}">{{ trans('account.coordinator_dashboard') }}</a></li>
    </ul>
  </div>
  {% endif %}

  {% if 'admin' in roles %}
  <div class="actions">
    <h2>{{ trans('admin.users_title') }}</h2>
    <p class="text-secondary">{{ trans('admin.users_subtitle') }}</p>
    <ul class="links">
      <li><a href="{{ lang_url('/admin/users') }}">{{ trans('admin.users_title') }}</a></li>
    </ul>
  </div>
  {% endif %}
</section>
{% endblock %}
