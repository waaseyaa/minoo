{% extends "layouts/base.html.twig" %}

{% block title %}Ingestion Dashboard — Minoo{% endblock %}

{% block content %}
<section class="content-section flow-lg">
  <h1 class="section-title">Ingestion Dashboard</h1>

  <div class="ingest-summary">
    <div class="ingest-summary__card">
      <span class="ingest-summary__label">Last Envelope Log</span>
      <span class="ingest-summary__value">
        {% if last_envelope_log %}
          {{ last_envelope_log|date('Y-m-d H:i') }}
        {% else %}
          No envelope logs yet
        {% endif %}
      </span>
    </div>
    <div class="ingest-summary__card">
      <span class="ingest-summary__label">NC Search Last Sync</span>
      <span class="ingest-summary__value">
        {% if nc_sync and nc_sync.last_sync|default('') %}
          {{ nc_sync.last_sync }}
        {% else %}
          No NC sync status
        {% endif %}
      </span>
    </div>
    <div class="ingest-summary__card">
      <span class="ingest-summary__label">Total Logs</span>
      <span class="ingest-summary__value">{{ total_count }}</span>
    </div>
    <div class="ingest-summary__card ingest-summary__card--approved">
      <span class="ingest-summary__label">Approved</span>
      <span class="ingest-summary__value">{{ status_counts.approved }}</span>
    </div>
    <div class="ingest-summary__card ingest-summary__card--pending">
      <span class="ingest-summary__label">Pending Review</span>
      <span class="ingest-summary__value">{{ status_counts.pending_review }}</span>
    </div>
    <div class="ingest-summary__card ingest-summary__card--failed">
      <span class="ingest-summary__label">Failed</span>
      <span class="ingest-summary__value">{{ status_counts.failed }}</span>
    </div>
    <div class="ingest-summary__card ingest-summary__card--rejected">
      <span class="ingest-summary__label">Rejected</span>
      <span class="ingest-summary__value">{{ status_counts.rejected }}</span>
    </div>
    <div class="ingest-summary__card">
      <span class="ingest-summary__label">NC Created</span>
      <span class="ingest-summary__value">{{ nc_sync.created|default(0) }}</span>
    </div>
    <div class="ingest-summary__card">
      <span class="ingest-summary__label">NC Skipped</span>
      <span class="ingest-summary__value">{{ nc_sync.skipped|default(0) }}</span>
    </div>
    <div class="ingest-summary__card ingest-summary__card--failed">
      <span class="ingest-summary__label">NC Failed</span>
      <span class="ingest-summary__value">{{ nc_sync.failed|default(0) }}</span>
    </div>
    <div class="ingest-summary__card">
      <span class="ingest-summary__label">NC Hits (last cycle)</span>
      <span class="ingest-summary__value">{{ nc_sync.fetched|default('—') }}</span>
    </div>
    <div class="ingest-summary__card">
      <span class="ingest-summary__label">NC Worker Cycles</span>
      <span class="ingest-summary__value">{{ nc_sync.cycles|default('—') }}</span>
    </div>
    <div class="ingest-summary__card{% if nc_sync.fetch_failed|default(false) %} ingest-summary__card--failed{% endif %}">
      <span class="ingest-summary__label">NC Fetch OK</span>
      <span class="ingest-summary__value">{% if nc_sync.fetch_failed|default(false) %}no{% else %}yes{% endif %}</span>
    </div>
  </div>

  <section class="ingest-nc-detail flow-md" aria-labelledby="ingest-nc-h">
    <h2 id="ingest-nc-h" class="section-title" style="font-size:1.15rem;">North Cloud → Minoo (search ingest)</h2>
    <p class="dashboard__lede" style="max-width:65ch;">
      The <code>minoo-nc-sync</code> service runs <code>scripts/nc-sync-worker.php</code> every <strong>30 minutes</strong>,
      pulls up to <strong>20</strong> recent hits from North Cloud Search (<code>topics[]=indigenous</code>, quality floor from config),
      and maps them to <strong>teaching</strong> / <strong>event</strong> rows (deduped on <code>source_url</code>).
      This page reads <code>storage/nc-sync-status.json</code>; the same payload is available at
      <a href="/api/admin/nc-sync-status"><code>/api/admin/nc-sync-status</code></a> (JSON).
    </p>
    {% if nc_sync.skip_reasons is defined and nc_sync.skip_reasons|length > 0 %}
      <div>
        <h3 class="section-title" style="font-size:1rem;">Skip reasons (last cycle)</h3>
        <dl class="ingest-skip-reasons">
          {% for reason, count in nc_sync.skip_reasons %}
            <div class="ingest-skip-reasons__row">
              <dt><code>{{ reason }}</code></dt>
              <dd>{{ count }}</dd>
            </div>
          {% endfor %}
        </dl>
      </div>
    {% endif %}
    {% if nc_sync.skipped_samples is defined and nc_sync.skipped_samples|length > 0 %}
      <details class="ingest-json-details">
        <summary>Skipped hit samples ({{ nc_sync.skipped_samples|length }})</summary>
        <pre class="ingest-json-pre">{{ nc_sync.skipped_samples|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
      </details>
    {% endif %}
    {% if nc_sync.created_samples is defined and nc_sync.created_samples|length > 0 %}
      <details class="ingest-json-details">
        <summary>Created hit samples ({{ nc_sync.created_samples|length }})</summary>
        <pre class="ingest-json-pre">{{ nc_sync.created_samples|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
      </details>
    {% endif %}
  </section>

  <nav class="ingest-filters" aria-label="Filter by status">
    <a href="/admin/ingestion" class="feed-chip{% if not status_filter %} feed-chip--active{% endif %}">All</a>
    <a href="/admin/ingestion?status=pending_review" class="feed-chip{% if status_filter == 'pending_review' %} feed-chip--active{% endif %}">Pending</a>
    <a href="/admin/ingestion?status=approved" class="feed-chip{% if status_filter == 'approved' %} feed-chip--active{% endif %}">Approved</a>
    <a href="/admin/ingestion?status=failed" class="feed-chip{% if status_filter == 'failed' %} feed-chip--active{% endif %}">Failed</a>
    <a href="/admin/ingestion?status=rejected" class="feed-chip{% if status_filter == 'rejected' %} feed-chip--active{% endif %}">Rejected</a>
  </nav>

  {% if logs|length > 0 %}
    <div class="ingest-table-wrap">
      <table class="ingest-table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Source</th>
            <th>Target Type</th>
            <th>Title</th>
            <th>Created</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          {% for log in logs %}
            <tr>
              <td colspan="6">
                <details class="ingest-row">
                  <summary class="ingest-row__summary">
                    <span class="ingest-badge ingest-badge--{{ log.get('status') }}">{{ log.get('status')|replace({'_': ' '}) }}</span>
                    <span class="ingest-row__cell">{{ log.get('source')|default('—') }}</span>
                    <span class="ingest-row__cell">{{ log.get('entity_type_target')|default('—') }}</span>
                    <span class="ingest-row__cell ingest-row__cell--title">{{ log.label()|default('—') }}</span>
                    <span class="ingest-row__cell ingest-row__cell--date">
                      {% if log.get('created_at') %}
                        {{ log.get('created_at')|date('Y-m-d H:i') }}
                      {% else %}
                        —
                      {% endif %}
                    </span>
                    <span class="ingest-row__cell ingest-row__cell--error">{{ log.get('error_message')|default('')|slice(0, 80) }}{% if log.get('error_message')|default('')|length > 80 %}…{% endif %}</span>
                  </summary>
                  <div class="ingest-row__detail">
                    <div class="ingest-row__section">
                      <h4>Actions</h4>
                      <div style="display:flex; gap:8px; flex-wrap:wrap;">
                        {% if log.get('status') == 'pending_review' %}
                          <form method="post" action="/api/admin/ingestion/{{ log.id() }}/approve">
                            <button type="submit" class="btn btn-secondary">Approve</button>
                          </form>
                          <form method="post" action="/api/admin/ingestion/{{ log.id() }}/reject">
                            <button type="submit" class="btn btn-secondary">Reject</button>
                          </form>
                        {% endif %}
                        {% if log.get('status') == 'approved' %}
                          <form method="post" action="/api/admin/ingestion/{{ log.id() }}/materialize">
                            <button type="submit" class="btn btn-primary">Materialize</button>
                          </form>
                        {% endif %}
                      </div>
                    </div>
                    {% if log.get('error_message') %}
                      <div class="ingest-row__section">
                        <h4>Error</h4>
                        <pre>{{ log.get('error_message') }}</pre>
                      </div>
                    {% endif %}
                    {% if log.get('payload_raw') %}
                      <div class="ingest-row__section">
                        <h4>Raw Payload</h4>
                        <pre>{{ log.get('payload_raw') }}</pre>
                      </div>
                    {% endif %}
                    {% if log.get('payload_parsed') %}
                      <div class="ingest-row__section">
                        <h4>Parsed Payload</h4>
                        <pre>{{ log.get('payload_parsed') }}</pre>
                      </div>
                    {% endif %}
                  </div>
                </details>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <p class="dashboard__empty">No ingest logs found{% if status_filter %} with status "{{ status_filter }}"{% endif %}.</p>
  {% endif %}
</section>
{% endblock %}
