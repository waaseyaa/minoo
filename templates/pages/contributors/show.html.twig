{% extends "layouts/base.html.twig" %}

{% block title %}
  {%- if contributor is defined and contributor -%}
    {{ contributor.get('name') }} — Minoo
  {%- else -%}
    Contributor Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if contributor is defined and contributor %}
    <div class="flow-lg detail">
      {% include "components/shared/layout/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: 'Home', url: '/'},
          {label: 'Contributors', url: lang_url('/contributors')},
          {label: contributor.get('name')}
        ]
      } %}
      <div class="detail-hero">
        <a href="{{ lang_url('/contributors') }}" class="detail-hero__back">{{ trans('contributors.all_contributors') }}</a>
        {% if contributor.get('role') is not empty %}
          <span class="detail-hero__badge">{{ contributor.get('role')|capitalize }}</span>
        {% endif %}
        <h1 class="detail-hero__title">{{ contributor.get('name') }}</h1>
      </div>
      <div class="content-well">
        <div class="detail__body flow">
          {% for paragraph in contributor.get('bio')|default('')|split("\n\n") %}
            <p>{{ paragraph }}</p>
          {% endfor %}
        </div>
      </div>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('contributors.not_found') }}</h1>
      <p>{{ trans('contributors.not_found_message') }}</p>
      <p><a href="{{ lang_url('/contributors') }}">{{ trans('contributors.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
