{% extends "layouts/base.html.twig" %}

{% block title %}
  {%- if event is defined and event -%}
    {{ event.get('title') }} — Minoo
  {%- else -%}
    {{ trans('events.not_found') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block og_type %}{% if event is defined and event %}article{% else %}website{% endif %}{% endblock %}
{% block og_description %}{% if event is defined and event %}{{ event.get('description')|default('')|striptags|slice(0, 160) }}{% else %}{{ parent() }}{% endif %}{% endblock %}
{% block og_image %}{% if event is defined and event %}{{ site_base_url }}/og/event/{{ event.get('slug') }}.png{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block content %}
  {% if event is defined and event %}
    <div class="flow-lg detail">
      {% include "components/shared/layout/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: trans('breadcrumb.home'), url: '/'},
          {label: trans('events.title'), url: lang_url('/events')},
          {label: event.get('title')}
        ]
      } %}
      {% include "components/shared/layout/hero-image.html.twig" with {
        image_url: image_url|default(''),
        alt: event.get('title'),
        credit: image_credit|default('')
      } %}
      {% set now = "now"|date("U") %}
      {% set start = event.get('starts_at') ? event.get('starts_at')|date("U") : null %}
      {% set end_date = event.get('ends_at') ? event.get('ends_at')|date("U") : null %}
      {% set source_url = event.get('source_url')|default('') %}
      {% set source_label = event.get('source')|default('') %}
      {% set verified_at = event.get('verified_at')|default(null) %}

      <a href="{{ lang_url('/events') }}" class="btn btn--ghost" style="margin-bottom: var(--space-sm); padding: 4px 0;">&larr; {{ trans('events.detail_back') }}</a>

      {% if event.get('type') is not empty %}
        <span class="badge badge--events">{{ event.get('type')|capitalize }}</span>
      {% endif %}
      <h1>{{ event.get('title') }}</h1>

      {% if start and end_date and now >= start and now <= end_date %}
        <span class="event-status event-status--active">{{ trans('events.status_happening') }}</span>
      {% elseif start and now < start %}
        <span class="event-status event-status--upcoming">{{ trans('events.status_upcoming') }}</span>
      {% elseif end_date and now > end_date %}
        <span class="event-status event-status--past">{{ trans('events.status_past') }}</span>
      {% endif %}

      <div class="detail__meta">
        {% if event.get('starts_at') %}
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {{ event.get('starts_at')|date('F j, Y') }}{% if event.get('ends_at') %} &ndash; {{ event.get('ends_at')|date('F j, Y') }}{% endif %}
          </span>
        {% endif %}
        {% if event.get('starts_at') %}
          <span>{{ event.get('starts_at')|relative_date }}</span>
        {% endif %}
        {% if event.get('location') %}
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {{ event.get('location') }}
          </span>
        {% endif %}
        {% if event.get('type') %}
          <span>{{ event.get('type')|capitalize }}</span>
        {% endif %}
        {% if host_community is defined and host_community %}
          <span><a href="/communities/{{ host_community.get('slug') }}">{{ host_community.get('name') }}</a></span>
        {% endif %}
      </div>

      <div class="detail__layout">
        <div class="detail__body flow">
          {% set description = event.get('description')|default('') %}
          {% if description|trim %}
            {% for paragraph in description|split("\n\n") %}
              {% if paragraph|trim %}
                <p>{{ paragraph }}</p>
              {% endif %}
            {% endfor %}
          {% else %}
            <p>{{ trans('events.no_description') }}</p>
          {% endif %}

          {% if source_url or source_label or verified_at %}
            <div class="detail__source">
              <p class="detail__source-title">{{ trans('events.source_title') }}</p>
              {% if source_url %}
                <a href="{{ source_url }}" target="_blank" rel="noopener noreferrer" class="detail__source-link">{{ trans('events.view_source') }}</a>
              {% endif %}
              {% if source_label or verified_at %}
                <p class="detail__source-meta">
                  {% if source_label %}
                    <span>{{ trans('events.source_name') }}: {{ source_label }}</span>
                  {% endif %}
                  {% if verified_at %}
                    <span>{{ trans('events.source_verified') }}: {{ verified_at|date('F j, Y') }}</span>
                  {% endif %}
                </p>
              {% endif %}
            </div>
          {% endif %}

          {% if event.get('slug') %}
            <a href="/events/{{ event.get('slug') }}.ics" class="btn btn--secondary" download>{{ trans('events.add_to_calendar') }}</a>
          {% endif %}
          {% if source_url %}
            <a href="{{ source_url }}" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">{{ trans('events.view_source') }}</a>
          {% endif %}
        </div>

        <aside class="detail__aside">
          {% if host_community is defined and host_community %}
            <div class="aside-card">
              <h3 class="aside-card__title">{{ trans('events.host_community') }}</h3>
              <a href="/communities/{{ host_community.get('slug') }}" class="community-link">
                {{ host_community.get('name') }}
              </a>
            </div>
          {% endif %}
        </aside>
      </div>

      {% if related_teachings is defined and related_teachings|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('events.related_teachings') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for teaching in related_teachings %}
              <a href="/teachings/{{ teaching.get('slug') }}" class="card card--compact">
                <span class="card__badge card__badge--teaching">{{ teaching.get('type')|default('')|capitalize }}</span>
                <h3 class="card__title">{{ teaching.get('title') }}</h3>
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if connected_people is defined and connected_people|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('events.people_connected') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for person in connected_people %}
              <a href="/people/{{ person.get('slug') }}" class="card card--compact">
                <h3 class="card__title">{{ person.get('name') }}</h3>
                {% if person.get('community') %}
                  <span class="card__meta">{{ person.get('community') }}</span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if similar_upcoming is defined and similar_upcoming|length > 0 %}
        <section class="related-section">
          <h2>{{ trans('events.similar_upcoming') }}</h2>
          <div class="card-grid card-grid--compact">
            {% for e in similar_upcoming %}
              {% include "components/domain/events/card.html.twig" with {
                title: e.get('title'),
                type: e.get('type')|default('')|capitalize,
                date: e.get('starts_at') ? e.get('starts_at')|date('F j, Y') : '',
                starts_at_iso: e.get('starts_at') ? e.get('starts_at')|date('c') : '',
                starts_at_raw: e.get('starts_at'),
                location: e.get('location')|default(''),
                excerpt: '',
                url: "/events/" ~ e.get('slug'),
                source_url: e.get('source_url')|default(''),
                source_name: e.get('source')|default(''),
                source_link_label: trans('events.source_card_label')
              } %}
            {% endfor %}
          </div>
        </section>
      {% endif %}
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('events.not_found') }}</h1>
      <p>{{ trans('events.not_found_message') }}</p>
      <p><a href="{{ lang_url('/events') }}">{{ trans('events.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
