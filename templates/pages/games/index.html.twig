{% extends "layouts/base.html.twig" %}

{% block title %}{{ trans('games.title') }} — Minoo{% endblock %}

{% block content %}
<div class="games-hub content-max">
    <header class="games-hub__header">
        <div class="games-hub__header-content">
            <h1 class="games-hub__title">{{ trans('games.title') }}</h1>
            <p class="games-hub__subtitle">{{ trans('games.subtitle') }}</p>
        </div>
    </header>

    <section class="games-hub__featured">
        <h2 class="visually-hidden">{{ trans('games.available_games') }}</h2>
        <a href="/games/shkoda" class="game-card game-card--featured">
            <div class="game-card__icon">
                <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
                    <ellipse class="game-card__glow" cx="40" cy="68" rx="24" ry="8" />
                    <path class="game-card__flame game-card__flame--outer" d="M40 10 C26 32, 18 54, 26 65 Q33 72, 40 68 Q47 72, 54 65 C62 54, 54 32, 40 10Z" />
                    <path class="game-card__flame game-card__flame--mid" d="M40 22 C30 38, 25 52, 30 62 Q35 67, 40 64 Q45 67, 50 62 C55 52, 50 38, 40 22Z" />
                    <path class="game-card__flame game-card__flame--inner" d="M40 34 C34 44, 31 54, 34 60 Q37 64, 40 62 Q43 64, 46 60 C49 54, 46 44, 40 34Z" />
                    <rect class="game-card__log" x="20" y="66" width="40" height="5" rx="2.5" />
                    <rect class="game-card__log game-card__log--cross" x="24" y="64" width="32" height="4" rx="2" transform="rotate(-6, 40, 66)" />
                </svg>
            </div>
            <div class="game-card__content">
                <span class="game-card__badge">{{ trans('games.word_game_badge') }}</span>
                <h3 class="game-card__title">{{ trans('games.shkoda_title') }}</h3>
                <p class="game-card__description">{{ trans('games.shkoda_description') }}</p>
                <span class="game-card__cta">{{ trans('games.play_now') }}</span>
            </div>
        </a>
        <a href="/games/crossword" class="game-card game-card--featured">
            <div class="game-card__icon">
                <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
                    <rect x="8" y="8" width="16" height="16" fill="currentColor" opacity="0.8" rx="2"/>
                    <rect x="26" y="8" width="16" height="16" fill="currentColor" opacity="0.8" rx="2"/>
                    <rect x="44" y="8" width="16" height="16" fill="currentColor" opacity="0.8" rx="2"/>
                    <rect x="62" y="8" width="10" height="16" fill="currentColor" opacity="0.15" rx="2"/>
                    <rect x="8" y="26" width="16" height="16" fill="currentColor" opacity="0.15" rx="2"/>
                    <rect x="26" y="26" width="16" height="16" fill="currentColor" opacity="0.8" rx="2"/>
                    <rect x="44" y="26" width="16" height="16" fill="currentColor" opacity="0.15" rx="2"/>
                    <rect x="8" y="44" width="16" height="16" fill="currentColor" opacity="0.8" rx="2"/>
                    <rect x="26" y="44" width="16" height="16" fill="currentColor" opacity="0.8" rx="2"/>
                    <rect x="44" y="44" width="16" height="16" fill="currentColor" opacity="0.8" rx="2"/>
                    <rect x="62" y="44" width="10" height="16" fill="currentColor" opacity="0.8" rx="2"/>
                    <rect x="26" y="62" width="16" height="10" fill="currentColor" opacity="0.8" rx="2"/>
                </svg>
            </div>
            <div class="game-card__content">
                <span class="game-card__badge">{{ trans('games.word_game_badge') }}</span>
                <h3 class="game-card__title">{{ trans('games.crossword_title') }}</h3>
                <p class="game-card__description">{{ trans('games.crossword_description') }}</p>
                <span class="game-card__cta">{{ trans('games.play_now') }}</span>
            </div>
        </a>
        <a href="/games/matcher" class="game-card game-card--featured">
            <div class="game-card__icon">
                <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
                    <circle cx="16" cy="20" r="6" fill="currentColor" opacity="0.8"/>
                    <circle cx="16" cy="40" r="6" fill="currentColor" opacity="0.8"/>
                    <circle cx="16" cy="60" r="6" fill="currentColor" opacity="0.8"/>
                    <circle cx="64" cy="20" r="6" fill="currentColor" opacity="0.8"/>
                    <circle cx="64" cy="40" r="6" fill="currentColor" opacity="0.8"/>
                    <circle cx="64" cy="60" r="6" fill="currentColor" opacity="0.8"/>
                    <line x1="22" y1="20" x2="58" y2="40" stroke="currentColor" stroke-width="2" opacity="0.5"/>
                    <line x1="22" y1="40" x2="58" y2="60" stroke="currentColor" stroke-width="2" opacity="0.5"/>
                    <line x1="22" y1="60" x2="58" y2="20" stroke="currentColor" stroke-width="2" opacity="0.5"/>
                </svg>
            </div>
            <div class="game-card__content">
                <span class="game-card__badge">{{ trans('games.word_game_badge') }}</span>
                <h3 class="game-card__title">{{ trans('games.word_match_title') }}</h3>
                <p class="game-card__description">{{ trans('games.word_match_description') }}</p>
                <span class="game-card__cta">{{ trans('games.play_now') }}</span>
            </div>
        </a>
        <a href="/games/agim" class="game-card game-card--featured">
            <div class="game-card__icon">
                <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
                    <text x="10" y="38" font-size="28" font-family="monospace" fill="currentColor" opacity="0.9">1</text>
                    <text x="32" y="52" font-size="22" font-family="monospace" fill="currentColor" opacity="0.7">2</text>
                    <text x="52" y="40" font-size="20" font-family="monospace" fill="currentColor" opacity="0.6">3</text>
                    <text x="18" y="68" font-size="16" font-family="monospace" fill="currentColor" opacity="0.5">4</text>
                    <text x="56" y="65" font-size="14" font-family="monospace" fill="currentColor" opacity="0.4">5</text>
                </svg>
            </div>
            <div class="game-card__content">
                <span class="game-card__badge">{{ trans('games.number_game_badge') }}</span>
                <h3 class="game-card__title">{{ trans('games.agim_title') }}</h3>
                <p class="game-card__description">{{ trans('games.agim_description') }}</p>
                <span class="game-card__cta">{{ trans('games.play_now') }}</span>
            </div>
        </a>
        <a href="/games/guess-price" class="game-card game-card--featured">
            <div class="game-card__icon">
                <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
                    <ellipse cx="40" cy="58" rx="22" ry="8" fill="currentColor" opacity="0.2"/>
                    <path fill="currentColor" opacity="0.85" d="M28 22h24c3 0 6 2 6 6v28H22V28c0-4 3-6 6-6z"/>
                    <text x="40" y="46" text-anchor="middle" font-size="18" font-weight="700" fill="currentColor">$</text>
                    <circle cx="52" cy="30" r="5" fill="currentColor" opacity="0.5"/>
                </svg>
            </div>
            <div class="game-card__content">
                <span class="game-card__badge">{{ trans('games.live_game_badge') }}</span>
                <h3 class="game-card__title">{{ trans('games.guess_price_title') }}</h3>
                <p class="game-card__description">{{ trans('games.guess_price_description') }}</p>
                <span class="game-card__cta">{{ trans('games.play_now') }}</span>
            </div>
        </a>
    </section>

    <section class="games-hub__coming">
        <h2 class="games-hub__section-title">{{ trans('games.more_coming') }}</h2>
        <div class="games-hub__coming-grid">
            <div class="game-card game-card--placeholder">
                <div class="game-card__placeholder-icon">
                    <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <span class="game-card__placeholder-label">{{ trans('games.listening_quiz') }}</span>
            </div>
            <div class="game-card game-card--placeholder">
                <div class="game-card__placeholder-icon">
                    <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <span class="game-card__placeholder-label">{{ trans('games.sentence_builder') }}</span>
            </div>
        </div>
    </section>
</div>
{% endblock %}
