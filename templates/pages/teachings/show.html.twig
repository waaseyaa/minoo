{% extends "layouts/base.html.twig" %}

{% block title %}
  {%- if teaching is defined and teaching -%}
    {{ teaching.get('title') }} — Minoo
  {%- else -%}
    {{ trans('teachings.not_found') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block og_type %}{% if teaching is defined and teaching %}article{% else %}website{% endif %}{% endblock %}
{% block og_description %}{% if teaching is defined and teaching %}{{ teaching.get('content')|default('')|striptags|slice(0, 160) }}{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block content %}
  {% if teaching is defined and teaching %}
    <div class="flow-lg detail">
      {% include "components/shared/layout/breadcrumb.html.twig" with {
        breadcrumbs: [
          {label: trans('breadcrumb.home'), url: '/'},
          {label: trans('teachings.title'), url: lang_url('/teachings')},
          {label: teaching.get('title')}
        ]
      } %}
      {% include "components/shared/layout/hero-image.html.twig" with {
        image_url: image_url|default(''),
        alt: teaching.get('title'),
        credit: image_credit|default('')
      } %}
      <a href="{{ lang_url('/teachings') }}" class="btn btn--ghost" style="margin-bottom: var(--space-sm); padding: 4px 0;">&larr; Back</a>
      <span class="badge badge--teachings">{{ teaching.get('type')|default('Teaching')|capitalize }}</span>
      <h1>{{ teaching.get('title') }}</h1>

      {% if teaching.get('duration') is defined and teaching.get('duration') is not empty or teaching.get('language') is defined and teaching.get('language') is not empty %}
        <div class="detail__meta">
          {% if teaching.get('duration') is not empty %}
            <span>{{ teaching.get('duration') }}</span>
          {% endif %}
          {% if teaching.get('language') is not empty %}
            <span>{{ teaching.get('language') }}</span>
          {% endif %}
        </div>
      {% endif %}

      <div class="detail__layout">
        <div class="detail__body flow">
          {% for paragraph in teaching.get('content')|default('')|split("\n\n") %}
            <p>{{ paragraph }}</p>
          {% endfor %}

          {% if teaching.get('source') is not empty %}
            <div class="teaching-source">
              <span class="teaching-source__label">{{ trans('teachings.source_label') }}</span>
              <span>{{ teaching.get('source') }}</span>
            </div>
          {% endif %}
        </div>

        <aside class="detail__aside">
          {% if knowledge_keepers is defined and knowledge_keepers|length > 0 %}
            <div class="aside-card">
              <h3 class="aside-card__title">{{ trans('teachings.knowledge_keepers') }}</h3>
              {% for person in knowledge_keepers %}
                <a href="/people/{{ person.get('slug') }}" class="card card--compact">
                  <h3 class="card__title">{{ person.get('name') }}</h3>
                  {% if person.get('community') %}
                    <span class="card__meta">{{ person.get('community') }}</span>
                  {% endif %}
                </a>
              {% endfor %}
            </div>
          {% endif %}

          {% if related_events is defined and related_events|length > 0 %}
            <div class="aside-card">
              <h3 class="aside-card__title">{{ trans('teachings.related_events') }}</h3>
              {% for event in related_events %}
                <a href="/events/{{ event.get('slug') }}" class="card card--compact">
                  <span class="card__badge card__badge--event">{{ event.get('type')|default('')|capitalize }}</span>
                  <h3 class="card__title">{{ event.get('title') }}</h3>
                  {% if event.get('starts_at') %}
                    <span class="card__meta">{{ event.get('starts_at')|date('F j, Y') }}</span>
                  {% endif %}
                </a>
              {% endfor %}
            </div>
          {% endif %}
        </aside>
      </div>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('teachings.not_found') }}</h1>
      <p>{{ trans('teachings.not_found_message') }}</p>
      <p><a href="{{ lang_url('/teachings') }}">{{ trans('teachings.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
