{% extends "base.html.twig" %}

{% block title %}
  {%- if path == '/language' -%}
    Language — Minoo
  {%- elseif entry is defined and entry -%}
    {{ entry.get('word') }} — Minoo
  {%- else -%}
    Entry Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if path == '/language' %}
    <div class="flow-lg">
      <h1>Language</h1>
      <p class="hero__subtitle">Anishinaabemowin carries a worldview that English cannot. Explore words, meanings, and the structure of a language that has been spoken on this land for thousands of years.</p>

      {% if entries is defined and entries|length > 0 %}
        <div class="card-grid">
          {% for e in entries %}
            {% include "components/dictionary-entry-card.html.twig" with {
              word: e.get('word'),
              part_of_speech: e.get('part_of_speech')|default(''),
              definition: e.get('definition')|default(''),
              example: '',
              tags: [],
              url: "/language/" ~ e.get('slug')
            } %}
          {% endfor %}
        </div>
      {% else %}
        {% include "components/empty-state.html.twig" with {
          heading: "No dictionary entries yet",
          body: "Anishinaabemowin words, meanings, and example sentences will appear here as speakers and language learners contribute. Language carries a worldview that translation alone cannot.",
          action_url: "/teachings",
          action_label: "Explore Teachings"
        } %}
      {% endif %}

      <footer class="attribution">
        <p>Dictionary content is copyrighted by <a href="http://ojibwe.lib.umn.edu" rel="external noopener">The Ojibwe People's Dictionary</a> and used under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" rel="external noopener">CC BY-NC-SA 4.0</a>.</p>
      </footer>
    </div>
  {% elseif entry is defined and entry %}
    <div class="flow-lg detail">
      <a href="/language" class="detail__back">Language</a>
      <div class="detail__header">
        <span class="card__badge card__badge--language">{{ entry.get('part_of_speech')|default('') }}</span>
        <h1>{{ entry.get('word') }}</h1>
        <div class="detail__meta">
          <span>{{ entry.get('definition')|default('') }}</span>
        </div>
      </div>
      <div class="detail__body flow">
        <p>{{ entry.get('definition')|default('') }}</p>
      </div>

      <footer class="attribution">
        <p>Dictionary content is copyrighted by <a href="http://ojibwe.lib.umn.edu" rel="external noopener">The Ojibwe People's Dictionary</a> and used under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" rel="external noopener">CC BY-NC-SA 4.0</a>.</p>
      </footer>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>Entry Not Found</h1>
      <p>The dictionary entry at <code>{{ path }}</code> could not be found.</p>
      <p><a href="/language">Browse all entries</a></p>
    </div>
  {% endif %}
{% endblock %}
