{% extends "layouts/base.html.twig" %}

{% block title %}
  {%- if path == '/language/search' -%}
    {{ trans('language.search_results_title') }} — Minoo
  {%- elseif path == '/language' -%}
    {{ trans('language.title') }} — Minoo
  {%- elseif entry is defined and entry -%}
    {{ entry.get('word') }} — Minoo
  {%- else -%}
    {{ trans('language.not_found') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if path == '/language/search' %}
    <div class="flow-lg">
      <h1>{{ trans('language.search_results_title') }}</h1>

      <form action="{{ lang_url('/language/search') }}" method="get" class="search-form">
        <input type="text" name="q" value="{{ search_query|default('') }}" placeholder="{{ trans('language.search_placeholder') }}" class="search-form__input" aria-label="{{ trans('language.search_placeholder') }}">
        <button type="submit" class="btn btn--primary">{{ trans('language.search_button') }}</button>
      </form>

      {% if search_query is defined and search_query != '' %}
        {% if search_results is defined and search_results|length > 0 %}
          <p class="listing-hero__count">{{ search_total }} {{ trans('language.search_results_count') }}</p>

          <div class="card-grid">
            {% for result in search_results %}
              {% include "components/domain/language/entry-card.html.twig" with {
                word: result.lemma|default(result.word|default('')),
                part_of_speech: result.word_class_normalized|default(result.part_of_speech|default('')),
                definition: result.definitions|default(result.definition|default('')),
                attribution_source: result.attribution_source|default(''),
                attribution_url: result.attribution_url|default(''),
                example: '',
                tags: [],
                url: result.slug is defined ? "/language/" ~ result.slug : ''
              } %}
            {% endfor %}
          </div>
        {% else %}
          <p>{{ trans('language.search_no_results') }}</p>
          <p><a href="{{ lang_url('/language') }}">{{ trans('language.browse_all') }}</a></p>
        {% endif %}
      {% endif %}

      <p><a href="{{ lang_url('/language') }}">{{ trans('language.browse_all') }}</a></p>
    </div>
  {% elseif path == '/language' %}
    <div class="flow-lg">
      <h1>{{ trans('language.title') }}</h1>
      <p class="listing-hero__subtitle">{{ trans('language.subtitle') }}</p>

      <form action="{{ lang_url('/language/search') }}" method="get" class="search-form">
        <input type="text" name="q" placeholder="{{ trans('language.search_placeholder') }}" class="search-form__input" aria-label="{{ trans('language.search_placeholder') }}">
        <button type="submit" class="btn btn--primary">{{ trans('language.search_button') }}</button>
      </form>

      {% if entries is defined and entries|length > 0 %}
        {% if total_entries is defined %}
          <p class="listing-hero__count">{{ total_entries }} {{ trans('language.entries_label') }}</p>
        {% endif %}

        <div class="card-grid">
          {% for e in entries %}
            {% include "components/domain/language/entry-card.html.twig" with {
              word: e.get('word'),
              part_of_speech: e.get('part_of_speech')|default(''),
              definition: e.get('definition')|default(''),
              attribution_source: e.get('attribution_source')|default(''),
              attribution_url: e.get('attribution_url')|default(''),
              example: '',
              tags: [],
              url: "/language/" ~ e.get('slug')
            } %}
          {% endfor %}
        </div>

        {% if total_pages is defined and total_pages > 1 %}
          <nav class="pagination" aria-label="Dictionary pages">
            {% if current_page > 1 %}
              <a href="{{ lang_url('/language') }}?page={{ current_page - 1 }}" class="pagination__link">← {{ trans('language.prev') }}</a>
            {% endif %}
            <span class="pagination__info">{{ trans('language.page') }} {{ current_page }} / {{ total_pages }}</span>
            {% if current_page < total_pages %}
              <a href="{{ lang_url('/language') }}?page={{ current_page + 1 }}" class="pagination__link">{{ trans('language.next') }} →</a>
            {% endif %}
          </nav>
        {% endif %}
      {% else %}
        {% include "components/empty-state.html.twig" with {
          heading: trans('language.empty_heading'),
          body: trans('language.empty_body'),
          action_url: lang_url('/teachings'),
          action_label: trans('language.explore_teachings')
        } %}
      {% endif %}

      <footer class="attribution">
        <p>{{ trans('language.copyright') }}</p>
      </footer>
    </div>
  {% elseif entry is defined and entry %}
    <div class="flow-lg detail">
      <a href="{{ lang_url('/language') }}" class="detail__back">{{ trans('language.detail_back') }}</a>
      <div class="detail__header">
        <span class="card__badge card__badge--language">{{ entry.get('part_of_speech')|default('') }}</span>
        <h1>{{ entry.get('word') }}</h1>
      </div>
      <div class="content-well">
        <div class="detail__body flow">
          <p>{{ entry.get('definition')|default('') }}</p>
          {% if inflected_forms is defined and inflected_forms %}
            <p>{{ inflected_forms|join(' · ') }}</p>
          {% endif %}
        </div>

        <footer class="attribution">
          {% if entry.get('attribution_source') %}
            <p>
              {% if entry.get('attribution_url') %}
                <a href="{{ entry.get('attribution_url') }}" rel="external noopener">{{ entry.get('attribution_source') }}</a>
              {% else %}
                {{ entry.get('attribution_source') }}
              {% endif %}
            </p>
          {% endif %}
          <p>{{ trans('language.copyright') }}</p>
        </footer>
      </div>{# .content-well #}
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('language.not_found') }}</h1>
      <p>{{ trans('language.not_found_message') }}</p>
      <p><a href="{{ lang_url('/language') }}">{{ trans('language.browse_all') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
