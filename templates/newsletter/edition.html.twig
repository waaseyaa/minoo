<!DOCTYPE html>
<html lang="{{ edition.get('langcode') ?: 'en' }}">
<head>
    <meta charset="UTF-8">
    <title>{{ edition.get('headline') }}</title>
    <style>
        @page {
            size: Letter;
            margin: 0.6in 0.65in 0.8in;
            @bottom-center {
                content: counter(page) "   ·   Powered by minoo.live";
                font-family: Georgia, serif;
                font-size: 8pt;
                color: #888;
            }
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Georgia, "Times New Roman", serif;
            font-size: 12pt;
            line-height: 1.5;
            color: #1a1a1a;
            background: #fff;
            max-width: 8.5in;
            margin: 0 auto;
        }

        /* ---------- Page wrapper ---------- */
        .page {
            page-break-after: always;
            position: relative;
        }
        .page:last-child { page-break-after: auto; }

        /* Page numbers and footer handled by @page @bottom-center */

        /* ---------- Cover / Masthead ---------- */
        .cover {
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            text-align: center;
        }
        .cover .newsletter-title {
            font-size: 32pt;
            font-weight: bold;
            letter-spacing: 1pt;
            margin-top: 1.2in;
            padding-bottom: 0.15in;
            border-bottom: 4px solid #1a1a1a;
        }
        .cover .subtitle {
            font-size: 13pt;
            font-style: italic;
            color: #555;
            margin-top: 0.1in;
        }
        .cover .masthead-info {
            font-size: 11pt;
            color: #444;
            margin-top: 0.6in;
        }
        .cover .issue-info {
            font-size: 16pt;
            font-weight: bold;
            margin-top: 0.4in;
        }
        .cover .welcome-box {
            margin-top: 0.8in;
            padding: 0.3in;
            border: 2px solid #1a1a1a;
            text-align: left;
            font-size: 13pt;
            line-height: 1.5;
        }
        .cover .toc {
            margin-top: 0.6in;
            text-align: left;
            font-size: 12pt;
            line-height: 2;
            padding-left: 0.5in;
        }
        .cover .toc span.toc-page {
            float: right;
            padding-right: 0.5in;
            color: #666;
        }

        /* ---------- Section headers ---------- */
        h2 {
            font-size: 16pt;
            text-transform: uppercase;
            letter-spacing: 1pt;
            border-bottom: 2px solid #1a1a1a;
            padding-bottom: 0.06in;
            margin-bottom: 0.25in;
            margin-top: 0.1in;
        }
        h3 {
            font-size: 13pt;
            margin-top: 0.15in;
            margin-bottom: 0.05in;
        }
        p {
            margin-bottom: 0.08in;
        }

        /* ---------- Section intro ---------- */
        .section-intro {
            font-style: italic;
            color: #444;
            font-size: 12pt;
            margin-bottom: 0.2in;
            border-left: 3px solid #999;
            padding-left: 0.15in;
        }

        /* ---------- Article blocks ---------- */
        article {
            margin-bottom: 0.15in;
        }

        /* ---------- Prose indent ---------- */
        .prose p {
            text-indent: 0.2in;
        }
        .prose p:first-of-type {
            text-indent: 0;
        }

        /* ---------- Boxed sections ---------- */
        .boxed {
            border: 2px solid #1a1a1a;
            padding: 0.2in;
            margin-bottom: 0.25in;
        }
        .boxed h3 {
            margin-top: 0;
        }

        /* ---------- Two-column layout ---------- */
        .two-col {
            column-count: 2;
            column-gap: 0.35in;
            column-rule: 1px solid #ccc;
        }

        /* ---------- Horoscope items ---------- */
        .horoscope-item {
            margin-bottom: 0.1in;
            break-inside: avoid;
        }
        .horoscope-item h3 {
            font-size: 11pt;
            margin-top: 0;
            margin-bottom: 0.02in;
        }
        .horoscope-item p {
            font-size: 11pt;
            line-height: 1.4;
            text-indent: 0;
        }

        /* ---------- Puzzle grid ---------- */
        .word-search-grid {
            font-family: "Courier New", monospace;
            font-size: 14pt;
            line-height: 1.8;
            letter-spacing: 0.15in;
            text-align: center;
            margin: 0.2in 0;
        }
        .word-list {
            column-count: 3;
            column-gap: 0.3in;
            font-size: 12pt;
            margin-top: 0.15in;
        }
        .word-list span {
            display: block;
        }

        /* ---------- Quote block ---------- */
        blockquote {
            border-left: 4px solid #1a1a1a;
            padding-left: 0.2in;
            margin: 0.2in 0;
            font-style: italic;
            font-size: 15pt;
            line-height: 1.5;
        }
        blockquote cite {
            display: block;
            font-style: normal;
            font-size: 12pt;
            margin-top: 0.1in;
            color: #555;
        }

        /* ---------- Source line ---------- */
        .source-line {
            text-indent: 0;
            font-size: 10pt;
            color: #666;
            margin-top: 0.05in;
        }

        /* ---------- Event detail lines ---------- */
        .event-detail {
            text-indent: 0;
            margin-bottom: 0.06in;
        }

        /* ---------- Events two-column ---------- */
        .events-grid {
            column-count: 2;
            column-gap: 0.3in;
            column-rule: 1px solid #ccc;
        }
        .events-grid article {
            break-inside: avoid;
            margin-bottom: 0.15in;
        }
        .events-grid h3 {
            font-size: 12pt;
            margin-top: 0;
        }
        .events-grid p {
            font-size: 11pt;
        }

        /* ---------- Mini calendar ---------- */
        .mini-cal {
            float: right;
            margin: 0 0 0.2in 0.25in;
            border: 2px solid #1a1a1a;
            border-collapse: collapse;
            font-size: 10pt;
            line-height: 1.3;
        }
        .mini-cal caption {
            font-weight: bold;
            font-size: 11pt;
            padding: 0.06in 0;
            border-bottom: 2px solid #1a1a1a;
        }
        .mini-cal th {
            font-size: 9pt;
            font-weight: normal;
            color: #666;
            padding: 0.04in 0.08in;
            text-align: center;
        }
        .mini-cal td {
            text-align: center;
            padding: 0.04in 0.08in;
            font-size: 10pt;
        }
        .mini-cal td.has-event {
            font-weight: bold;
            background: #e8e8e8;
        }

        /* ---------- Drop cap ---------- */
        .drop-cap::first-letter {
            float: left;
            font-size: 3.2em;
            line-height: 0.8;
            padding-right: 0.06in;
            padding-top: 0.04in;
            font-weight: bold;
        }

        /* ---------- Signature block ---------- */
        .signature {
            margin-top: 0.4in;
            font-style: italic;
            text-indent: 0;
        }

        /* ---------- Attribution ---------- */
        .attribution {
            text-indent: 0;
            margin-top: 0.15in;
            font-style: italic;
        }

        /* ---------- Featured word box ---------- */
        .featured-word {
            border: 2px solid #1a1a1a;
            text-align: center;
            padding: 0.35in 0.4in;
            margin-bottom: 0.25in;
        }
        .featured-word .word {
            font-size: 28pt;
            font-weight: bold;
            margin-bottom: 0.08in;
            text-indent: 0;
        }
        .featured-word .pronunciation {
            font-size: 15pt;
            font-style: italic;
            color: #555;
            margin-bottom: 0.15in;
            text-indent: 0;
        }
        .featured-word .meaning {
            font-size: 16pt;
            text-indent: 0;
        }
        .featured-word .example {
            font-size: 13pt;
            color: #444;
            margin-top: 0.12in;
            text-indent: 0;
        }

        /* ---------- Vocabulary list ---------- */
        .vocab-list {
            text-indent: 0;
            margin-top: 0.15in;
        }
        .vocab-item {
            margin-bottom: 0.12in;
            text-indent: 0;
        }

        /* ---------- Visual vocab grid ---------- */
        .vocab-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.2in;
            margin-top: 0.2in;
        }
        .vocab-card {
            border: 1.5px solid #1a1a1a;
            padding: 0.12in 0.15in;
            text-align: center;
            break-inside: avoid;
        }
        .vocab-card svg {
            display: block;
            margin: 0 auto 0.06in;
        }
        .vocab-card .vocab-word {
            font-size: 14pt;
            font-weight: bold;
            margin-bottom: 0.02in;
        }
        .vocab-card .vocab-pron {
            font-size: 9pt;
            font-style: italic;
            color: #666;
            margin-bottom: 0.04in;
        }
        .vocab-card .vocab-meaning {
            font-size: 11pt;
        }

        /* ---------- Joke styling ---------- */
        .joke {
            margin-bottom: 0.25in;
            padding-bottom: 0.15in;
            border-bottom: 1px dotted #ccc;
        }
        .joke:last-child {
            border-bottom: none;
        }
        .joke p {
            text-indent: 0;
        }

        /* ---------- Puzzle styling ---------- */
        .puzzle-text {
            text-indent: 0;
        }

        /* ---------- No-indent utility ---------- */
        .no-indent { text-indent: 0; }

        /* ---------- Photo caption ---------- */
        .photo-wrap {
            text-align: center;
            margin-bottom: 0.25in;
        }
        .photo-wrap img {
            width: 3.5in;
            border: 3px solid #1a1a1a;
        }
        .photo-caption {
            font-size: 10pt;
            color: #555;
            font-style: italic;
            margin-top: 0.05in;
            text-indent: 0;
        }

        /* ---------- Back page ---------- */
        .back-page-box {
            border: 2px solid #1a1a1a;
            padding: 0.25in;
            margin-top: 0.3in;
        }
        .back-page-box h3 {
            text-align: center;
            margin-top: 0;
            margin-bottom: 0.15in;
        }
        .contact-line {
            font-size: 12pt;
            margin-bottom: 0.1in;
            text-indent: 0;
        }

        /* ---------- Partners block ---------- */
        .partners {
            text-align: center;
            margin-top: 0.25in;
        }
        .partners-label {
            font-size: 9pt;
            color: #888;
            text-indent: 0;
            letter-spacing: 1pt;
            text-transform: uppercase;
            margin-bottom: 0.15in;
        }
        .partners-logos {
            display: inline-flex;
            align-items: center;
            gap: 0.6in;
        }

        /* ---------- Colophon ---------- */
        .colophon {
            text-align: center;
            margin-top: 0.15in;
        }
        .colophon p {
            font-size: 11pt;
            color: #555;
            text-indent: 0;
        }
        .closing {
            text-align: center;
            margin-top: 0.3in;
            font-size: 11pt;
            color: #888;
        }

        /* ---------- Divider ---------- */
        hr {
            border: none;
            border-top: 1px solid #ccc;
            margin: 0.25in 0;
        }

        /* ---------- Keep together ---------- */
        .keep-together { break-inside: avoid; page-break-inside: avoid; }

        /* ---------- Print resets ---------- */
        @media print {
            body { background: #fff; }
            a { color: #000; text-decoration: none; }
        }

        {% if review_mode|default(false) %}
        /* --- Review draft watermark --- */
        body::before {
            content: "REVIEW DRAFT — NOT FOR PRINT";
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-35deg);
            font-size: 48pt;
            font-family: Arial, sans-serif;
            font-weight: bold;
            color: rgba(0, 0, 0, 0.06);
            white-space: nowrap;
            z-index: 9999;
            pointer-events: none;
        }

        /* --- Collaborator annotation box --- */
        .collaborator-note {
            border: 2px dashed #000;
            padding: 0.2in;
            margin-top: 0.2in;
            break-inside: avoid;
            page-break-inside: avoid;
        }
        .collaborator-note h4 {
            font-size: 13pt;
            font-weight: bold;
            margin-bottom: 0.08in;
            border-bottom: 1px solid #000;
            padding-bottom: 0.05in;
        }
        .collaborator-note p {
            font-size: 11pt;
            line-height: 1.4;
            margin-bottom: 0.06in;
        }
        .collaborator-note ul {
            font-size: 11pt;
            line-height: 1.4;
            margin-left: 0.25in;
            margin-bottom: 0.06in;
        }
        {% endif %}
    </style>
</head>
<body>

{# ============================================================
   PAGE 1 — Cover
   ============================================================ #}
<div class="page cover">
    <div class="newsletter-title">Minoo Newsletter</div>
    <div class="subtitle">For Communities</div>
    <div class="issue-info">
        Vol. {{ edition.get('volume') }} &middot; Issue {{ edition.get('issue_number') }}
        &middot; {{ edition.get('publish_date') }}
    </div>
    <div class="masthead-info">
        Serving the communities of the North Shore, Robinson Huron Treaty territory
    </div>

    {% if items_by_section['cover'] is defined %}
        {% for item in items_by_section['cover'] %}
            {% if item.get('included') %}
                <div class="welcome-box">{{ item.get('inline_body')|raw }}</div>
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 2 — Keeper's Note (Editor's Note)
   ============================================================ #}
<div class="page">
    <h2>Keeper&rsquo;s Note</h2>
    {% if items_by_section['editors_note'] is defined %}
        {% for item in items_by_section['editors_note'] %}
            {% if item.get('included') %}
                <div class="prose">{{ item.get('inline_body')|raw }}</div>
            {% endif %}
        {% endfor %}
    {% endif %}
</div>

{# ============================================================
   PAGE 3 — Community News
   ============================================================ #}
<div class="page">
    <h2>Community News</h2>
    <div class="section-intro">What is happening around the community this month.</div>

    {% if items_by_section['news'] is defined %}
        {% for item in items_by_section['news'] %}
            {% if item.get('included') %}
            <article class="prose">
                {% if item.get('source_type') and source_entities[item.id()] is defined %}
                    {% set src = source_entities[item.id()] %}
                    <h3>{{ src.label() ?: src.get('title') }}</h3>
                    {% if item.get('editor_blurb') %}
                        <p>{{ item.get('editor_blurb') }}</p>
                    {% else %}
                        <p>{{ src.get('body')|default(src.get('description'))|striptags|slice(0, 400) }}</p>
                    {% endif %}
                    {% if src.get('source_attribution') %}
                        <p class="source-line"><em>{{ src.get('source_attribution') }}</em></p>
                    {% endif %}
                {% else %}
                    <h3>{{ item.get('inline_title') }}</h3>
                    <div>{{ item.get('inline_body')|raw }}</div>
                {% endif %}
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 4 — Events Calendar
   ============================================================ #}
<div class="page">
    <h2>Events Calendar</h2>
    <div class="section-intro">Upcoming events across the North Shore.</div>

    <div class="events-grid">
    {% if items_by_section['events'] is defined %}
        {% for item in items_by_section['events'] %}
            {% if item.get('included') %}
            <article>
                {% if item.get('source_type') and source_entities[item.id()] is defined %}
                    {% set src = source_entities[item.id()] %}
                    <h3>{{ src.label() ?: src.get('title') }}</h3>
                    {% if src.get('event_date') %}
                        <p class="event-detail"><strong>When:</strong> {{ src.get('event_date') }}</p>
                    {% endif %}
                    {% if src.get('location') %}
                        <p class="event-detail"><strong>Where:</strong> {{ src.get('location') }}</p>
                    {% endif %}
                    {% if item.get('editor_blurb') %}
                        <p>{{ item.get('editor_blurb') }}</p>
                    {% elseif src.get('description') %}
                        <p>{{ src.get('description')|striptags|slice(0, 200) }}</p>
                    {% endif %}
                {% else %}
                    <h3>{{ item.get('inline_title') }}</h3>
                    <div>{{ item.get('inline_body')|raw }}</div>
                {% endif %}
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}
    </div>

</div>

{# ============================================================
   PAGE 5 — Teachings
   ============================================================ #}
<div class="page">
    <h2>Teachings</h2>
    <div class="section-intro">Seasonal knowledge passed down through generations.</div>

    {% if items_by_section['teachings'] is defined %}
        {% for item in items_by_section['teachings'] %}
            {% if item.get('included') %}
            <article class="prose">
                {% if item.get('source_type') and source_entities[item.id()] is defined %}
                    {% set src = source_entities[item.id()] %}
                    <h3>{{ src.label() ?: src.get('title') }}</h3>
                    {% if src.get('source') or src.get('knowledge_keeper') %}
                        <div class="attribution">
                            {{ src.get('knowledge_keeper') ?: src.get('source') }}
                        </div>
                    {% endif %}
                    {% if item.get('editor_blurb') %}
                        <p>{{ item.get('editor_blurb') }}</p>
                    {% else %}
                        <p>{{ src.get('body')|default(src.get('description'))|striptags|slice(0, 500) }}</p>
                    {% endif %}
                {% else %}
                    <h3>{{ item.get('inline_title') }}</h3>
                    <div>{{ item.get('inline_body')|raw }}</div>
                {% endif %}
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 6 — Language Corner
   ============================================================ #}
<div class="page">
    <h2>Language Corner</h2>
    <div class="section-intro">A word to carry with you this month.</div>

    {# Featured word from dictionary entity #}
    {% if items_by_section['language'] is defined %}
        {% for item in items_by_section['language'] %}
            {% if item.get('included') %}
                {% if item.get('source_type') and source_entities[item.id()] is defined %}
                    {% set src = source_entities[item.id()] %}
                    <div class="featured-word">
                        <p class="word">{{ src.label() ?: src.get('word') }}</p>
                        {% if src.get('pronunciation') %}
                            <p class="pronunciation">{{ src.get('pronunciation') }}</p>
                        {% endif %}
                        <p class="meaning"><strong>{{ src.get('definition') }}</strong></p>
                        {% if src.get('example_sentence') %}
                            <p class="example">&ldquo;{{ src.get('example_sentence') }}&rdquo;</p>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="featured-word">
                        <p class="word">{{ item.get('inline_title') }}</p>
                        <div>{{ item.get('inline_body')|raw }}</div>
                    </div>
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {# Anishinaabemowin Corner inline content (vocab, phrases, etc.) #}
    {% if items_by_section['language_corner'] is defined %}
        {% for item in items_by_section['language_corner'] %}
            {% if item.get('included') %}
            <article>
                {% if item.get('inline_title') %}
                    <h3>{{ item.get('inline_title') }}</h3>
                {% endif %}
                <div>{{ item.get('inline_body')|raw }}</div>
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if review_mode|default(false) %}
    <div class="collaborator-note">
        <h4>Note for Language Collaborators</h4>
        <p>This section is reserved for Anishinaabemowin language content.
           We are looking for contributions that help readers connect with the language
           in an accessible, everyday way.</p>
        <p><strong>What we are looking for:</strong></p>
        <ul>
            <li>Vocabulary (5-10 words with pronunciation and definitions)</li>
            <li>Common phrases or greetings for the season</li>
            <li>Cultural context for how words are used in ceremony or daily life</li>
        </ul>
        <p><strong>Space available:</strong> Approximately 200-300 words
           (half a printed page in the newsletter layout above).</p>
        <p><strong>To submit:</strong> Email your content to the Minoo editorial team,
           or share via a document link. We will format it to match the newsletter style.</p>
        <p><strong>Timeline:</strong> Content received before the print deadline will be
           included in this issue. Otherwise, it will appear in the next issue.</p>
    </div>
    {% endif %}

</div>

{# ============================================================
   PAGE 7 — Community Voices
   ============================================================ #}
<div class="page">
    <h2>Community Voices</h2>
    <div class="section-intro">Stories and memories from our communities.</div>

    {% if items_by_section['community'] is defined %}
        {% for item in items_by_section['community'] %}
            {% if item.get('included') %}
            <article class="prose">
                {% if item.get('source_type') and source_entities[item.id()] is defined %}
                    {% set src = source_entities[item.id()] %}
                    <h3>{{ src.label() ?: src.get('title') }}</h3>
                    {% if src.get('author_name') or src.get('community') %}
                        <div class="attribution">
                            {{ src.get('author_name') }}
                            {% if src.get('community') %}, {{ src.get('community') }}{% endif %}
                        </div>
                    {% endif %}
                    {% if item.get('editor_blurb') %}
                        <p>{{ item.get('editor_blurb') }}</p>
                    {% else %}
                        <p>{{ src.get('body')|default(src.get('submission_text'))|striptags|slice(0, 600) }}</p>
                    {% endif %}
                {% else %}
                    <h3>{{ item.get('inline_title') }}</h3>
                    <div>{{ item.get('inline_body')|raw }}</div>
                {% endif %}
            </article>
            {% if not loop.last %}<hr>{% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 8 — Jokes & Humour
   ============================================================ #}
<div class="page">
    <h2>Jokes &amp; Humour</h2>
    <div class="section-intro">A little laughter is good medicine.</div>

    {% if items_by_section['jokes'] is defined %}
        {% for item in items_by_section['jokes'] %}
            {% if item.get('included') %}
            <div class="joke">
                {% if item.get('inline_title') %}
                    <h3>{{ item.get('inline_title') }}</h3>
                {% endif %}
                <div>{{ item.get('inline_body')|raw }}</div>
            </div>
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 9 — Puzzles
   ============================================================ #}
<div class="page">
    <h2>Puzzles</h2>
    <div class="section-intro">Something to work on with your morning tea.</div>

    {% if items_by_section['puzzles'] is defined %}
        {% for item in items_by_section['puzzles'] %}
            {% if item.get('included') %}
            <article>
                {% if item.get('inline_title') %}
                    <h3>{{ item.get('inline_title') }}</h3>
                {% endif %}
                <div>{{ item.get('inline_body')|raw }}</div>
            </article>
            {% if not loop.last %}<hr>{% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 10 — Clan Horoscopes
   ============================================================ #}
<div class="page">
    <h2>Clan Horoscopes</h2>
    <div class="section-intro">Seasonal guidance drawn from the clans. Take what speaks to you.</div>

    <div class="two-col">
        {% if items_by_section['horoscope'] is defined %}
            {% for item in items_by_section['horoscope'] %}
                {% if item.get('included') %}
                <div class="horoscope-item">
                    {% if item.get('inline_title') %}
                        <h3>{{ item.get('inline_title') }}</h3>
                    {% endif %}
                    <div>{{ item.get('inline_body')|raw }}</div>
                </div>
                {% endif %}
            {% endfor %}
        {% endif %}
    </div>

</div>

{# ============================================================
   PAGE 11 — Elder Spotlight
   ============================================================ #}
<div class="page">
    <h2>Elder Spotlight</h2>
    <div class="section-intro">Honouring the people who carry our community forward.</div>

    {% if items_by_section['elder_spotlight'] is defined %}
        {% for item in items_by_section['elder_spotlight'] %}
            {% if item.get('included') %}
            <article class="prose">
                {% if item.get('inline_title') %}
                    <h3>{{ item.get('inline_title') }}</h3>
                {% endif %}
                <div>{{ item.get('inline_body')|raw }}</div>
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 12 — About & Contact (Back Page)
   ============================================================ #}
<div class="page">
    <h2>About This Newsletter</h2>

    {% if items_by_section['back_page'] is defined %}
        {% for item in items_by_section['back_page'] %}
            {% if item.get('included') %}
                <div class="prose">{{ item.get('inline_body')|raw }}</div>
            {% endif %}
        {% endfor %}
    {% else %}
        <article class="prose">
            <p>This newsletter is generated by Minoo Live, a community platform built by
            Anishinaabe people for Indigenous communities. Content is produced and
            curated at <strong>minoo.live</strong>.</p>
            <p>This newsletter is free.</p>
        </article>
    {% endif %}

</div>

</body>
</html>
