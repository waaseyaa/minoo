{% extends "layouts/newsletter-edition.html.twig" %}
{% block lang %}{{ edition.get('langcode') ?: 'en' }}{% endblock %}
{% block title %}{{ edition.get('headline') }}{% endblock %}
{% block styles %}
        @page {
            size: Letter;
            margin: 0.6in 0.65in 0.8in;
            @bottom-center {
                content: counter(page) "   ·   Powered by minoo.live";
                font-family: Georgia, serif;
                font-size: 8pt;
                color: #888;
            }
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Georgia, "Times New Roman", serif;
            font-size: 14pt;
            line-height: 1.6;
            color: #1a1a1a;
            background: #fff;
            max-width: 8.5in;
            margin: 0 auto;
        }

        /* ---------- Page wrapper ---------- */
        .page {
            page-break-after: always;
            position: relative;
        }
        .page:last-child { page-break-after: auto; }

        /* Page numbers and footer handled by @page @bottom-center */

        /* ---------- Cover / Masthead ---------- */
        .cover {
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            text-align: center;
        }
        .cover .newsletter-title {
            font-size: 40pt;
            font-weight: bold;
            letter-spacing: 1.5pt;
            margin-top: 0.45in;
            padding-bottom: 0.1in;
            border-bottom: 4px solid #1a1a1a;
        }
        .cover .subtitle {
            font-size: 15pt;
            font-style: italic;
            color: #555;
            margin-top: 0.1in;
        }
        .cover .masthead-info {
            font-size: 11.5pt;
            color: #444;
            margin-top: 0.2in;
        }
        .cover .issue-info {
            font-size: 18pt;
            font-weight: bold;
            margin-top: 0.14in;
        }
        .cover .welcome-box {
            margin-top: 0.3in;
            padding: 0.2in 0.25in;
            border: 2px solid #1a1a1a;
            text-align: left;
            font-size: 13pt;
            line-height: 1.5;
        }
        .cover .welcome-box p { margin: 0; }
        .cover .toc {
            margin-top: 0.3in;
            text-align: left;
            padding: 0 0.4in;
        }
        .cover .toc-title {
            font-size: 14pt;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1pt;
            border-bottom: 1px solid #1a1a1a;
            padding-bottom: 0.05in;
            margin-bottom: 0.1in;
        }
        .cover .toc-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13pt;
            line-height: 1.3;
        }
        .cover .toc-table tr {
            border-bottom: 1px dotted #bbb;
        }
        .cover .toc-table tr:last-child {
            border-bottom: none;
        }
        .cover .toc-label {
            padding: 0.06in 0.1in 0.06in 0;
            white-space: nowrap;
        }
        .cover .toc-dots {
            width: 100%;
        }
        .cover .toc-page {
            text-align: right;
            font-weight: bold;
            padding: 0.06in 0;
            color: #333;
            white-space: nowrap;
        }

        /* ---------- Section headers ---------- */
        h2 {
            font-size: 18pt;
            text-transform: uppercase;
            letter-spacing: 1pt;
            border-bottom: 2px solid #1a1a1a;
            padding-bottom: 0.04in; /* was 0.06in */
            margin-bottom: 0.14in; /* was 0.25in */
            margin-top: 0.05in; /* was 0.1in */
        }
        h3 {
            font-size: 15pt;
            margin-top: 0.14in; /* was 0.25in */
            margin-bottom: 0.05in; /* was 0.08in */
        }
        p {
            margin-bottom: 0.08in; /* was 0.15in */
        }

        /* ---------- Section intro ---------- */
        .source-line {
            text-indent: 0;
            font-size: 9.5pt;
            line-height: 1.25;
            color: #666;
            margin-top: 0.04in;
            margin-bottom: 0.06in;
        }
        .news-lead {
            margin-bottom: 0.18in;
        }
        .news-lead h3 {
            font-size: 18pt;
            line-height: 1.2;
            margin-top: 0.04in;
            margin-bottom: 0.08in;
        }
        .news-lead .drop-cap {
            font-size: 14pt;
        }
        .kicker {
            font-size: 9pt;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
            color: #555;
            border-bottom: 1px solid #bbb;
            padding-bottom: 0.03in;
            margin-bottom: 0.06in;
        }
        hr.lead-rule {
            border: 0;
            border-top: 1px solid #999;
            margin: 0.1in 0 0.15in;
        }
        .date-line {
            text-indent: 0;
            font-size: 9.5pt;
            line-height: 1.25;
            color: #666;
            font-style: italic;
            margin-top: 0;
            margin-bottom: 0.06in;
        }
        .section-header {
            display: flex;
            align-items: baseline;
            gap: 0.2in;
            margin-bottom: 0.14in;
            border-bottom: 1px solid #999;
            padding-bottom: 0.06in;
        }
        .section-header h2 {
            border-bottom: none;
            padding-bottom: 0;
            margin: 0;
            flex-shrink: 0;
        }
        .section-header .section-intro {
            border-left: none;
            padding-left: 0;
            margin-bottom: 0;
            font-size: 11pt;
            flex: 1;
        }
        .section-intro {
            color: #333;
            font-size: 13pt;
            line-height: 1.5;
            margin-bottom: 0.14in;
            border-left: 3px solid #999;
            padding-left: 0.15in;
        }

        /* ---------- Article blocks ---------- */
        article {
            margin-bottom: 0.16in; /* was 0.3in */
        }

        /* ---------- Prose indent ---------- */
        .prose p {
            text-indent: 0.2in;
        }
        .prose p:first-of-type {
            text-indent: 0;
        }

        /* ---------- Boxed sections ---------- */
        .boxed {
            border: 2px solid #1a1a1a;
            padding: 0.15in; /* was 0.2in */
            margin-bottom: 0.14in; /* was 0.25in */
        }
        .boxed h3 {
            margin-top: 0;
        }

        /* ---------- Two-column layout ---------- */
        .two-col {
            column-count: 2;
            column-gap: 0.35in;
            column-rule: 1px solid #ccc;
        }

        /* ---------- Horoscope items ---------- */
        .horoscope-item {
            margin-bottom: 0.14in;
            break-inside: avoid;
        }
        .horoscope-item h3 {
            font-size: 12pt;
            margin-top: 0;
            margin-bottom: 0.05in;
            padding-bottom: 0.03in;
            border-bottom: 1px solid #1a1a1a;
            text-transform: uppercase;
            letter-spacing: 0.5pt;
        }
        .horoscope-item p {
            font-size: 11pt;
            text-indent: 0;
            line-height: 1.45;
        }

        /* ---------- Puzzle tail (two-col under word search) ---------- */
        .puzzle-tail {
            column-count: 2;
            column-gap: 0.35in;
            column-rule: 1px solid #ccc;
            margin-top: 0.18in;
        }
        .puzzle-card {
            break-inside: avoid;
            margin-bottom: 0.14in;
        }
        .puzzle-card h3 {
            font-size: 12pt;
            text-transform: uppercase;
            letter-spacing: 0.5pt;
            border-bottom: 1px solid #1a1a1a;
            padding-bottom: 0.03in;
            margin: 0 0 0.05in;
        }
        .puzzle-card p { text-indent: 0; font-size: 11pt; }

        /* ---------- Puzzle grid ---------- */
        .word-search-grid {
            font-family: "Courier New", "Courier", monospace;
            border-collapse: collapse;
            margin: 0.1in auto; /* was 0.15in */
            border: 2px solid #1a1a1a;
        }
        .word-search-grid td {
            width: 0.34in;
            height: 0.34in;
            text-align: center;
            vertical-align: middle;
            font-size: 12pt;
            font-weight: bold;
            text-transform: uppercase;
            border: 1px solid #888;
            padding: 0;
        }
        .word-list {
            column-count: 3;
            column-gap: 0.3in;
            font-size: 12pt;
            margin: 0.1in 0.2in 0; /* was 0.15in top */
            padding: 0;
            list-style: none;
        }
        .word-list li {
            break-inside: avoid;
            margin-bottom: 0.03in;
        }

        /* ---------- Quote block ---------- */
        blockquote {
            border-left: 4px solid #1a1a1a;
            padding-left: 0.2in;
            margin: 0.12in 0; /* was 0.2in */
            font-style: italic;
            font-size: 15pt;
            line-height: 1.5;
        }
        blockquote cite {
            display: block;
            font-style: normal;
            font-size: 12pt;
            margin-top: 0.1in;
            color: #555;
        }

        /* ---------- Source line ---------- */
        .source-line {
            text-indent: 0;
            font-size: 10pt;
            color: #666;
            margin-top: 0.05in;
        }

        /* ---------- Event detail lines ---------- */
        .event-detail {
            text-indent: 0;
            margin-bottom: 0.06in;
        }

        /* ---------- Events list (single column; wraps floated calendar) ---------- */
        .events-grid {
            /* Text flows in one column around the floated mini-calendar */
        }
        .events-grid article {
            break-inside: avoid;
            margin-bottom: 0.08in;
            padding-bottom: 0.05in;
            border-bottom: 1px dotted #bbb;
        }
        .events-grid article:last-child {
            border-bottom: none;
        }
        .events-grid h3 {
            font-size: 14pt;
            line-height: 1.25;
            margin-top: 0;
            margin-bottom: 0.06in;
        }
        .events-grid p {
            font-size: 12pt;
            line-height: 1.5;
            margin-bottom: 0.04in;
        }
        .events-grid .event-detail {
            font-size: 12pt;
            line-height: 1.35;
            margin-bottom: 0.03in;
        }
        .events-grid .event-detail strong {
            display: inline-block;
            min-width: 0.55in;
        }
        /* Clear the calendar float so the dotted rule sits below it cleanly */
        .events-grid::after {
            content: "";
            display: block;
            clear: both;
        }

        /* ---------- Mini calendar (elder-readable sizing) ---------- */
        .mini-cal {
            float: right;
            margin: 0 0 0.15in 0.22in;
            border: 2px solid #1a1a1a;
            border-collapse: collapse;
            font-size: 12pt;
            line-height: 1.35;
        }
        .mini-cal caption {
            font-weight: bold;
            font-size: 13pt;
            padding: 0.07in 0;
            border-bottom: 2px solid #1a1a1a;
            letter-spacing: 0.5pt;
            text-transform: uppercase;
        }
        .mini-cal th {
            font-size: 10pt;
            font-weight: bold;
            color: #333;
            padding: 0.05in 0.09in;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.5pt;
            background: #f0f0f0;
            border-bottom: 1px solid #888;
        }
        .mini-cal td {
            text-align: center;
            padding: 0.06in 0.09in;
            font-size: 12pt;
            border: 1px solid #ccc;
            min-width: 0.32in;
            height: 0.32in;
        }
        .mini-cal td.has-event {
            font-weight: bold;
            background: #e8e8e8;
            border-color: #1a1a1a;
        }

        /* ---------- Drop cap ---------- */
        .drop-cap::first-letter {
            float: left;
            font-size: 3.2em;
            line-height: 0.8;
            padding-right: 0.06in;
            padding-top: 0.04in;
            font-weight: bold;
        }

        /* ---------- Signature block ---------- */
        .signature {
            margin-top: 0.22in; /* was 0.4in */
            font-style: italic;
            text-indent: 0;
        }

        /* ---------- Attribution ---------- */
        .attribution {
            text-indent: 0;
            margin-top: 0.08in; /* was 0.15in */
            font-style: italic;
        }

        /* ---------- Featured word box ---------- */
        .featured-word {
            border: 2px solid #1a1a1a;
            text-align: center;
            padding: 0.22in 0.3in; /* was 0.35in 0.4in */
            margin-bottom: 0.15in; /* was 0.25in */
        }
        .featured-word .word {
            font-size: 28pt;
            font-weight: bold;
            margin-bottom: 0.05in; /* was 0.08in */
            text-indent: 0;
        }
        .featured-word .pronunciation {
            font-size: 15pt;
            font-style: italic;
            color: #555;
            margin-bottom: 0.08in; /* was 0.15in */
            text-indent: 0;
        }
        .featured-word .meaning {
            font-size: 16pt;
            text-indent: 0;
        }
        .featured-word .example {
            font-size: 13pt;
            color: #444;
            margin-top: 0.07in; /* was 0.12in */
            text-indent: 0;
        }
        .featured-word-svg {
            margin-bottom: 0.07in; /* was 0.12in */
        }
        .featured-word-svg svg {
            display: block;
            margin: 0 auto;
            max-height: 0.6in;
        }

        /* ---------- Teachings ---------- */
        .teaching-banner {
            margin: 0.05in 0 0.1in;
            text-align: center;
        }
        .teaching-banner svg {
            display: block;
            margin: 0 auto;
            max-height: 0.7in;
            width: auto;
        }
        .teaching-block {
            margin-bottom: 0.12in;
            padding-bottom: 0.08in;
            border-bottom: 1px solid #e0e0e0;
        }
        .teaching-block:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        .teaching-heading {
            display: flex;
            align-items: center;
            gap: 0.15in;
            margin: 0 0 0.08in;
        }
        .teaching-icon {
            flex: 0 0 0.7in;
        }
        .teaching-icon svg {
            display: block;
            width: 0.7in;
            height: 0.7in;
        }
        .teaching-heading h3 {
            margin: 0;
            flex: 1;
        }
        .teaching-block .teaching-body {
            text-indent: 0;
        }
        .teaching-block .teaching-body p {
            text-indent: 0.2in;
            margin: 0 0 0.06in;
        }
        .teaching-block .teaching-body p:first-child {
            text-indent: 0;
        }
        .teaching-block.has-drop-cap .teaching-body p:first-child::first-letter {
            float: left;
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 36pt;
            line-height: 0.85;
            padding: 0.04in 0.06in 0 0;
            font-weight: bold;
        }

        /* ---------- Vocabulary list ---------- */
        .vocab-list {
            text-indent: 0;
            margin-top: 0.08in; /* was 0.15in */
        }
        .vocab-item {
            margin-bottom: 0.07in; /* was 0.12in */
            text-indent: 0;
        }

        /* ---------- Visual vocab grid ---------- */
        .vocab-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.12in; /* was 0.2in */
            margin-top: 0.12in; /* was 0.2in */
        }
        .vocab-card {
            border: 1.5px solid #1a1a1a;
            padding: 0.09in 0.12in; /* was 0.12in 0.15in */
            text-align: center;
            break-inside: avoid;
        }
        .vocab-card svg {
            display: block;
            margin: 0 auto 0.06in;
            max-height: 0.45in;
        }
        .vocab-card .vocab-word {
            font-size: 14pt;
            font-weight: bold;
            margin-bottom: 0.02in;
        }
        .vocab-card .vocab-pron {
            font-size: 9pt;
            font-style: italic;
            color: #666;
            margin-bottom: 0.04in;
        }
        .vocab-card .vocab-meaning {
            font-size: 11pt;
        }

        /* ---------- Joke styling ---------- */
        .jokes-grid {
            column-count: 2;
            column-gap: 0.35in;
            column-rule: 1px solid #ccc;
            margin-top: 0.08in;
        }
        .joke {
            break-inside: avoid;
            margin-bottom: 0.14in;
            padding-bottom: 0.08in;
            border-bottom: 1px dotted #ccc;
        }
        .joke:last-child {
            border-bottom: none;
        }
        .joke p {
            text-indent: 0;
            margin-bottom: 0.05in;
        }
        .joke h3 {
            font-size: 11pt;
            text-transform: uppercase;
            letter-spacing: 1pt;
            color: #444;
            margin: 0 0 0.05in;
            border-bottom: 1px solid #bbb;
            padding-bottom: 0.02in;
        }

        /* ---------- Puzzle styling ---------- */
        .puzzle-text {
            text-indent: 0;
        }

        /* ---------- No-indent utility ---------- */
        .no-indent { text-indent: 0; }

        /* ---------- Photo caption ---------- */
        .photo-wrap {
            text-align: center;
            margin-bottom: 0.14in;
        }
        .photo-wrap img {
            width: 3.5in;
            border: 3px solid #1a1a1a;
        }
        .photo-caption {
            font-size: 10pt;
            color: #555;
            font-style: italic;
            margin-top: 0.05in;
            text-indent: 0;
        }
        /* Floated spotlight photo — wraps prose */
        .photo-wrap.float-left {
            float: left;
            width: 2.6in;
            margin: 0.04in 0.22in 0.08in 0;
        }
        .photo-wrap.float-left img {
            width: 2.6in;
        }

        /* ---------- Pull quote ---------- */
        .pull-quote {
            float: right;
            width: 2.2in;
            margin: 0.1in 0 0.15in 0.25in;
            padding: 0.12in 0 0.1in;
            border-top: 2px solid #1a1a1a;
            border-bottom: 2px solid #1a1a1a;
            font-family: Georgia, "Times New Roman", serif;
            font-size: 15pt;
            font-style: italic;
            line-height: 1.3;
            text-indent: 0;
            color: #1a1a1a;
        }
        .pull-quote::before { content: "\201C"; }
        .pull-quote::after  { content: "\201D"; }

        /* Spotlight CTA line at foot of elder feature */
        .spotlight-cta {
            text-indent: 0;
            font-style: italic;
            color: #444;
            border-top: 1px solid #999;
            padding-top: 0.1in;
            margin-top: 0.2in;
            font-size: 11pt;
        }

        /* ---------- Back page ---------- */
        .back-page-box {
            border: 2px solid #1a1a1a;
            padding: 0.18in; /* was 0.25in */
            margin-top: 0.18in; /* was 0.3in */
        }
        .back-page-box h3 {
            text-align: center;
            margin-top: 0;
            margin-bottom: 0.08in; /* was 0.15in */
        }
        .contact-line {
            font-size: 12pt;
            margin-bottom: 0.05in; /* was 0.1in */
            text-indent: 0;
        }

        /* ---------- Partners block ---------- */
        .partners {
            text-align: center;
            margin-top: 0.14in; /* was 0.25in */
        }
        .partners-label {
            font-size: 9pt;
            color: #888;
            text-indent: 0;
            letter-spacing: 1pt;
            text-transform: uppercase;
            margin-bottom: 0.08in; /* was 0.15in */
        }
        .partners-logos {
            display: flex;
            justify-content: center;
            align-items: flex-end;
            gap: 0.6in;
            flex-wrap: wrap;
        }
        .partner-logo {
            text-align: center;
        }
        .partner-logo svg {
            display: block;
            margin: 0 auto 0.05in;
            max-height: 0.6in;
        }
        .partner-name {
            font-size: 10pt;
            color: #333;
        }

        /* ---------- Colophon ---------- */
        .colophon {
            text-align: center;
            margin-top: 0.08in; /* was 0.15in */
        }
        .colophon p {
            font-size: 11pt;
            color: #555;
            text-indent: 0;
        }

        /* ---------- Elder Spotlight closing callout ---------- */
        .spotlight-callout {
            clear: both;
            position: relative;
            margin: 0.6in 0 0;
            padding: 0.3in 0.35in;
            background: #fbf8ef;
            border-top: 3px solid #6a4a1a;
            border-bottom: 3px solid #6a4a1a;
            break-inside: avoid;
            page-break-inside: avoid;
        }
        .spotlight-callout::before {
            content: "✦   ✦   ✦";
            position: absolute;
            top: -0.45in;
            left: 50%;
            transform: translateX(-50%);
            font-size: 11pt;
            color: #b68c3c;
            letter-spacing: 0.4in;
        }
        .spotlight-callout h3 {
            font-family: Georgia, serif;
            font-size: 13pt;
            letter-spacing: 1.2pt;
            text-transform: uppercase;
            color: #6a4a1a;
            margin: 0 0 0.1in;
            border: none;
            padding: 0;
        }
        .spotlight-callout p {
            font-size: 11pt;
            line-height: 1.45;
            margin: 0 0 0.1in;
            text-indent: 0;
        }
        .spotlight-callout p:last-child { margin-bottom: 0; }
        .spotlight-callout .callout-quote {
            font-style: italic;
            font-size: 12pt;
            color: #3a352b;
            margin: 0.14in 0;
            padding-left: 0.22in;
            border-left: 3px solid #b68c3c;
        }
        .spotlight-callout .callout-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.35in;
            margin-top: 0.22in;
            padding-top: 0.18in;
            border-top: 1px dotted #d8d3c4;
        }
        .spotlight-callout .callout-grid > div strong {
            display: block;
            font-family: Georgia, serif;
            font-size: 9pt;
            letter-spacing: 1.4pt;
            text-transform: uppercase;
            color: #8a6b3a;
            margin-bottom: 0.1in;
        }
        .spotlight-callout .callout-grid ul {
            margin: 0 0 0 0.18in;
            padding: 0;
            font-size: 11pt;
            line-height: 1.45;
        }
        .spotlight-callout .callout-grid li { margin-bottom: 0.06in; }
        .spotlight-callout .callout-grid p {
            margin: 0 0 0.08in;
            font-size: 10.5pt;
            line-height: 1.4;
        }

        /* ---------- TOC page (dedicated p3) ---------- */
        .toc-page h2 { margin-bottom: 0.04in; }
        .toc-page { line-height: 1.3; }
        .toc-layout {
            margin-top: 0.1in;
        }
        .toc-rail {
            margin-top: 0.25in;
            padding-top: 0.15in;
            border-top: 1px solid #e7e1cf;
            display: grid;
            grid-template-columns: 1.3fr 1fr;
            gap: 0.3in;
        }
        .toc-page .toc-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }
        .toc-page .toc-table tr { break-inside: avoid; }
        .toc-page .toc-table td {
            vertical-align: baseline;
            padding: 0.05in 0;
            border-bottom: 1px dotted #d8d3c4;
        }
        .toc-page .toc-label { width: auto; }
        .toc-page .toc-dots { width: 1.2in; }
        .toc-page .toc-page-num { width: 0.5in; }
        .toc-page .toc-kicker {
            display: block;
            font-family: Georgia, serif;
            font-size: 8pt;
            letter-spacing: 1.2pt;
            text-transform: uppercase;
            color: #8a6b3a;
            margin-bottom: 0;
        }
        .toc-page .toc-title-line { font-size: 11pt; line-height: 1.25; }
        .toc-page .toc-dots {
            border-bottom: 2px dotted #c8bfa8;
            position: relative;
            top: -0.04in;
        }
        .toc-page .toc-page-num {
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            text-align: right;
            font-size: 12pt;
            padding-left: 0.1in !important;
        }
        .toc-pullquote {
            font-family: Georgia, serif;
            font-style: italic;
            font-size: 12pt;
            line-height: 1.45;
            color: #3a352b;
            margin-bottom: 0.22in;
        }
        .toc-pullquote .pullquote-mark {
            font-size: 32pt;
            line-height: 0.2;
            color: #b68c3c;
            display: block;
            margin-bottom: 0.08in;
        }
        .toc-pullquote .pullquote-attrib {
            font-style: normal;
            font-size: 9pt;
            color: #6a6458;
            margin-top: 0.08in;
        }
        .next-issue-teaser { font-size: 10.5pt; }
        .next-issue-kicker {
            font-family: Georgia, serif;
            font-size: 8.5pt;
            letter-spacing: 1.6pt;
            text-transform: uppercase;
            color: #6a4a1a;
            border-top: 2px solid #6a4a1a;
            padding-top: 0.06in;
            margin-bottom: 0.08in;
        }
        .next-issue-teaser ul { margin: 0 0 0.14in 0.2in; padding: 0; }
        .next-issue-teaser li { margin-bottom: 0.03in; }
        .next-issue-cta {
            font-size: 10pt;
            line-height: 1.35;
            color: #3a352b;
        }

        /* ---------- Back cover (p16) ---------- */
        .back-cover {
            display: flex;
            flex-direction: column;
            gap: 0.12in;
        }
        .back-cover-teaser {
            border-top: 4px solid #6a4a1a;
            border-bottom: 1px solid #d8d3c4;
            padding: 0.1in 0 0.14in;
        }
        .teaser-kicker {
            font-size: 9pt;
            letter-spacing: 1.6pt;
            text-transform: uppercase;
            color: #6a4a1a;
        }
        .teaser-head {
            font-family: Georgia, serif;
            font-size: 15pt;
            line-height: 1.2;
            margin: 0.05in 0;
            color: #2a2620;
        }
        .teaser-sub { font-style: italic; color: #4a4437; margin: 0; font-size: 11pt; }
        .back-cover-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 0.3in;
        }
        .colophon-block h4 {
            font-size: 10pt;
            letter-spacing: 1.6pt;
            text-transform: uppercase;
            color: #6a4a1a;
            margin: 0 0 0.08in;
        }
        .colophon-block p {
            font-size: 9.5pt;
            line-height: 1.4;
            margin: 0 0 0.06in;
            text-indent: 0;
        }
        .colophon-meta {
            display: grid;
            grid-template-columns: max-content 1fr;
            gap: 0.04in 0.18in;
            margin-top: 0.14in;
            font-size: 9.5pt;
        }
        .colophon-meta dt { color: #8a6b3a; font-weight: 600; }
        .colophon-meta dd { margin: 0; color: #2a2620; }
        .mailing-panel {
            border: 1px dashed #b8b09a; /* proof only; set transparent for press */
            padding: 0.08in;
            display: flex;
            flex-direction: column;
            gap: 0.08in;
            background: #fbf8ef;
        }
        .indicia { display: flex; justify-content: space-between; gap: 0.15in; }
        .indicia-box {
            border: 1.5px solid #2a2620;
            padding: 0.06in 0.08in;
            font-size: 8pt;
            line-height: 1.25;
            text-align: center;
            min-width: 1.6in;
            font-family: Georgia, serif;
            text-transform: uppercase;
            letter-spacing: 0.6pt;
        }
        .indicia-number { font-weight: 700; letter-spacing: 1pt; }
        .return-address {
            font-size: 8.5pt;
            line-height: 1.3;
            color: #3a352b;
        }
        .address-window { min-height: 0.7in; }
        .back-cover-partners { margin-top: 0.08in; }
        .back-cover-footer {
            border-top: 1px solid #d8d3c4;
            padding-top: 0.09in;
            display: flex;
            justify-content: space-between;
            align-items: baseline;
        }
        .wordmark {
            font-family: Georgia, serif;
            font-size: 16pt;
            font-weight: 700;
            color: #2a2620;
            letter-spacing: 0.3pt;
        }
        .footer-tag { font-size: 10pt; color: #6a6458; }

        .closing {
            text-align: center;
            margin-top: 0.15in; /* was 0.3in */
            font-size: 11pt;
            color: #888;
        }

        /* ---------- Divider ---------- */
        hr {
            border: none;
            border-top: 1px solid #ccc;
            margin: 0.14in 0; /* was 0.25in */
        }

        /* ---------- Keep together ---------- */
        .keep-together { break-inside: avoid; page-break-inside: avoid; }

        /* ---------- Reader Mail ---------- */
        .reader-mail p {
            text-indent: 0;
            margin-bottom: 0.1in;
        }
        .reader-mail p strong:first-child {
            display: inline-block;
            min-width: 0.1in;
        }
        .next-issue-close {
            text-align: center;
            border-top: 1px solid #999;
            padding-top: 0.14in;
            margin-top: 0.22in;
            font-size: 12pt;
            color: #444;
        }

        /* ---------- Memoir block (Community Voices remembrance pieces) ---------- */
        .memoir {
            border-left: 4px solid #1a1a1a;
            padding: 0.05in 0 0.05in 0.25in;
            margin-top: 0.18in;
        }
        .memoir h3 {
            font-family: Georgia, "Times New Roman", serif;
            font-style: italic;
            font-weight: normal;
            font-size: 17pt;
            margin: 0 0 0.08in;
        }
        .memoir p { text-indent: 0; }
        .memoir p + p { text-indent: 0.2in; }

        /* ---------- Our Territory (page 8) ---------- */
        .territory-epigraph {
            font-family: Georgia, "Times New Roman", serif;
            font-style: italic;
            font-size: 14pt;
            line-height: 1.45;
            text-align: center;
            margin: 0.15in 0.4in 0.22in;
            color: #1a1a1a;
        }
        .territory-intro {
            font-size: 12pt;
            line-height: 1.55;
            margin: 0 0 0.2in;
        }
        .territory-list {
            list-style: none;
            padding: 0;
            margin: 0 0 0.2in;
            column-count: 2;
            column-gap: 0.35in;
            column-rule: 0.5pt solid #bbb;
        }
        .territory-list li {
            font-size: 12pt;
            line-height: 1.5;
            margin: 0 0 0.11in;
            padding: 0;
            break-inside: avoid;
        }
        .territory-list .t-name {
            font-weight: bold;
        }
        .territory-list .t-meaning {
            font-style: italic;
        }
        .territory-list .t-note {
            display: block;
            font-size: 10.5pt;
            color: #555;
            margin-left: 0.05in;
        }
        .territory-closing {
            font-family: Georgia, "Times New Roman", serif;
            font-style: italic;
            font-size: 12pt;
            line-height: 1.5;
            text-align: center;
            margin: 0.18in 0.3in 0;
            color: #1a1a1a;
        }

        /* ---------- Print resets ---------- */
        @media print {
            body { background: #fff; }
            a { color: #000; text-decoration: none; }
        }

        {% if review_mode|default(false) %}
        /* --- Review draft watermark --- */
        body::before {
            content: "REVIEW DRAFT — NOT FOR PRINT";
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-35deg);
            font-size: 48pt;
            font-family: Arial, sans-serif;
            font-weight: bold;
            color: rgba(0, 0, 0, 0.06);
            white-space: nowrap;
            z-index: 9999;
            pointer-events: none;
        }

        /* --- Collaborator annotation box --- */
        .collaborator-note {
            border: 2px dashed #000;
            padding: 0.2in;
            margin-top: 0.2in;
            break-inside: avoid;
            page-break-inside: avoid;
        }
        .collaborator-note h4 {
            font-size: 13pt;
            font-weight: bold;
            margin-bottom: 0.08in;
            border-bottom: 1px solid #000;
            padding-bottom: 0.05in;
        }
        .collaborator-note p {
            font-size: 11pt;
            line-height: 1.4;
            margin-bottom: 0.06in;
        }
        .collaborator-note ul {
            font-size: 11pt;
            line-height: 1.4;
            margin-left: 0.25in;
            margin-bottom: 0.06in;
        }
        {% endif %}
{% endblock %}
{% block body %}

{# ============================================================
   PAGE 1 — Cover
   ============================================================ #}
<div class="page cover">
    <div class="newsletter-title">Minoo Newsletter</div>
    <div class="subtitle">For Communities</div>
    <div class="issue-info">
        Vol. {{ edition.get('volume') }} &middot; Issue {{ edition.get('issue_number') }}
        &middot; {{ edition.get('publish_date') }}
    </div>
    <div class="masthead-info">
        Serving the communities of the North Shore, Robinson Huron Treaty territory
    </div>

    {% if items_by_section['cover'] is defined %}
        {% for item in items_by_section['cover'] %}
            {% if item.get('included') and item.get('kind') != 'toc' %}
                <div class="welcome-box">{{ item.get('inline_body')|raw }}</div>
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 2 — Keeper's Note (Editor's Note)
   ============================================================ #}
<div class="page">
    <h2>Keeper&rsquo;s Note</h2>
    {% if items_by_section['editors_note'] is defined %}
        {% for item in items_by_section['editors_note'] %}
            {% if item.get('included') %}
                {% set k = item.get('kind') %}
                {% if k == 'drop_cap' %}
                    <div class="prose drop-cap">{{ item.get('inline_body')|raw }}</div>
                {% else %}
                    <div class="prose">{{ item.get('inline_body')|raw }}</div>
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}
</div>

{# ============================================================
   PAGE 3 — In This Issue (Table of Contents)
   ============================================================ #}
<div class="page toc-page">
    <h2>In This Issue</h2>
    <div class="section-intro"><em>Biindigen</em> &mdash; come inside.</div>

    <div class="toc-layout">
        <div class="toc-main">
        {% set toc_items = items_by_section['toc']|default([]) %}
            {% set rendered_toc = false %}
            {% for item in toc_items %}
                {% if item.get('included') and item.get('kind') == 'toc' %}
                    {% set toc = item.get('structured') %}
                    {% if toc and toc.entries %}
                        {% set rendered_toc = true %}
                        <table class="toc-table">
                            {% for entry in toc.entries %}
                            <tr>
                                <td class="toc-label">
                                    {% if entry.kicker %}<span class="toc-kicker">{{ entry.kicker }}</span>{% endif %}
                                    <span class="toc-title-line">{{ entry.label }}</span>
                                </td>
                                <td class="toc-dots" aria-hidden="true"></td>
                                <td class="toc-page-num">{{ entry.page }}</td>
                            </tr>
                            {% endfor %}
                        </table>
                    {% endif %}
                {% endif %}
            {% endfor %}

            {% if not rendered_toc %}
                {# Fallback for Issue 1-1 — curated highlights, not a full index #}
                <table class="toc-table">
                    <tr><td class="toc-label"><span class="toc-kicker">News</span><span class="toc-title-line">Treaty Chiefs say no to herbicide spraying</span></td><td class="toc-dots"></td><td class="toc-page-num">4</td></tr>
                    <tr><td class="toc-label"><span class="toc-kicker">Calendar</span><span class="toc-title-line">May events across the North Shore</span></td><td class="toc-dots"></td><td class="toc-page-num">6</td></tr>
                    <tr><td class="toc-label"><span class="toc-kicker">Teachings</span><span class="toc-title-line">Ziigwan: the time of new growth</span></td><td class="toc-dots"></td><td class="toc-page-num">7</td></tr>
                    <tr><td class="toc-label"><span class="toc-kicker">Language</span><span class="toc-title-line">A word to carry: <em>Ziigwan</em></span></td><td class="toc-dots"></td><td class="toc-page-num">8</td></tr>
                    <tr><td class="toc-label"><span class="toc-kicker">Our Territory</span><span class="toc-title-line">The twenty-one First Nations of Robinson Huron</span></td><td class="toc-dots"></td><td class="toc-page-num">9</td></tr>
                    <tr><td class="toc-label"><span class="toc-kicker">Puzzles &amp; Humour</span><span class="toc-title-line">Word search, jokes, horoscopes</span></td><td class="toc-dots"></td><td class="toc-page-num">10</td></tr>
                    <tr><td class="toc-label"><span class="toc-kicker">Elder Spotlight</span><span class="toc-title-line">Grace Manitowabi on Minigoziwin</span></td><td class="toc-dots"></td><td class="toc-page-num">13</td></tr>
                    <tr><td class="toc-label"><span class="toc-kicker">Reader Mail</span><span class="toc-title-line">What we hope you send for Issue 2</span></td><td class="toc-dots"></td><td class="toc-page-num">15</td></tr>
                </table>
            {% endif %}
        </div>

        <div class="toc-rail">
            <div class="toc-pullquote">
                <span class="pullquote-mark">&ldquo;</span>
                <p>I built this newsletter because I wanted Anishinaabe news to arrive
                at the kitchen table, not the algorithm.</p>
                <div class="pullquote-attrib">&mdash; Russell, p.&thinsp;2</div>
            </div>

            <div class="next-issue-teaser">
                <div class="next-issue-kicker">In the next issue</div>
                <ul>
                    <li>Niibin (summer) teachings</li>
                    <li>Powwow trail &mdash; 2026 schedule</li>
                    <li>Riddle of the Month winner</li>
                </ul>
                <div class="next-issue-cta">
                    Send stories, events, and photos to
                    <strong>hello@minoo.live</strong>.
                </div>
            </div>
        </div>
    </div>
</div>

{# ============================================================
   PAGE 4 — Community News
   ============================================================ #}
<div class="page">
    <h2>Community News</h2>
    <div class="section-intro">What is happening around the community this month.</div>

    {% if items_by_section['news'] is defined %}
        {# Lead story — full-width above the two-column grid #}
        {% for item in items_by_section['news'] %}
            {% if item.get('kind') == 'news_lead' and item.get('included') %}
            <article class="news-lead">
                {% if item.get('kicker') %}
                    <div class="kicker">{{ item.get('kicker') }}</div>
                {% endif %}
                <h3>{{ item.get('inline_title') }}</h3>
                {% if item.get('date_line') %}
                    <p class="date-line">{{ item.get('date_line') }}</p>
                {% endif %}
                <div class="drop-cap">{{ item.get('inline_body')|raw }}</div>
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 3b — News Briefs (secondary stories)
   ============================================================ #}
<div class="page">
    <h2>News Briefs</h2>
    <div class="section-intro">More from around our communities.</div>

    {% if items_by_section['news'] is defined %}
        <div class="two-col">
        {% for item in items_by_section['news'] %}
            {% if item.get('kind') != 'news_lead' %}
            {% if item.get('included') %}
            <article class="prose">
                {% if item.get('source_type') and source_entities[item.id()] is defined %}
                    {% set src = source_entities[item.id()] %}
                    <h3>{{ src.label() ?: src.get('title') }}</h3>
                    {% if item.get('editor_blurb') %}
                        <p>{{ item.get('editor_blurb') }}</p>
                    {% else %}
                        <p>{{ src.get('body')|default(src.get('description'))|striptags|slice(0, 400) }}</p>
                    {% endif %}
                    {% if src.get('source_attribution') %}
                        <p class="source-line"><em>{{ src.get('source_attribution') }}</em></p>
                    {% endif %}
                {% else %}
                    <h3>{{ item.get('inline_title') }}</h3>
                    {% if item.get('date_line') %}
                        <p class="date-line">{{ item.get('date_line') }}</p>
                    {% endif %}
                    <div>{{ item.get('inline_body')|raw }}</div>
                {% endif %}
            </article>
            {% endif %}
            {% endif %}
        {% endfor %}
    </div>
    {% endif %}

</div>

{# ============================================================
   PAGE 4 — Events Calendar
   ============================================================ #}
<div class="page">
    <h2>Events Calendar</h2>
    <div class="section-intro">May brings the first spring markets, the opening of fishing season, and a full slate of adult ed evenings. Here is what is happening across the North Shore.</div>

    {# Render calendar item(s) first, outside the events-grid so it floats right #}
    {% if items_by_section['events'] is defined %}
        {% for item in items_by_section['events'] %}
            {% if item.get('included') and item.get('kind') == 'calendar' %}
                {% set cal = item.get('structured') %}
                {% if cal %}
                <table class="mini-cal">
                    <caption>{{ cal.month }}</caption>
                    <tr>
                        {% for wd in cal.weekdays %}<th>{{ wd }}</th>{% endfor %}
                    </tr>
                    {% for week in cal.weeks %}
                    <tr>
                        {% for cell in week %}
                            {% if cell is null %}
                                <td></td>
                            {% elseif cell.event %}
                                <td class="has-event">{{ cell.day }}</td>
                            {% else %}
                                <td>{{ cell.day }}</td>
                            {% endif %}
                        {% endfor %}
                    </tr>
                    {% endfor %}
                </table>
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}

    <div class="events-grid">
    {% if items_by_section['events'] is defined %}
        {% for item in items_by_section['events'] %}
            {% if item.get('included') and item.get('kind') != 'calendar' %}
            <article>
                {% if item.get('source_type') and source_entities[item.id()] is defined %}
                    {% set src = source_entities[item.id()] %}
                    <h3>{{ src.label() ?: src.get('title') }}</h3>
                    {% if src.get('event_date') %}
                        <p class="event-detail"><strong>When:</strong> {{ src.get('event_date') }}</p>
                    {% endif %}
                    {% if src.get('location') %}
                        <p class="event-detail"><strong>Where:</strong> {{ src.get('location') }}</p>
                    {% endif %}
                    {% if item.get('editor_blurb') %}
                        <p>{{ item.get('editor_blurb') }}</p>
                    {% elseif src.get('description') %}
                        <p>{{ src.get('description')|striptags|slice(0, 200) }}</p>
                    {% endif %}
                {% else %}
                    <h3>{{ item.get('inline_title') }}</h3>
                    <div>{{ item.get('inline_body')|raw }}</div>
                {% endif %}
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}
    </div>

</div>

{# ============================================================
   PAGE 5 — Teachings
   ============================================================ #}
<div class="page">
    <h2>Teachings</h2>
    <div class="section-intro">Seasonal knowledge passed down through generations.</div>

    {# Page-top banner from first teaching_block with banner_svg #}
    {% if items_by_section['teachings'] is defined %}
        {% for item in items_by_section['teachings'] %}
            {% if item.get('included') and item.get('kind') == 'teaching_block' %}
                {% set tbStruct = item.get('structured') %}
                {% if tbStruct and tbStruct.banner_svg %}
                    <div class="teaching-banner">{{ tbStruct.banner_svg|raw }}</div>
                {% endif %}
            {% endif %}
        {% endfor %}

        {% for item in items_by_section['teachings'] %}
            {% if item.get('included') %}
                {% if item.get('kind') == 'teaching_block' %}
                    {% set tbStruct = item.get('structured') %}
                    <article class="teaching-block{% if tbStruct and tbStruct.drop_cap %} has-drop-cap{% endif %}">
                        <div class="teaching-heading">
                            {% if tbStruct and tbStruct.icon_svg %}
                                <div class="teaching-icon">{{ tbStruct.icon_svg|raw }}</div>
                            {% endif %}
                            <h3>{{ item.get('inline_title') }}</h3>
                        </div>
                        <div class="teaching-body">{{ item.get('inline_body')|raw }}</div>
                    </article>
                {% else %}
                    <article class="prose">
                        {% if item.get('source_type') and source_entities[item.id()] is defined %}
                            {% set src = source_entities[item.id()] %}
                            <h3>{{ src.label() ?: src.get('title') }}</h3>
                            {% if src.get('source') or src.get('knowledge_keeper') %}
                                <div class="attribution">
                                    {{ src.get('knowledge_keeper') ?: src.get('source') }}
                                </div>
                            {% endif %}
                            {% if item.get('editor_blurb') %}
                                <p>{{ item.get('editor_blurb') }}</p>
                            {% else %}
                                <p>{{ src.get('body')|default(src.get('description'))|striptags|slice(0, 500) }}</p>
                            {% endif %}
                        {% else %}
                            <h3>{{ item.get('inline_title') }}</h3>
                            <div>{{ item.get('inline_body')|raw }}</div>
                        {% endif %}
                    </article>
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 6 — Language Corner
   ============================================================ #}
<div class="page">
    <h2>Language Corner</h2>
    <div class="section-intro">A word to carry with you this month.</div>

    {# Featured word from dictionary entity #}
    {% if items_by_section['language'] is defined %}
        {% for item in items_by_section['language'] %}
            {% if item.get('included') %}
                {% set fwStruct = item.get('structured') %}
                {% if item.get('source_type') and source_entities[item.id()] is defined %}
                    {% set src = source_entities[item.id()] %}
                    <div class="featured-word">
                        {% if fwStruct and fwStruct.svg %}<div class="featured-word-svg">{{ fwStruct.svg|raw }}</div>{% endif %}
                        <p class="word">{{ src.label() ?: src.get('word') }}</p>
                        {% if src.get('pronunciation') %}
                            <p class="pronunciation">{{ src.get('pronunciation') }}</p>
                        {% endif %}
                        <p class="meaning"><strong>{{ src.get('definition') }}</strong></p>
                        {% if src.get('example_sentence') %}
                            <p class="example">&ldquo;{{ src.get('example_sentence') }}&rdquo;</p>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="featured-word">
                        {% if fwStruct and fwStruct.svg %}<div class="featured-word-svg">{{ fwStruct.svg|raw }}</div>{% endif %}
                        <p class="word">{{ item.get('inline_title') }}</p>
                        <div>{{ item.get('inline_body')|raw }}</div>
                    </div>
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {# Anishinaabemowin Corner inline content (vocab grid, phrases, etc.) #}
    {% if items_by_section['language_corner'] is defined %}
        {% for item in items_by_section['language_corner'] %}
            {% if item.get('included') %}
            <article>
                {% if item.get('inline_title') %}
                    <h3>{{ item.get('inline_title') }}</h3>
                {% endif %}
                {% if item.get('inline_body') %}
                    <div>{{ item.get('inline_body')|raw }}</div>
                {% endif %}
                {% if item.get('kind') == 'vocab_grid' %}
                    {% set vg = item.get('structured') %}
                    {% if vg and vg.cards %}
                    <div class="vocab-grid">
                        {% for c in vg.cards %}
                        <div class="vocab-card">
                            {% if c.svg %}{{ c.svg|raw }}{% endif %}
                            <div class="vocab-word">{{ c.word }}</div>
                            {% if c.pronunciation %}<div class="vocab-pron">{{ c.pronunciation }}</div>{% endif %}
                            <div class="vocab-meaning">{{ c.meaning }}</div>
                            {% if c.example %}<div class="vocab-example">{{ c.example }}</div>{% endif %}
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                {% endif %}
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if review_mode|default(false) %}
    <div class="collaborator-note">
        <h4>Note for Language Collaborators</h4>
        <p>This section is reserved for Anishinaabemowin language content.
           We are looking for contributions that help readers connect with the language
           in an accessible, everyday way.</p>
        <p><strong>What we are looking for:</strong></p>
        <ul>
            <li>Vocabulary (5-10 words with pronunciation and definitions)</li>
            <li>Common phrases or greetings for the season</li>
            <li>Cultural context for how words are used in ceremony or daily life</li>
        </ul>
        <p><strong>Space available:</strong> Approximately 200-300 words
           (half a printed page in the newsletter layout above).</p>
        <p><strong>To submit:</strong> Email your content to the Minoo editorial team,
           or share via a document link. We will format it to match the newsletter style.</p>
        <p><strong>Timeline:</strong> Content received before the print deadline will be
           included in this issue. Otherwise, it will appear in the next issue.</p>
    </div>
    {% endif %}

</div>

{# ============================================================
   PAGE 7 — Our Territory (Robinson Huron Treaty First Nations)
   ============================================================ #}
<div class="page">
    <h2>Our Territory</h2>
    <div class="section-intro">The twenty-one First Nations of the Robinson Huron Treaty, 1850.</div>

    {% if items_by_section['territory'] is defined %}
        {% for item in items_by_section['territory'] %}
            {% if item.get('included') %}
            {% set data = item.get('structured') %}
            {% if data.epigraph is defined %}
                <p class="territory-epigraph">&ldquo;{{ data.epigraph }}&rdquo;</p>
            {% endif %}
            {% if data.intro is defined %}
                <p class="territory-intro">{{ data.intro }}</p>
            {% endif %}
            {% if data.nations is defined %}
                <ul class="territory-list">
                    {% for n in data.nations %}
                        <li>
                            <span class="t-name">{{ n.name }}</span>
                            {% if n.meaning %}<span class="t-meaning">&mdash; {{ n.meaning }}</span>{% endif %}
                            {% if n.note %}<span class="t-note">({{ n.note }})</span>{% endif %}
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
            {% if data.closing is defined %}
                <p class="territory-closing">{{ data.closing }}</p>
            {% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 8 — Jokes & Humour
   ============================================================ #}
<div class="page">
    <h2>Jokes &amp; Humour</h2>
    <div class="section-intro">A little laughter is good medicine.</div>

    {% if items_by_section['jokes'] is defined %}
        <div class="jokes-grid">
        {% for item in items_by_section['jokes'] %}
            {% if item.get('included') %}
                {{ item.get('inline_body')|raw }}
            {% endif %}
        {% endfor %}
        </div>
    {% endif %}

</div>

{# ============================================================
   PAGE 9 — Puzzles
   ============================================================ #}
<div class="page">
    <h2>Puzzles</h2>
    <div class="section-intro">Something to work on with your morning tea.</div>

    {% if items_by_section['puzzles'] is defined %}
        {# Word search renders full-width first #}
        {% for item in items_by_section['puzzles'] %}
            {% if item.get('included') and item.get('kind') == 'word_search' %}
            <article class="puzzle-main">
                {% if item.get('inline_title') %}<h3>{{ item.get('inline_title') }}</h3>{% endif %}
                {% if item.get('inline_body') %}<div>{{ item.get('inline_body')|raw }}</div>{% endif %}
                {% set ws = item.get('structured') %}
                {% if ws and ws.grid %}
                <table class="word-search-grid">
                    {% for row in ws.grid %}
                    <tr>{% for cell in row %}<td>{{ cell }}</td>{% endfor %}</tr>
                    {% endfor %}
                </table>
                {% if ws.words %}
                <ul class="word-list">
                    {% for w in ws.words %}<li>{{ w }}</li>{% endfor %}
                </ul>
                {% endif %}
                {% endif %}
            </article>
            {% endif %}
        {% endfor %}

        {# Remaining puzzle items (riddle, scramble, etc.) flow in two columns #}
        <div class="puzzle-tail">
            {% for item in items_by_section['puzzles'] %}
                {% if item.get('included') and item.get('kind') != 'word_search' %}
                <article class="puzzle-card">
                    {% if item.get('inline_title') %}<h3>{{ item.get('inline_title') }}</h3>{% endif %}
                    {% if item.get('inline_body') %}<div>{{ item.get('inline_body')|raw }}</div>{% endif %}
                </article>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

</div>

{# ============================================================
   PAGE 10 — Clan Horoscopes
   ============================================================ #}
<div class="page">
    <h2>Clan Horoscopes</h2>
    <div class="section-intro">Seasonal guidance drawn from the clans. Take what speaks to you.</div>

    <div class="two-col">
        {% if items_by_section['horoscope'] is defined %}
            {% for item in items_by_section['horoscope'] %}
                {% if item.get('included') %}
                <div class="horoscope-item">
                    {% if item.get('inline_title') %}
                        <h3>{{ item.get('inline_title') }}</h3>
                    {% endif %}
                    <div>{{ item.get('inline_body')|raw }}</div>
                </div>
                {% endif %}
            {% endfor %}
        {% endif %}
    </div>

</div>

{# ============================================================
   PAGE 11 — Elder Spotlight
   ============================================================ #}
<div class="page elder-spotlight-page">
    <h2>Elder Spotlight</h2>
    <div class="section-intro">Honouring the people who carry our community forward.</div>

    {% if items_by_section['elder_spotlight'] is defined %}
        {% for item in items_by_section['elder_spotlight'] %}
            {% if item.get('included') %}
                {% set k = item.get('kind') %}
                {% if k == 'spotlight_callout' %}
                    <aside class="spotlight-callout">
                        {% if item.get('inline_title') %}<h3>{{ item.get('inline_title') }}</h3>{% endif %}
                        <div>{{ item.get('inline_body')|raw }}</div>
                    </aside>
                {% else %}
                    {% if k == 'spotlight' and item.get('media_url') %}
                        <div class="photo-wrap float-left">
                            <img src="{{ item.get('media_url') }}" alt="{{ item.get('media_alt') }}">
                            {% if item.get('media_caption') %}
                                <p class="photo-caption">{{ item.get('media_caption') }}</p>
                            {% endif %}
                        </div>
                    {% endif %}
                    <article class="prose{% if k == 'spotlight' or k == 'drop_cap' %} drop-cap{% endif %}">
                        {% if item.get('inline_title') %}
                            <h3>{{ item.get('inline_title') }}</h3>
                        {% endif %}
                        <div>{{ item.get('inline_body')|raw }}</div>
                    </article>
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}

</div>

{# ============================================================
   PAGE 15 — Reader Mail & Next Issue
   ============================================================ #}
<div class="page">
    <h2>Reader Mail &amp; Next Issue</h2>
    <div class="section-intro">What we are hoping you send us for Issue 2.</div>

    {% if items_by_section['reader_mail'] is defined %}
        {% for item in items_by_section['reader_mail'] %}
            {% if item.get('included') %}
            <article class="prose reader-mail">
                <div>{{ item.get('inline_body')|raw }}</div>
            </article>
            {% endif %}
        {% endfor %}
    {% endif %}
</div>

{# ============================================================
   PAGE 16 — Back Cover (colophon + mailing panel + teaser)
   ============================================================ #}
<div class="page back-cover">

    <div class="back-cover-teaser">
        <div class="teaser-kicker">Issue 2 &middot; Niibin / Summer 2026</div>
        <h3 class="teaser-head">The powwow trail, a summer of markets, and what Grace planted.</h3>
        <p class="teaser-sub">Send us your photos, stories, and events by June&nbsp;15.</p>
    </div>

    <div class="back-cover-grid">
        <section class="colophon-block">
            <h4>About this newsletter</h4>
            {% set had_back_page_content = false %}
            {% if items_by_section['back_page'] is defined %}
                {% for item in items_by_section['back_page'] %}
                    {% if item.get('included') %}
                        {% set k = item.get('kind') %}
                        {% if k == 'back_page_box' %}
                            {% set had_back_page_content = true %}
                            <div class="back-page-box">
                                {% if item.get('inline_title') %}<h5>{{ item.get('inline_title') }}</h5>{% endif %}
                                {{ item.get('inline_body')|raw }}
                            </div>
                        {% elseif k == 'colophon' %}
                            {% set had_back_page_content = true %}
                            <div class="colophon">{{ item.get('inline_body')|raw }}</div>
                        {% elseif k != 'partners' %}
                            {% set had_back_page_content = true %}
                            <div class="prose">{{ item.get('inline_body')|raw }}</div>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            {% endif %}
            {% if not had_back_page_content %}
                <p>This newsletter is generated by <strong>Minoo Live</strong>, a
                community platform built by Anishinaabe people for Indigenous
                communities. Stories and events are contributed at
                <strong>minoo.live</strong> and curated by the Keeper.</p>
                <p>Printed in Espanola, Ontario. Free to our communities.</p>
            {% endif %}

            <dl class="colophon-meta">
                <dt>Editor &amp; Keeper</dt><dd>Russell Jones, Sagamok Anishnawbek</dd>
                <dt>Published</dt><dd>{{ edition.get('publish_date') }}</dd>
                <dt>Issue</dt><dd>Vol. {{ edition.get('volume') }} &middot; No. {{ edition.get('issue_number') }}</dd>
                <dt>Contact</dt><dd>hello@minoo.live &middot; minoo.live</dd>
            </dl>
        </section>

        <section class="mailing-panel" aria-label="Mailing panel">
            <div class="indicia">
                <div class="indicia-box">
                    <div>Canada Post</div>
                    <div>Publications Mail</div>
                    <div>Agreement No.</div>
                    <div class="indicia-number">[pending]</div>
                </div>
                <div class="return-address">
                    <strong>Return undeliverable to:</strong><br>
                    Minoo Live<br>
                    [Street address]<br>
                    Sagamok, ON&nbsp; [P.C.]
                </div>
            </div>
            <div class="address-window" aria-hidden="true"></div>
        </section>
    </div>

    {% if items_by_section['back_page'] is defined %}
        {% for item in items_by_section['back_page'] %}
            {% if item.get('included') and item.get('kind') == 'partners' %}
                {% set ps = item.get('structured') %}
                <div class="partners back-cover-partners">
                    <div class="partners-label">With thanks to</div>
                    <div class="partners-logos">
                        {% for p in (ps.partners ?? []) %}
                            <div class="partner-logo">
                                {% if p.svg %}{{ p.svg|raw }}{% endif %}
                                <div class="partner-name">
                                    {% if p.url %}<a href="{{ p.url }}">{{ p.name }}</a>{% else %}{{ p.name }}{% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    {% endif %}

    <div class="back-cover-footer">
        <span class="wordmark">Minoo</span>
        <span class="footer-tag">For Communities &middot; <em>minoo.live</em></span>
    </div>
</div>

{% endblock %}
