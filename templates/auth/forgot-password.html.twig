{% extends "base.html.twig" %}

{% block title %}Forgot Password — Minoo{% endblock %}

{% block content %}
<section class="content-section flow-lg">
  <h1>Forgot your password?</h1>
  <p>Enter your email address and we'll generate a reset link.</p>

  {% if reset_url is defined and reset_url %}
    <div class="form__success" role="status">
      <p>A reset link has been generated. Click the link below to reset your password:</p>
      <p><a href="{{ reset_url }}">{{ reset_url }}</a></p>
    </div>
  {% elseif submitted is defined and submitted %}
    <div class="form__success" role="status">
      <p>If an account exists with that email, a reset link has been generated.</p>
    </div>
  {% endif %}

  <form class="form" method="post" action="/forgot-password">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
    <div class="form__field">
      <label class="form__label" for="email">Email</label>
      <input
        class="form__input"
        type="email" id="email" name="email"
        value="{{ values.email|default('') }}"
        required autocomplete="email">
    </div>

    <div class="form__actions">
      <button class="form__submit" type="submit">Send Reset Link</button>
    </div>
  </form>

  <p class="form__link"><a href="/login">Back to login</a></p>
</section>
{% endblock %}
