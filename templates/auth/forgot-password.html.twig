{% extends "base.html.twig" %}

{% block title %}{{ trans('auth.forgot_title') }} — Minoo{% endblock %}

{% block content %}
<section class="content-section flow-lg">
  <h1>{{ trans('auth.forgot_title') }}</h1>
  <p>{{ trans('auth.forgot_intro') }}</p>

  {% if reset_url is defined and reset_url %}
    <div class="form__success" role="status">
      <p>{{ trans('auth.reset_link_generated') }}</p>
      <p><a href="{{ reset_url }}">{{ reset_url }}</a></p>
    </div>
  {% elseif submitted is defined and submitted %}
    <div class="form__success" role="status">
      <p>{{ trans('auth.reset_submitted') }}</p>
    </div>
  {% endif %}

  <form class="form form--centered" method="post" action="{{ lang_url('/forgot-password') }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
    <div class="form__field">
      <label class="form__label" for="email">{{ trans('auth.email') }}</label>
      <input
        class="form__input"
        type="email" id="email" name="email"
        value="{{ values.email|default('') }}"
        required autocomplete="email">
    </div>

    <div class="form__actions">
      <button class="form__submit" type="submit">{{ trans('auth.reset_button') }}</button>
    </div>
  </form>

  <p class="form__link"><a href="{{ lang_url('/login') }}">{{ trans('auth.back_to_login') }}</a></p>
</section>
{% endblock %}
