{% extends "base.html.twig" %}

{% block title %}{{ trans('auth.reset_title') }} — Minoo{% endblock %}

{% block content %}
<section class="content-section flow-lg">
  <h1>{{ trans('auth.reset_title') }}</h1>

  {% if token_error is defined and token_error %}
    <div class="form__error-banner" role="alert">
      <p>{{ token_error }}</p>
    </div>
    <p class="form__link"><a href="{{ lang_url('/forgot-password') }}">{{ trans('auth.reset_error_link') }}</a></p>
  {% else %}
    <form class="form" method="post" action="{{ lang_url('/reset-password') }}">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
      <input type="hidden" name="token" value="{{ token }}">

      <div class="form__field">
        <label class="form__label" for="password">{{ trans('auth.new_password') }}</label>
        <input
          class="form__input{% if errors.password is defined %} form__input--error{% endif %}"
          type="password" id="password" name="password"
          minlength="8"
          required autocomplete="new-password">
        {% if errors.password is defined %}
          <p class="form__error" role="alert">{{ errors.password }}</p>
        {% endif %}
      </div>

      <div class="form__field">
        <label class="form__label" for="password_confirm">{{ trans('auth.confirm_password') }}</label>
        <input
          class="form__input{% if errors.password_confirm is defined %} form__input--error{% endif %}"
          type="password" id="password_confirm" name="password_confirm"
          minlength="8"
          required autocomplete="new-password">
        {% if errors.password_confirm is defined %}
          <p class="form__error" role="alert">{{ errors.password_confirm }}</p>
        {% endif %}
      </div>

      <div class="form__actions">
        <button class="form__submit" type="submit">{{ trans('auth.reset_submit') }}</button>
      </div>
    </form>
  {% endif %}
</section>
{% endblock %}
