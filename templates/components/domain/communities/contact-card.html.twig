{# Required: —
   Optional: people (array|null), band_office (array|null) #}
{# Leadership + Band Office contact card for a community.
   Expects: people (array|null), band_office (array|null) #}

{# --- Leadership --- #}
{% if people is not empty %}
<div class="community-section">
  <div class="community-section__label">{{ trans('community.leadership') }}</div>
  {% for person in people %}
    {% if person.role == 'chief' %}
    <div class="card card--compact card--person" style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <div class="card__badge">{{ trans('community.chief') }}</div>
        <div class="card__title">{{ person.name }}</div>
      </div>
      <div class="card__meta">{{ trans('community.current') }}</div>
    </div>
    {% endif %}
  {% endfor %}
  <div class="community-leader-grid">
    {% for person in people %}
      {% if person.role == 'councillor' %}
      <div class="card card--compact card--person">
        <div class="card__badge">{{ trans('community.councillor') }}</div>
        <div class="card__title">{{ person.name }}</div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}

{# --- Band Office --- #}
{% if band_office %}
<div class="community-section">
  <div class="community-section__label">{{ trans('community.band_office') }}</div>
  <div class="card card--contact">
    <div class="card--contact__grid">
      {% if band_office.address_line1 %}
      <div>
        <div class="card--contact__label">{{ trans('community.address') }}</div>
        <div class="card--contact__value">
          {{ band_office.address_line1 }}
          {% if band_office.address_line2 %}<br>{{ band_office.address_line2 }}{% endif %}
          {% if band_office.city %}<br>{{ band_office.city }}, {{ band_office.province }} {{ band_office.postal_code }}{% endif %}
        </div>
      </div>
      {% endif %}
      {% if band_office.office_hours %}
      <div>
        <div class="card--contact__label">{{ trans('community.hours') }}</div>
        <div class="card--contact__value">{{ band_office.office_hours }}</div>
      </div>
      {% endif %}
      {% if band_office.phone %}
      <div>
        <div class="card--contact__label">{{ trans('community.phone') }}</div>
        <div class="card--contact__value"><a href="tel:{{ band_office.phone }}">{{ band_office.phone }}</a></div>
      </div>
      {% endif %}
      {% if band_office.email %}
      <div>
        <div class="card--contact__label">{{ trans('community.email') }}</div>
        <div class="card--contact__value"><a href="mailto:{{ band_office.email }}">{{ band_office.email }}</a></div>
      </div>
      {% endif %}
      {% if band_office.toll_free %}
      <div>
        <div class="card--contact__label">{{ trans('community.toll_free') }}</div>
        <div class="card--contact__value"><a href="tel:{{ band_office.toll_free }}">{{ band_office.toll_free }}</a></div>
      </div>
      {% endif %}
      {% if band_office.fax %}
      <div>
        <div class="card--contact__label">{{ trans('community.fax') }}</div>
        <div class="card--contact__value">{{ band_office.fax }}</div>
      </div>
      {% endif %}
    </div>
  </div>
</div>
{% endif %}
