{# Expects: title, events (list), communities (map), variant (optional: 'featured'|'now') #}
<section class="event-feed__section{% if variant is defined %} event-feed__section--{{ variant }}{% endif %}">
  <header class="event-feed__section-header">
    <h2>{{ title }}</h2>
    <span class="event-feed__section-count">{{ events|length }}</span>
  </header>
  <div class="card-grid">
    {% for e in events %}
      {% set comm = communities[e.get('community_id')]|default({}) %}
      {% include "components/event-card.html.twig" with {
        title: e.get('title'),
        type: e.get('type')|default('')|capitalize,
        date: e.get('starts_at') ? e.get('starts_at')|date('F j, Y') : '',
        location: e.get('location')|default(''),
        excerpt: e.get('description')|default('')|split("\n\n")|first|length > 120 ? e.get('description')|default('')|split("\n\n")|first|slice(0, 120) ~ '…' : e.get('description')|default('')|split("\n\n")|first,
        url: "/events/" ~ e.get('slug'),
        community_name: comm.name|default(''),
        community_slug: comm.slug|default('')
      } %}
    {% endfor %}
  </div>
</section>
