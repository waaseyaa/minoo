{% if chat_enabled is defined and chat_enabled %}
<div id="chat-widget" class="chat-widget" aria-label="{{ trans('chat.title') }}"
     data-trans-thinking="{{ trans('chat.thinking') }}"
     data-trans-error="{{ trans('chat.error') }}">
  <button class="chat-widget__toggle" aria-expanded="false" aria-controls="chat-panel">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span class="visually-hidden">{{ trans('chat.toggle_label') }}</span>
  </button>

  <div id="chat-panel" class="chat-widget__panel" hidden>
    <div class="chat-widget__header">
      <h2 class="chat-widget__title">{{ trans('chat.title') }}</h2>
      <button class="chat-widget__close" aria-label="{{ trans('chat.close_label') }}">&times;</button>
    </div>

    <div class="chat-widget__messages" role="log" aria-live="polite">
      <div class="chat-widget__message chat-widget__message--assistant">
        <p>{{ trans('chat.initial_message') }}</p>
      </div>
    </div>

    <form class="chat-widget__form" autocomplete="off">
      <label for="chat-input" class="visually-hidden">{{ trans('chat.input_label') }}</label>
      <input id="chat-input" class="chat-widget__input" type="text" placeholder="{{ trans('chat.input_placeholder') }}" maxlength="2000" required>
      <button class="chat-widget__send" type="submit">{{ trans('chat.send_button') }}</button>
    </form>

    <p class="chat-widget__disclaimer">{{ trans('chat.disclaimer') }}</p>
  </div>
</div>
{% endif %}
