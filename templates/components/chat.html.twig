{% if chat_enabled is defined and chat_enabled %}
<div id="chat-widget" class="chat-widget" aria-label="Community assistant chat">
  <button class="chat-widget__toggle" aria-expanded="false" aria-controls="chat-panel">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span class="visually-hidden">Open chat</span>
  </button>

  <div id="chat-panel" class="chat-widget__panel" hidden>
    <div class="chat-widget__header">
      <h2 class="chat-widget__title">Community Assistant</h2>
      <button class="chat-widget__close" aria-label="Close chat">&times;</button>
    </div>

    <div class="chat-widget__messages" role="log" aria-live="polite">
      <div class="chat-widget__message chat-widget__message--assistant">
        <p>Hello! I can help you find events, teachings, groups, and other community resources. What are you looking for?</p>
      </div>
    </div>

    <form class="chat-widget__form" autocomplete="off">
      <label for="chat-input" class="visually-hidden">Your message</label>
      <input id="chat-input" class="chat-widget__input" type="text" placeholder="Ask about community resources..." maxlength="2000" required>
      <button class="chat-widget__send" type="submit">Send</button>
    </form>

    <p class="chat-widget__disclaimer">Responses are generated by AI and may not always be accurate.</p>
  </div>
</div>
{% endif %}
