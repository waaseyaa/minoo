{% extends "base.html.twig" %}

{% block title %}{{ trans('elders.title') }} — Minoo{% endblock %}
{% block og_title %}Elder Support Program — Minoo{% endblock %}
{% block og_description %}Rides, groceries, yard work, visits. Our Elders shouldn't have to ask twice. Request help or volunteer your time.{% endblock %}
{% block og_image %}https://minoo.live/img/og-elder-support.png{% endblock %}

{% block content %}
<section class="content-section flow-lg">
  <div class="portal-section">
    <h1>{{ trans('elders.title') }}</h1>
    <p class="text-secondary">{{ trans('elders.subtitle') }}</p>
  </div>

  <div class="portal-section flow">
    <h2 data-testid="how-it-works-heading">{{ trans('elders.how_heading') }}</h2>
    <div class="how-it-works">
      <div class="how-it-works__step flow">
        <h3 data-testid="step-1-heading">{{ trans('elders.step1_title') }}</h3>
        <p>{{ trans('elders.step1_text') }}</p>
      </div>
      <div class="how-it-works__step flow">
        <h3 data-testid="step-2-heading">{{ trans('elders.step2_title') }}</h3>
        <p>{{ trans('elders.step2_text') }}</p>
      </div>
      <div class="how-it-works__step flow">
        <h3 data-testid="step-3-heading">{{ trans('elders.step3_title') }}</h3>
        <p>{{ trans('elders.step3_text') }}</p>
      </div>
    </div>
  </div>

  <div class="how-it-works">
    <div class="how-it-works__step">
      <h2>{{ trans('elders.for_elders_heading') }}</h2>
      <p>{{ trans('elders.for_elders_text') }}</p>
      <ol class="how-it-works__list">
        <li>{{ trans('elders.for_elders_step1') }}</li>
        <li>{{ trans('elders.for_elders_step2') }}</li>
        <li>{{ trans('elders.for_elders_step3') }}</li>
        <li>{{ trans('elders.for_elders_step4') }}</li>
      </ol>
      <a href="{{ lang_url('/elders/request') }}" class="btn btn--primary" data-testid="request-help-link">{{ trans('elders.request_help_button') }}</a>
    </div>

    <div class="how-it-works__step">
      <h2>{{ trans('elders.for_volunteers_heading') }}</h2>
      <p>{{ trans('elders.for_volunteers_text') }}</p>
      <ol class="how-it-works__list">
        <li>{{ trans('elders.for_volunteers_step1') }}</li>
        <li>{{ trans('elders.for_volunteers_step2') }}</li>
        <li>{{ trans('elders.for_volunteers_step3') }}</li>
        <li>{{ trans('elders.for_volunteers_step4') }}</li>
      </ol>
      <a href="{{ lang_url('/elders/volunteer') }}" class="btn btn--secondary">{{ trans('elders.volunteer_button') }}</a>
    </div>
  </div>

  <div class="safety-callout">
    <h2>{{ trans('elders.safety_heading') }}</h2>
    <p>{{ trans('elders.safety_text') }} <a href="{{ lang_url('/safety') }}">{{ trans('elders.safety_link') }}</a>.</p>
  </div>

  <div class="portal-section">
    <h2>{{ trans('elders.prefer_call_heading') }}</h2>
    <p>{{ trans('elders.prefer_call_text') }}</p>
  </div>
</section>
{% endblock %}
