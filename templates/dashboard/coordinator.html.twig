{% extends "base.html.twig" %}

{% block title %}Coordinator Dashboard — Minoo{% endblock %}

{% block content %}
<section class="content-section flow-lg">
  <h1>Coordinator Dashboard</h1>
  <p class="text-secondary">You're the link between Elders who need support and volunteers who can help. Here's what needs your attention.</p>

  <h2>Open Requests ({{ open_requests|length }})</h2>
  {% if open_requests is empty %}
    <p class="dashboard__empty">No open requests right now. New requests will appear here as they come in.</p>
  {% else %}
  <div class="dashboard__cards">
    {% for req in open_requests %}
    <article class="card card--dashboard">
      <span class="card__badge card__badge--open">Open</span>
      <h3 class="card__title">{{ req.get('name') }}</h3>
      <dl class="card__meta">
        <dt>Type</dt><dd>{{ req.get('type') }}</dd>
        {% if req.get('phone') %}<dt>Phone</dt><dd>{{ req.get('phone') }}</dd>{% endif %}
        {% if req.get('community') %}<dt>Community</dt><dd>{{ community_names[req.get('community')]|default(req.get('community')) }}</dd>{% endif %}
        {% if req.get('notes') %}<dt>Notes</dt><dd>{{ req.get('notes') }}</dd>{% endif %}
      </dl>
      <form class="dashboard__assign-form" method="post" action="/elders/request/{{ req.id() }}/assign">
        <label class="form__label" for="volunteer-{{ req.id() }}">Assign to</label>
        <select class="form__select" name="volunteer_id" id="volunteer-{{ req.id() }}" required>
          <option value="">Select volunteer...</option>
          {% set ranked = ranked_by_request[req.id()] ?? [] %}
          {% for rv in ranked %}
          <option value="{{ rv.volunteer.id() }}">{{ rv.volunteer.get('name') }}{% if rv.hasDistance() %} — {{ rv.formattedDistance() }}{% if rv.exceedsMaxTravel %} (exceeds {{ rv.volunteer.get('max_travel_km') }} km limit){% endif %}{% elseif rv.volunteer.get('community') %} ({{ community_names[rv.volunteer.get('community')]|default(rv.volunteer.get('community')) }}){% endif %}</option>
          {% endfor %}
        </select>
        <button class="form__submit" type="submit">Assign</button>
      </form>
      <details class="dashboard__cancel-details">
        <summary class="form__link">Cancel Request</summary>
        <form method="post" action="/elders/request/{{ req.id() }}/cancel" class="dashboard__cancel-form">
          <label class="form__label" for="cancel-reason-{{ req.id() }}">Reason</label>
          <textarea class="form__textarea" id="cancel-reason-{{ req.id() }}" name="reason" rows="2"></textarea>
          <button class="form__submit form__submit--danger form__submit--sm" type="submit">Confirm Cancel</button>
        </form>
      </details>
    </article>
    {% endfor %}
  </div>
  {% endif %}

  <h2>Assigned / In Progress ({{ assigned_requests|length }})</h2>
  {% if assigned_requests is empty %}
    <p class="dashboard__empty">No assigned requests.</p>
  {% else %}
  <div class="dashboard__cards">
    {% for req in assigned_requests %}
    <article class="card card--dashboard">
      <span class="card__badge card__badge--{{ req.get('status') }}">{{ req.get('status')|replace({'_': ' '})|title }}</span>
      <h3 class="card__title">{{ req.get('name') }}</h3>
      <dl class="card__meta">
        <dt>Type</dt><dd>{{ req.get('type') }}</dd>
        {% if req.get('phone') %}<dt>Phone</dt><dd>{{ req.get('phone') }}</dd>{% endif %}
        {% if req.get('community') %}<dt>Community</dt><dd>{{ community_names[req.get('community')]|default(req.get('community')) }}</dd>{% endif %}
        {% set assigned_volunteer = volunteers_by_id[req.get('assigned_volunteer')] ?? null %}
        {% if assigned_volunteer %}<dt>Volunteer</dt><dd>{{ assigned_volunteer.get('name') }}</dd>{% endif %}
      </dl>
      {% if req.get('status') == 'assigned' %}
      <details class="dashboard__reassign-details">
        <summary class="form__link">Reassign</summary>
        <form class="dashboard__assign-form" method="post" action="/elders/request/{{ req.id() }}/reassign">
          <label class="form__label" for="reassign-volunteer-{{ req.id() }}">Reassign to</label>
          <select class="form__select" name="volunteer_id" id="reassign-volunteer-{{ req.id() }}" required>
            <option value="">Select volunteer...</option>
            {% set ranked = ranked_by_request[req.id()] ?? [] %}
            {% for rv in ranked %}
            <option value="{{ rv.volunteer.id() }}">{{ rv.volunteer.get('name') }}{% if rv.hasDistance() %} — {{ rv.formattedDistance() }}{% if rv.exceedsMaxTravel %} (exceeds {{ rv.volunteer.get('max_travel_km') }} km limit){% endif %}{% elseif rv.volunteer.get('community') %} ({{ community_names[rv.volunteer.get('community')]|default(rv.volunteer.get('community')) }}){% endif %}</option>
            {% endfor %}
          </select>
          <button class="form__submit" type="submit">Reassign</button>
        </form>
      </details>
      {% endif %}
      <details class="dashboard__cancel-details">
        <summary class="form__link">Cancel Request</summary>
        <form method="post" action="/elders/request/{{ req.id() }}/cancel" class="dashboard__cancel-form">
          <label class="form__label" for="cancel-reason-{{ req.id() }}">Reason</label>
          <textarea class="form__textarea" id="cancel-reason-{{ req.id() }}" name="reason" rows="2"></textarea>
          <button class="form__submit form__submit--danger form__submit--sm" type="submit">Confirm Cancel</button>
        </form>
      </details>
    </article>
    {% endfor %}
  </div>
  {% endif %}

  <h2>Pending Confirmation ({{ pending_confirmation|length }})</h2>
  {% if pending_confirmation is empty %}
    <p class="dashboard__empty">No requests waiting for confirmation.</p>
  {% else %}
  <div class="dashboard__cards">
    {% for req in pending_confirmation %}
    <article class="card card--dashboard">
      <span class="card__badge card__badge--completed">Completed</span>
      <h3 class="card__title">{{ req.get('name') }}</h3>
      <dl class="card__meta">
        <dt>Type</dt><dd>{{ req.get('type') }}</dd>
        {% set assigned_vol = volunteers_by_id[req.get('assigned_volunteer')] ?? null %}
        {% if assigned_vol %}<dt>Volunteer</dt><dd>{{ assigned_vol.get('name') }}</dd>{% endif %}
        {% if req.get('completion_notes') %}<dt>Notes</dt><dd>{{ req.get('completion_notes') }}</dd>{% endif %}
      </dl>
      <form method="post" action="/elders/request/{{ req.id() }}/confirm">
        <button class="form__submit" type="submit">Confirm Completion</button>
      </form>
    </article>
    {% endfor %}
  </div>
  {% endif %}

  <h2>Volunteer Pool ({{ volunteers|length }})</h2>
  {% if volunteers is empty %}
    <p class="dashboard__empty">No active volunteers yet. Volunteer signups will appear here once approved.</p>
  {% else %}
  <div class="dashboard__cards">
    {% for vol in volunteers %}
    <article class="card card--dashboard">
      <h3 class="card__title">{{ vol.get('name') }}</h3>
      <dl class="card__meta">
        <dt>Phone</dt><dd>{{ vol.get('phone') }}</dd>
        {% if vol.get('community') %}<dt>Community</dt><dd>{{ community_names[vol.get('community')]|default(vol.get('community')) }}</dd>{% endif %}
        {% if vol.get('availability') %}<dt>Availability</dt><dd>{{ vol.get('availability') }}</dd>{% endif %}
      </dl>
    </article>
    {% endfor %}
  </div>
  {% endif %}

  <h2>History</h2>
  {% set has_history = confirmed_requests is not empty or cancelled_requests is not empty %}
  {% if not has_history %}
    <p class="dashboard__empty">No completed or cancelled requests yet.</p>
  {% else %}
  <div class="dashboard__cards">
    {% for req in confirmed_requests %}
    <article class="card card--dashboard card--history">
      <span class="card__badge card__badge--confirmed">Confirmed</span>
      <h3 class="card__title">{{ req.get('name') }}</h3>
      <dl class="card__meta">
        <dt>Type</dt><dd>{{ req.get('type') }}</dd>
      </dl>
    </article>
    {% endfor %}
    {% for req in cancelled_requests %}
    <article class="card card--dashboard card--history">
      <span class="card__badge card__badge--cancelled">Cancelled</span>
      <h3 class="card__title">{{ req.get('name') }}</h3>
      <dl class="card__meta">
        <dt>Type</dt><dd>{{ req.get('type') }}</dd>
        {% if req.get('cancelled_reason') %}<dt>Reason</dt><dd>{{ req.get('cancelled_reason') }}</dd>{% endif %}
      </dl>
    </article>
    {% endfor %}
  </div>
  {% endif %}
</section>
{% endblock %}
