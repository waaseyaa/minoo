{% extends "base.html.twig" %}

{% block title %}My Dashboard — Minoo{% endblock %}

{% block content %}
<section class="content-section flow-lg">
  <h1>My Assignments</h1>
  <p class="text-secondary">Your coordinator will assign requests to you. Here's where you'll manage them.</p>

  {% if volunteer is defined and volunteer %}
  <div class="dashboard__profile-bar">
    <span class="status-indicator status-indicator--{{ volunteer.get('status') }}">{{ volunteer.get('status')|title }}</span>
    <a href="/dashboard/volunteer/edit" class="form__link">Edit Profile</a>
    <form method="post" action="/dashboard/volunteer/toggle-availability" class="dashboard__toggle-form">
      <button type="submit" class="form__submit form__submit--secondary form__submit--sm">
        {% if volunteer.get('status') == 'active' %}Go Unavailable{% else %}Go Active{% endif %}
      </button>
    </form>
  </div>
  {% endif %}

  {% if requests is empty %}
    <p class="dashboard__empty">No assignments yet. When a coordinator matches you with an Elder, it'll show up here.</p>
  {% else %}

    {% if grouped.assigned is not empty %}
    <h2>Assigned to You</h2>
    <div class="dashboard__cards">
      {% for req in grouped.assigned %}
      <article class="card card--dashboard">
        <span class="card__badge card__badge--assigned">Assigned</span>
        <h3 class="card__title">{{ req.get('name') }}</h3>
        <dl class="card__meta">
          <dt>Type</dt><dd>{{ req.get('type') }}</dd>
          {% if req.get('phone') %}<dt>Phone</dt><dd>{{ req.get('phone') }}</dd>{% endif %}
          {% if req.get('community') %}<dt>Community</dt><dd>{{ req.get('community') }}</dd>{% endif %}
          {% if req.get('notes') %}<dt>Notes</dt><dd>{{ req.get('notes') }}</dd>{% endif %}
        </dl>
        <div class="card__actions">
          <form method="post" action="/elders/request/{{ req.id() }}/start">
            <button class="form__submit" type="submit">Accept & Start</button>
          </form>
          <form method="post" action="/elders/request/{{ req.id() }}/decline">
            <button class="form__submit form__submit--secondary form__submit--sm" type="submit">Decline</button>
          </form>
        </div>
      </article>
      {% endfor %}
    </div>
    {% endif %}

    {% if grouped.in_progress is not empty %}
    <h2>In Progress</h2>
    <div class="dashboard__cards">
      {% for req in grouped.in_progress %}
      <article class="card card--dashboard">
        <span class="card__badge card__badge--in-progress">In Progress</span>
        <h3 class="card__title">{{ req.get('name') }}</h3>
        <dl class="card__meta">
          <dt>Type</dt><dd>{{ req.get('type') }}</dd>
          {% if req.get('phone') %}<dt>Phone</dt><dd>{{ req.get('phone') }}</dd>{% endif %}
          {% if req.get('community') %}<dt>Community</dt><dd>{{ req.get('community') }}</dd>{% endif %}
          {% if req.get('notes') %}<dt>Notes</dt><dd>{{ req.get('notes') }}</dd>{% endif %}
        </dl>
        <details class="dashboard__complete-details">
          <summary class="form__submit" type="button">Mark Complete</summary>
          <form method="post" action="/elders/request/{{ req.id() }}/complete" class="dashboard__complete-form">
            <label class="form__label" for="completion-notes-{{ req.id() }}">How did it go? (optional)</label>
            <textarea class="form__textarea" id="completion-notes-{{ req.id() }}" name="completion_notes" rows="2"></textarea>
            <button class="form__submit" type="submit">Confirm Complete</button>
          </form>
        </details>
      </article>
      {% endfor %}
    </div>
    {% endif %}

    {% if grouped.completed is not empty %}
    <h2>Completed (Awaiting Confirmation)</h2>
    <div class="dashboard__cards">
      {% for req in grouped.completed %}
      <article class="card card--dashboard">
        <span class="card__badge card__badge--completed">Completed</span>
        <h3 class="card__title">{{ req.get('name') }}</h3>
        <dl class="card__meta">
          <dt>Type</dt><dd>{{ req.get('type') }}</dd>
        </dl>
        <p class="card__note">Waiting for coordinator confirmation.</p>
      </article>
      {% endfor %}
    </div>
    {% endif %}

    {% if grouped.confirmed is not empty %}
    <h2>History</h2>
    <div class="dashboard__cards">
      {% for req in grouped.confirmed %}
      <article class="card card--dashboard card--history">
        <span class="card__badge card__badge--confirmed">Confirmed</span>
        <h3 class="card__title">{{ req.get('name') }}</h3>
        <dl class="card__meta">
          <dt>Type</dt><dd>{{ req.get('type') }}</dd>
        </dl>
      </article>
      {% endfor %}
    </div>
    {% endif %}

  {% endif %}
</section>
{% endblock %}
