{% extends "base.html.twig" %}

{% block title %}Games — Minoo{% endblock %}

{% block content %}
<div class="games-hub">
    <header class="games-hub__header">
        <div class="games-hub__header-content">
            <h1 class="games-hub__title">Games</h1>
            <p class="games-hub__subtitle">Learn Anishinaabemowin through play. Every game draws from our living dictionary.</p>
        </div>
    </header>

    <section class="games-hub__featured">
        <h2 class="visually-hidden">Available Games</h2>
        <a href="/games/shkoda" class="game-card game-card--featured">
            <div class="game-card__icon">
                <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
                    <ellipse class="game-card__glow" cx="40" cy="68" rx="24" ry="8" />
                    <path class="game-card__flame game-card__flame--outer" d="M40 10 C26 32, 18 54, 26 65 Q33 72, 40 68 Q47 72, 54 65 C62 54, 54 32, 40 10Z" />
                    <path class="game-card__flame game-card__flame--mid" d="M40 22 C30 38, 25 52, 30 62 Q35 67, 40 64 Q45 67, 50 62 C55 52, 50 38, 40 22Z" />
                    <path class="game-card__flame game-card__flame--inner" d="M40 34 C34 44, 31 54, 34 60 Q37 64, 40 62 Q43 64, 46 60 C49 54, 46 44, 40 34Z" />
                    <rect class="game-card__log" x="20" y="66" width="40" height="5" rx="2.5" />
                    <rect class="game-card__log game-card__log--cross" x="24" y="64" width="32" height="4" rx="2" transform="rotate(-6, 40, 66)" />
                </svg>
            </div>
            <div class="game-card__content">
                <span class="game-card__badge">Word Game</span>
                <h3 class="game-card__title">Shkoda</h3>
                <p class="game-card__description">Guess Ojibwe words letter by letter while keeping the campfire burning. Daily challenges, practice mode, and streaks.</p>
                <span class="game-card__cta">Play now</span>
            </div>
        </a>
    </section>

    <section class="games-hub__coming">
        <h2 class="games-hub__section-title">More games coming</h2>
        <div class="games-hub__coming-grid">
            <div class="game-card game-card--placeholder">
                <div class="game-card__placeholder-icon">
                    <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <span class="game-card__placeholder-label">Word Match</span>
            </div>
            <div class="game-card game-card--placeholder">
                <div class="game-card__placeholder-icon">
                    <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <span class="game-card__placeholder-label">Listening Quiz</span>
            </div>
            <div class="game-card game-card--placeholder">
                <div class="game-card__placeholder-icon">
                    <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <span class="game-card__placeholder-label">Sentence Builder</span>
            </div>
        </div>
    </section>
</div>
{% endblock %}
