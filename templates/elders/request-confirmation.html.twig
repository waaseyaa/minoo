{% extends "base.html.twig" %}

{% block title %}
  {%- if entity -%}
    Request Received — Minoo
  {%- else -%}
    Request Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if entity %}
    <div class="flow-lg">
      <div>
        <span class="card__badge card__badge--elder">Elder Support</span>
        <h1>Your Request Has Been Received</h1>
        <p class="card__meta">Reference: {{ entity.uuid() }}</p>
        <p class="text-secondary">Thank you, {{ entity.get('name') }}. A volunteer will reach out to you at {{ entity.get('phone') }}.</p>
      </div>

      <div class="card card--detail">
        <dl class="detail__fields">
          <div class="detail__field">
            <dt>Type of Help</dt>
            <dd>{{ entity.get('type')|capitalize }}</dd>
          </div>
          {% if entity.get('community') %}
            <div class="detail__field">
              <dt>Community</dt>
              <dd>{{ entity.get('community') }}</dd>
            </div>
          {% endif %}
          {% if entity.get('is_representative') %}
            <div class="detail__field">
              <dt>Requested for</dt>
              <dd>{{ entity.get('elder_name') }}</dd>
            </div>
          {% endif %}
          {% if entity.get('notes') %}
            <div class="detail__field">
              <dt>Notes</dt>
              <dd>{{ entity.get('notes') }}</dd>
            </div>
          {% endif %}
        </dl>
      </div>

      <div class="flow">
        <h2>What Happens Next</h2>
        <ol class="how-it-works__list">
          <li>A coordinator will review your request</li>
          <li>A volunteer will be matched based on your community and needs</li>
          <li>The volunteer will contact you at the phone number you provided</li>
          <li>After the visit, the coordinator will follow up</li>
        </ol>
      </div>

      <p><a href="/elders/request">Submit another request</a></p>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>Request Not Found</h1>
      <p>That request could not be found.</p>
      <p><a href="/elders/request">Submit a new request</a></p>
    </div>
  {% endif %}
{% endblock %}
