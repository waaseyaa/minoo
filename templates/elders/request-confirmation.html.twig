{% extends "base.html.twig" %}

{% block title %}
  {%- if entity -%}
    {{ trans('request_confirm.title') }} — Minoo
  {%- else -%}
    {{ trans('request_confirm.not_found_title') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if entity %}
    <div class="elders-confirmation">

      <header class="elders-confirmation__hero">
        <p class="elders-eyebrow">{{ trans('request_confirm.badge') }}</p>
        <h1 class="elders-confirmation__title">{{ trans('request_confirm.title') }}</h1>
        <p class="elders-confirmation__lede text-secondary" data-testid="confirmation-message">{{ trans('request_confirm.message', {name: entity.get('name'), phone: entity.get('phone')}) }}</p>
        <p class="elders-confirmation__reference card__meta">{{ trans('request_confirm.reference') }} <span>{{ entity.uuid() }}</span></p>
        <p class="elders-confirmation__cancel">{{ trans('request_confirm.cancel_note') }}</p>
      </header>

      <dl class="elders-summary card card--detail">
        <div class="elders-summary__row detail__field">
          <dt class="elders-summary__term">{{ trans('request_confirm.type_of_help') }}</dt>
          <dd class="elders-summary__value" data-testid="confirmation-type">{{ entity.get('type')|capitalize }}</dd>
        </div>
        {% if entity.get('community') %}
          <div class="elders-summary__row detail__field">
            <dt class="elders-summary__term">{{ trans('request_confirm.community') }}</dt>
            <dd class="elders-summary__value" data-testid="confirmation-community">{{ entity.get('community') }}</dd>
          </div>
        {% endif %}
        {% if entity.get('is_representative') %}
          <div class="elders-summary__row detail__field">
            <dt class="elders-summary__term">{{ trans('request_confirm.requested_for') }}</dt>
            <dd class="elders-summary__value">{{ entity.get('elder_name') }}</dd>
          </div>
        {% endif %}
        {% if entity.get('notes') %}
          <div class="elders-summary__row detail__field">
            <dt class="elders-summary__term">{{ trans('request_confirm.notes') }}</dt>
            <dd class="elders-summary__value">{{ entity.get('notes') }}</dd>
          </div>
        {% endif %}
      </dl>

      <section class="elders-timeline" aria-labelledby="what-next-heading">
        <h2 class="elders-timeline__heading" id="what-next-heading" data-testid="what-next-heading">{{ trans('request_confirm.what_next') }}</h2>
        <ol class="elders-timeline__list">
          <li class="elders-timeline__item"><p>{{ trans('request_confirm.next_step1') }}</p></li>
          <li class="elders-timeline__item"><p>{{ trans('request_confirm.next_step2') }}</p></li>
          <li class="elders-timeline__item"><p>{{ trans('request_confirm.next_step3') }}</p></li>
          <li class="elders-timeline__item"><p>{{ trans('request_confirm.next_step4') }}</p></li>
        </ol>
      </section>

      <div class="elders-actions">
        <a class="elders-actions__link" href="{{ lang_url('/elders/request') }}">{{ trans('request_confirm.submit_another') }}</a>
        <a class="elders-actions__link" href="{{ lang_url('/elders') }}">Back to Elder Support</a>
      </div>

    </div>
  {% else %}
    <div class="elders-empty">
      <h1 class="elders-confirmation__title">{{ trans('request_confirm.not_found_title') }}</h1>
      <p class="text-secondary">{{ trans('request_confirm.not_found_text') }}</p>
      <p><a class="elders-actions__link" href="{{ lang_url('/elders/request') }}">{{ trans('request_confirm.submit_new') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
