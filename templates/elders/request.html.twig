{% extends "base.html.twig" %}

{% block title %}Request Elder Support — Minoo{% endblock %}

{% block content %}
  <div class="flow-lg">
    <div>
      <h1>Request Elder Support</h1>
      <p class="text-secondary">You don't have to manage everything alone. Tell us what you need and a coordinator will find a volunteer near you. A family member or friend can also fill this out on your behalf.</p>
    </div>

    <form class="form form--centered" method="POST" action="/elders/request">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">
      <div class="form__field">
        <label class="form__label" for="name">Your Name <span aria-hidden="true">*</span></label>
        {% if errors.name is defined %}
          <p class="form__error" role="alert">{{ errors.name }}</p>
        {% endif %}
        <input class="form__input{% if errors.name is defined %} form__input--error{% endif %}"
               type="text" id="name" name="name"
               value="{{ values.name ?? '' }}"
               required autocomplete="name">
      </div>

      <div class="form__field">
        <label class="form__checkbox-label">
          <input type="checkbox" id="is_representative" name="is_representative" value="1"
                 {% if values.isRepresentative is defined and values.isRepresentative %}checked{% endif %}>
          I'm requesting on behalf of an Elder
        </label>
      </div>

      <div id="representative-fields" class="form__fieldset" {% if not (values.isRepresentative is defined and values.isRepresentative) %}hidden{% endif %}>
        <div class="form__field">
          <label class="form__label" for="elder_name">Elder's Name <span aria-hidden="true">*</span></label>
          {% if errors.elder_name is defined %}
            <p class="form__error" role="alert">{{ errors.elder_name }}</p>
          {% endif %}
          <input class="form__input{% if errors.elder_name is defined %} form__input--error{% endif %}"
                 type="text" id="elder_name" name="elder_name"
                 value="{{ values.elderName ?? '' }}">
        </div>
        <div class="form__field">
          <label class="form__checkbox-label">
            <input type="checkbox" id="consent" name="consent" value="1"
                   {% if values.consent is defined and values.consent %}checked{% endif %}>
            I confirm the Elder has given permission for this request
          </label>
          {% if errors.consent is defined %}
            <p class="form__error" role="alert">{{ errors.consent }}</p>
          {% endif %}
        </div>
      </div>

      <div class="form__field">
        <label class="form__label" for="phone">Phone Number <span aria-hidden="true">*</span></label>
        {% if errors.phone is defined %}
          <p class="form__error" role="alert">{{ errors.phone }}</p>
        {% endif %}
        <input class="form__input{% if errors.phone is defined %} form__input--error{% endif %}"
               type="tel" id="phone" name="phone"
               value="{{ values.phone ?? '' }}"
               required autocomplete="tel">
      </div>

      <div class="form__field">
        <label class="form__label" for="community">Community <span class="form__label-optional">(optional)</span></label>
        <input class="form__input" type="text" id="community" name="community"
               value="{{ values.community ?? (location is defined and location.hasLocation() ? location.communityName : '') }}"
               autocomplete="address-level2">
      </div>

      <div class="form__field">
        <label class="form__label" for="type">Type of Help Needed <span aria-hidden="true">*</span></label>
        {% if errors.type is defined %}
          <p class="form__error" role="alert">{{ errors.type }}</p>
        {% endif %}
        <select class="form__select{% if errors.type is defined %} form__select--error{% endif %}"
                id="type" name="type" required>
          <option value="">— Select —</option>
          <option value="ride"{% if (values.type ?? '') == 'ride' %} selected{% endif %}>Ride</option>
          <option value="groceries"{% if (values.type ?? '') == 'groceries' %} selected{% endif %}>Groceries</option>
          <option value="chores"{% if (values.type ?? '') == 'chores' %} selected{% endif %}>Chores</option>
          <option value="visit"{% if (values.type ?? '') == 'visit' %} selected{% endif %}>Visit / Companionship</option>
        </select>
      </div>

      <div class="form__field">
        <label class="form__label" for="notes">Additional Notes <span class="form__label-optional">(optional)</span></label>
        <textarea class="form__textarea" id="notes" name="notes" rows="4">{{ values.notes ?? '' }}</textarea>
      </div>

      <div class="privacy-note">
        <p>Your information is only shared with the coordinator and the volunteer matched to your request. We never share it with anyone else.
        <a href="/legal/privacy">Read our full privacy policy</a>.</p>
      </div>

      <div class="form__actions">
        <button type="submit" class="btn btn--primary">Submit Request</button>
      </div>
    </form>

    <p class="text-secondary">Are you able to help? <a href="/elders/volunteer">Sign up as a volunteer</a>.</p>
    <p class="text-secondary">Your safety matters. <a href="/safety">Read our safety guidelines</a>.</p>
  </div>
{% endblock %}

{% block scripts %}
<script>
  document.getElementById('is_representative')?.addEventListener('change', function() {
    document.getElementById('representative-fields').hidden = !this.checked;
  });
</script>
{% endblock %}
