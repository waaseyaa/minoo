{% extends "base.html.twig" %}

{% block title %}{{ trans('request.title') }} — Minoo{% endblock %}

{% block content %}
<div class="elders-form-page">

  <header class="elders-form-page__header">
    <p class="elders-eyebrow">Elder Support</p>
    <h1 class="elders-form-page__title">{{ trans('request.title') }}</h1>
    <p class="elders-form-page__lede text-secondary">{{ trans('request.subtitle') }}</p>
  </header>

  <div class="elders-form-card">
    <form class="form form--centered" method="POST" action="{{ lang_url('/elders/request') }}">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}">

      <div class="form__field">
        <label class="form__label" for="name">{{ trans('request.your_name') }} <span aria-hidden="true">*</span></label>
        {% if errors.name is defined %}
          <p class="form__error" role="alert">{{ errors.name }}</p>
        {% endif %}
        <input class="form__input{% if errors.name is defined %} form__input--error{% endif %}"
               type="text" id="name" name="name"
               value="{{ values.name ?? '' }}"
               required autocomplete="name">
      </div>

      <div class="form__field">
        <label class="form__checkbox-label">
          <input type="checkbox" id="is_representative" name="is_representative" value="1"
                 {% if values.isRepresentative is defined and values.isRepresentative %}checked{% endif %}>
          {{ trans('request.on_behalf') }}
        </label>
      </div>

      <div id="representative-fields" class="form__fieldset" {% if not (values.isRepresentative is defined and values.isRepresentative) %}hidden{% endif %}>
        <div class="form__field">
          <label class="form__label" for="elder_name">{{ trans('request.elder_name') }} <span aria-hidden="true">*</span></label>
          {% if errors.elder_name is defined %}
            <p class="form__error" role="alert">{{ errors.elder_name }}</p>
          {% endif %}
          <input class="form__input{% if errors.elder_name is defined %} form__input--error{% endif %}"
                 type="text" id="elder_name" name="elder_name"
                 value="{{ values.elderName ?? '' }}">
        </div>
        <div class="form__field">
          <label class="form__checkbox-label">
            <input type="checkbox" id="consent" name="consent" value="1"
                   {% if values.consent is defined and values.consent %}checked{% endif %}>
            {{ trans('request.consent') }}
          </label>
          {% if errors.consent is defined %}
            <p class="form__error" role="alert">{{ errors.consent }}</p>
          {% endif %}
        </div>
      </div>

      <div class="form__field">
        <label class="form__label" for="phone">{{ trans('request.phone') }} <span aria-hidden="true">*</span></label>
        {% if errors.phone is defined %}
          <p class="form__error" role="alert">{{ errors.phone }}</p>
        {% endif %}
        <input class="form__input{% if errors.phone is defined %} form__input--error{% endif %}"
               type="tel" id="phone" name="phone"
               value="{{ values.phone ?? '' }}"
               required autocomplete="tel">
      </div>

      <div class="form__field">
        <label class="form__label" for="community">{{ trans('request.community') }} <span class="form__label-optional">{{ trans('request.optional') }}</span></label>
        <input class="form__input" type="text" id="community" name="community"
               value="{{ values.community ?? (location is defined and location.hasLocation() ? location.communityName : '') }}"
               autocomplete="address-level2">
      </div>

      <div class="form__field">
        <label class="form__label" for="type">{{ trans('request.type_of_help') }} <span aria-hidden="true">*</span></label>
        {% if errors.type is defined %}
          <p class="form__error" role="alert">{{ errors.type }}</p>
        {% endif %}
        <select class="form__select{% if errors.type is defined %} form__select--error{% endif %}"
                id="type" name="type" required>
          <option value="">{{ trans('request.select_default') }}</option>
          <option value="ride"{% if (values.type ?? '') == 'ride' %} selected{% endif %}>{{ trans('request.type_ride') }}</option>
          <option value="groceries"{% if (values.type ?? '') == 'groceries' %} selected{% endif %}>{{ trans('request.type_groceries') }}</option>
          <option value="chores"{% if (values.type ?? '') == 'chores' %} selected{% endif %}>{{ trans('request.type_chores') }}</option>
          <option value="visit"{% if (values.type ?? '') == 'visit' %} selected{% endif %}>{{ trans('request.type_visit') }}</option>
        </select>
      </div>

      <div class="form__field">
        <label class="form__label" for="notes">{{ trans('request.additional_notes') }} <span class="form__label-optional">{{ trans('request.optional') }}</span></label>
        <textarea class="form__textarea" id="notes" name="notes" rows="4">{{ values.notes ?? '' }}</textarea>
      </div>

      <div class="form__actions">
        <button type="submit" class="btn btn--primary">{{ trans('request.submit_button') }}</button>
      </div>

      <div class="privacy-note">
        <p>{{ trans('request.privacy_note') }} <a href="{{ lang_url('/legal/privacy') }}">{{ trans('request.privacy_link') }}</a>.</p>
      </div>
    </form>
  </div>

  <footer class="elders-form-page__footer">
    <p>{{ trans('request.can_help') }} <a href="{{ lang_url('/elders/volunteer') }}">{{ trans('request.volunteer_link') }}</a>.</p>
    <p>{{ trans('request.safety_matters') }} <a href="{{ lang_url('/safety') }}">{{ trans('request.safety_link') }}</a>.</p>
  </footer>

</div>
{% endblock %}

{% block scripts %}
<script>
  document.getElementById('is_representative')?.addEventListener('change', function() {
    document.getElementById('representative-fields').hidden = !this.checked;
  });
</script>
{% endblock %}
