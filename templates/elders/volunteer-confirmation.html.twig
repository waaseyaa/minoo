{% extends "base.html.twig" %}

{% block title %}
  {%- if entity -%}
    {{ trans('volunteer_confirm.title') }} — Minoo
  {%- else -%}
    {{ trans('volunteer_confirm.not_found_title') }} — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if entity %}
    <div class="flow-lg">
      <div>
        <span class="card__badge card__badge--elder">{{ trans('volunteer_confirm.badge') }}</span>
        <h1 data-testid="confirmation-heading">{{ trans('volunteer_confirm.title') }}</h1>
        <p class="text-secondary" data-testid="confirmation-message">{{ trans('volunteer_confirm.message', {name: entity.get('name'), phone: entity.get('phone')}) }}</p>
      </div>

      <div class="card card--detail">
        <dl class="detail__fields">
          {% if entity.get('availability') %}
            <div class="detail__field">
              <dt>{{ trans('volunteer_confirm.availability') }}</dt>
              <dd data-testid="confirmation-availability">{{ entity.get('availability') }}</dd>
            </div>
          {% endif %}
          {% if entity.get('skills') is iterable and entity.get('skills')|length > 0 %}
            <div class="detail__field">
              <dt>{{ trans('volunteer_confirm.skills') }}</dt>
              <dd>
                <div class="card__tags">
                  {% for skill in entity.get('skills') %}
                    <span class="card__tag">{{ skill }}</span>
                  {% endfor %}
                </div>
              </dd>
            </div>
          {% endif %}
          {% if entity.get('notes') %}
            <div class="detail__field">
              <dt>{{ trans('volunteer_confirm.notes') }}</dt>
              <dd>{{ entity.get('notes') }}</dd>
            </div>
          {% endif %}
        </dl>
      </div>

      <div class="flow">
        <h2 data-testid="what-next-heading">{{ trans('volunteer_confirm.what_next') }}</h2>
        <ol class="how-it-works__list">
          <li>{{ trans('volunteer_confirm.next_step1') }}</li>
          <li>{{ trans('volunteer_confirm.next_step2') }}</li>
          <li>{{ trans('volunteer_confirm.next_step3') }}</li>
        </ol>
      </div>

      <p><a href="{{ lang_url('/elders/volunteer') }}">{{ trans('volunteer_confirm.signup_another') }}</a></p>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>{{ trans('volunteer_confirm.not_found_title') }}</h1>
      <p>{{ trans('volunteer_confirm.not_found_text') }}</p>
      <p><a href="{{ lang_url('/elders/volunteer') }}">{{ trans('volunteer_confirm.signup_link') }}</a></p>
    </div>
  {% endif %}
{% endblock %}
