{% extends "base.html.twig" %}

{% block title %}
  {%- if entity -%}
    Thank You for Volunteering — Minoo
  {%- else -%}
    Volunteer Not Found — Minoo
  {%- endif -%}
{% endblock %}

{% block content %}
  {% if entity %}
    <div class="flow-lg">
      <div>
        <span class="card__badge card__badge--elder">Volunteer</span>
        <h1>Thank You for Volunteering</h1>
        <p class="text-secondary">Thank you, {{ entity.get('name') }}. You're now part of something that matters to this community. A coordinator will reach out to you at {{ entity.get('phone') }} when an Elder in your area needs support.</p>
      </div>

      <div class="card card--detail">
        <dl class="detail__fields">
          {% if entity.get('availability') %}
            <div class="detail__field">
              <dt>Availability</dt>
              <dd>{{ entity.get('availability') }}</dd>
            </div>
          {% endif %}
          {% if entity.get('skills') is iterable and entity.get('skills')|length > 0 %}
            <div class="detail__field">
              <dt>Skills</dt>
              <dd>
                <div class="card__tags">
                  {% for skill in entity.get('skills') %}
                    <span class="card__tag">{{ skill }}</span>
                  {% endfor %}
                </div>
              </dd>
            </div>
          {% endif %}
          {% if entity.get('notes') %}
            <div class="detail__field">
              <dt>Notes</dt>
              <dd>{{ entity.get('notes') }}</dd>
            </div>
          {% endif %}
        </dl>
      </div>

      <div class="flow">
        <h2>What Happens Next</h2>
        <ol class="how-it-works__list">
          <li>A community coordinator will review your signup</li>
          <li>When an Elder nearby needs help that matches your skills and availability, the coordinator will call you</li>
          <li>You'll connect with the Elder and arrange the details together</li>
        </ol>
      </div>

      <p><a href="/elders/volunteer">Sign up another volunteer</a></p>
    </div>
  {% else %}
    <div class="flow-lg">
      <h1>Volunteer Not Found</h1>
      <p>That volunteer record could not be found.</p>
      <p><a href="/elders/volunteer">Sign up as a volunteer</a></p>
    </div>
  {% endif %}
{% endblock %}
