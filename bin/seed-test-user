#!/usr/bin/env php
<?php

/**
 * Seed test users for Playwright auth tests.
 *
 * Usage: bin/seed-test-user
 *
 * Creates:
 *   test@minoo.test / TestPass123! with volunteer role.
 *   member@minoo.test / MemberPass123! with no roles.
 * Skips users that already exist.
 */

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

$kernel = new Waaseyaa\Foundation\Kernel\ConsoleKernel(dirname(__DIR__));

(new ReflectionMethod($kernel, 'boot'))->invoke($kernel);

$entityTypeManager = $kernel->getEntityTypeManager();
$storage = $entityTypeManager->getStorage('user');

// Clear rate limits so Playwright login attempts don't get throttled.
$dbPath = getenv('WAASEYAA_DB') ?: dirname(__DIR__) . '/storage/waaseyaa.sqlite';
$pdo = new PDO('sqlite:' . $dbPath);
$pdo->exec('CREATE TABLE IF NOT EXISTS rate_limits (id INTEGER PRIMARY KEY AUTOINCREMENT, ip TEXT NOT NULL, path TEXT NOT NULL, created_at INTEGER NOT NULL)');
$pdo->exec('DELETE FROM rate_limits');
fprintf(STDOUT, "Rate limits cleared.\n");

// Seed volunteer test user.
$existing = $storage->getQuery()->condition('mail', 'test@minoo.test')->execute();

if ($existing !== []) {
    fprintf(STDOUT, "Test user already exists.\n");
} else {
    $user = $storage->create([
        'name' => 'Test User',
        'mail' => 'test@minoo.test',
        'status' => true,
        'created' => time(),
        'roles' => ['volunteer'],
        'permissions' => ['view own assignments', 'update assignment status'],
    ]);
    $user->setRawPassword('TestPass123!');
    $storage->save($user);
    fprintf(STDOUT, "Test user created: test@minoo.test / TestPass123!\n");
}

// Seed non-volunteer test user.
$existingMember = $storage->getQuery()->condition('mail', 'member@minoo.test')->execute();

if ($existingMember !== []) {
    fprintf(STDOUT, "Member user already exists.\n");
} else {
    $member = $storage->create([
        'name' => 'Member User',
        'mail' => 'member@minoo.test',
        'status' => true,
        'created' => time(),
        'roles' => [],
        'permissions' => [],
    ]);
    $member->setRawPassword('MemberPass123!');
    $storage->save($member);
    fprintf(STDOUT, "Member user created: member@minoo.test / MemberPass123!\n");
}
