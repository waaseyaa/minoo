#!/usr/bin/env php
<?php

/**
 * Delete non–First Nations community records that lack an inac_id.
 *
 * These are manually-entered records from early development (Sudbury, Sault
 * Ste. Marie) that are not part of the CIRNAC dataset and will be replaced
 * by a future municipal indexing milestone.
 *
 * Tracks: waaseyaa/minoo#173
 *
 * Usage:
 *   bin/delete-non-fn              # dry-run (default, no writes)
 *   bin/delete-non-fn --apply      # perform deletions
 *
 * Safety: Only deletes records where inac_id IS NULL AND community_type IS NULL.
 */

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

// --- Parse arguments ---------------------------------------------------------

$apply = in_array('--apply', $argv, true);
$dryRun = !$apply;

// --- Boot Waaseyaa -----------------------------------------------------------

$kernel = new Waaseyaa\Foundation\Kernel\ConsoleKernel(dirname(__DIR__));
(new ReflectionMethod($kernel, 'boot'))->invoke($kernel);

$storage = $kernel->getEntityTypeManager()->getStorage('community');

// --- Find orphans: no inac_id AND no community_type -------------------------

$allIds = $storage->getQuery()->execute();
$targets = [];

foreach ($allIds as $id) {
    $entity = $storage->load($id);
    if ($entity === null) {
        continue;
    }

    $inacId = (string) $entity->get('inac_id');
    $type = (string) $entity->get('community_type');

    if ($inacId === '' && $type === '') {
        $targets[] = $entity;
    }
}

if ($targets === []) {
    fprintf(STDOUT, "No non-FN orphans found. Nothing to delete.\n");
    exit(0);
}

fprintf(STDOUT, "Found %d non-FN orphan(s):\n", count($targets));

foreach ($targets as $entity) {
    $name = (string) $entity->get('name');
    $website = (string) $entity->get('website');
    fprintf(STDOUT, "  cid=%d \"%s\"%s\n", $entity->id(), $name, $website !== '' ? " (website: {$website})" : '');
}

if ($dryRun) {
    fprintf(STDOUT, "\n[DRY RUN] No changes will be written. Use --apply to execute.\n");
    exit(0);
}

// --- Back up and delete ------------------------------------------------------

$dbPath = dirname(__DIR__) . '/waaseyaa.sqlite';
$backupPath = $dbPath . '.pre-delete-non-fn.bak';

if (!copy($dbPath, $backupPath)) {
    fprintf(STDERR, "ERROR: Failed to back up database to %s\n", $backupPath);
    exit(1);
}

fprintf(STDOUT, "\n[BACKUP] %s\n", $backupPath);

$storage->delete($targets);

fprintf(STDOUT, "Deleted %d record(s).\n", count($targets));
