#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Audit entity data quality — reports field coverage per entity type.
 *
 * Usage: bin/audit-entity-quality
 * Exit code: always 0 (audit only, not a gate)
 */

require __DIR__ . '/../vendor/autoload.php';

use Waaseyaa\Foundation\Kernel\AbstractKernel;
use Waaseyaa\Foundation\Kernel\HttpKernel;

$kernel = new HttpKernel(dirname(__DIR__));
$boot = new ReflectionMethod(AbstractKernel::class, 'boot');
$boot->invoke($kernel);

$entityTypeManager = $kernel->getEntityTypeManager();

/**
 * Entity types to audit and their field mappings.
 * Keys: label_field, description_field, slug_field, community_field, type_field
 */
$auditConfig = [
    'event' => [
        'label_field' => 'title',
        'description_field' => 'description',
        'slug_field' => 'slug',
        'community_field' => 'community_id',
        'type_field' => 'type',
    ],
    'teaching' => [
        'label_field' => 'title',
        'description_field' => 'content',
        'slug_field' => 'slug',
        'community_field' => 'community_id',
        'type_field' => 'type',
    ],
    'group' => [
        'label_field' => 'name',
        'description_field' => 'description',
        'slug_field' => 'slug',
        'community_field' => 'community_id',
        'type_field' => 'type',
    ],
    'resource_person' => [
        'label_field' => 'name',
        'description_field' => 'bio',
        'slug_field' => 'slug',
        'community_field' => 'community',
        'type_field' => null,
    ],
    'community' => [
        'label_field' => 'name',
        'description_field' => null,
        'slug_field' => 'slug',
        'community_field' => null,
        'type_field' => null,
    ],
];

fprintf(STDOUT, "\n");
fprintf(STDOUT, "  Minoo Entity Quality Audit\n");
fprintf(STDOUT, "  %s\n", date('Y-m-d H:i:s'));
fprintf(STDOUT, "\n");

$divider = str_repeat('-', 94);
fprintf(STDOUT, "  %-20s %7s %8s %8s %8s %10s %8s %10s\n",
    'Entity Type', 'Total', 'Label', 'Desc', 'Slug', 'Community', 'Type', 'Published');
fprintf(STDOUT, "  %s\n", $divider);

$grandTotal = 0;

foreach ($auditConfig as $entityType => $config) {
    try {
        $storage = $entityTypeManager->getStorage($entityType);
    } catch (\Throwable $e) {
        fprintf(STDOUT, "  %-20s  (storage unavailable: %s)\n", $entityType, $e->getMessage());
        continue;
    }

    $ids = $storage->getQuery()->execute();
    $total = count($ids);
    $grandTotal += $total;

    if ($total === 0) {
        fprintf(STDOUT, "  %-20s %7d %8s %8s %8s %10s %8s %10s\n",
            $entityType, 0, '--', '--', '--', '--', '--', '--');
        continue;
    }

    $entities = $storage->loadMultiple($ids);

    $counts = [
        'label' => 0,
        'description' => 0,
        'slug' => 0,
        'community' => 0,
        'type' => 0,
        'published' => 0,
    ];

    foreach ($entities as $entity) {
        // Label (title or name)
        if ($config['label_field'] !== null) {
            $val = $entity->get($config['label_field']);
            if ($val !== null && $val !== '') {
                $counts['label']++;
            }
        }

        // Description (description, content, or bio)
        if ($config['description_field'] !== null) {
            $val = $entity->get($config['description_field']);
            if ($val !== null && $val !== '') {
                $counts['description']++;
            }
        }

        // Slug
        if ($config['slug_field'] !== null) {
            $val = $entity->get($config['slug_field']);
            if ($val !== null && $val !== '') {
                $counts['slug']++;
            }
        }

        // Community reference
        if ($config['community_field'] !== null) {
            $val = $entity->get($config['community_field']);
            if ($val !== null && $val !== '' && $val !== 0 && $val !== '0') {
                $counts['community']++;
            }
        }

        // Type / bundle
        if ($config['type_field'] !== null) {
            $val = $entity->get($config['type_field']);
            if ($val !== null && $val !== '') {
                $counts['type']++;
            }
        }

        // Published status
        $status = $entity->get('status');
        if ($status === 1 || $status === '1' || $status === true) {
            $counts['published']++;
        }
    }

    $pct = fn(int $count, ?string $field): string =>
        $field === null ? '--' : sprintf('%5.1f%%', ($count / $total) * 100);

    fprintf(STDOUT, "  %-20s %7d %8s %8s %8s %10s %8s %10s\n",
        $entityType,
        $total,
        $pct($counts['label'], $config['label_field']),
        $pct($counts['description'], $config['description_field']),
        $pct($counts['slug'], $config['slug_field']),
        $pct($counts['community'], $config['community_field']),
        $pct($counts['type'], $config['type_field']),
        $pct($counts['published'], 'status'),
    );
}

fprintf(STDOUT, "  %s\n", $divider);
fprintf(STDOUT, "  Total entities: %d\n", $grandTotal);
fprintf(STDOUT, "\n");

exit(0);
