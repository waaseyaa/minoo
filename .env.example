# Minoo environment configuration
# Copy to .env and fill in values

# Mercure real-time messaging hub
MERCURE_HUB_URL=http://localhost:3000/.well-known/mercure
MERCURE_PUBLISHER_JWT=!ChangeMe!ThisIsADevSecret
MERCURE_SUBSCRIBER_JWT_SECRET=!ChangeMe!ThisIsADevSecret

# SendGrid (email digests)
SENDGRID_API_KEY=
MAIL_FROM_ADDRESS=noreply@minoo.live
MAIL_FROM_NAME=Minoo

# NorthCloud API
NORTHCLOUD_BASE_URL=http://localhost:8050
