# Minoo environment configuration
#
# This file is committed to version control as a template.
# Copy to .env.local for personal overrides (never committed).
#
# Precedence: process env > .env.local > .env

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=Minoo
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# ── Database ───────────────────────────────────────────────────────────────────
WAASEYAA_DB=./storage/waaseyaa.sqlite

# ── Authentication ─────────────────────────────────────────────────────────────
# Auto-generated by post-create-setup — do not change unless rotating the secret.
WAASEYAA_JWT_SECRET=

# Dev-only: auto-authenticate as admin (never enable in production)
# WAASEYAA_DEV_FALLBACK_ACCOUNT=true

# Mercure real-time messaging hub
MERCURE_HUB_URL=http://localhost:3000/.well-known/mercure
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!

# SendGrid (email digests)
SENDGRID_API_KEY=
MAIL_FROM_ADDRESS=noreply@minoo.live
MAIL_FROM_NAME=Minoo

# NorthCloud API
NORTHCLOUD_BASE_URL=http://localhost:8050
