{
  "name": "minoo",
  "version": "1.0.0",
  "description": "Indigenous knowledge platform powered by [Waaseyaa CMS](https://github.com/waaseyaa/framework) and [NorthCloud](https://github.com/jonesrussell/north-cloud) ingestion.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "prepare": "husky",
    "test": "vendor/bin/phpunit",
    "test:unit": "vendor/bin/phpunit --testsuite MinooUnit",
    "test:integration": "vendor/bin/phpunit --testsuite MinooIntegration",
    "lint": "composer validate --strict --no-check-all && find src -name '*.php' -exec php -l {} \\;"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/waaseyaa/minoo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/waaseyaa/minoo/issues"
  },
  "homepage": "https://github.com/waaseyaa/minoo#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7"
  }
}
