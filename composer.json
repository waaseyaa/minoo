{
    "name": "waaseyaa/minoo",
    "description": "Indigenous knowledge platform powered by NorthCloud ingestion",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "geoip2/geoip2": "^3.0",
        "sendgrid/sendgrid": "^8.1",
        "waaseyaa/access": "^0.1@alpha",
        "waaseyaa/api": "^0.1@alpha",
        "waaseyaa/cache": "^0.1@alpha",
        "waaseyaa/cli": "^0.1@alpha",
        "waaseyaa/config": "^0.1@alpha",
        "waaseyaa/database-legacy": "^0.1@alpha",
        "waaseyaa/entity": "^0.1@alpha",
        "waaseyaa/entity-storage": "^0.1@alpha",
        "waaseyaa/field": "^0.1@alpha",
        "waaseyaa/foundation": "^0.1@alpha",
        "waaseyaa/i18n": "^0.1@alpha",
        "waaseyaa/mcp": "^0.1@alpha",
        "waaseyaa/media": "^0.1@alpha",
        "waaseyaa/menu": "^0.1@alpha",
        "waaseyaa/node": "^0.1@alpha",
        "waaseyaa/path": "^0.1@alpha",
        "waaseyaa/plugin": "^0.1@alpha",
        "waaseyaa/queue": "^0.1@alpha",
        "waaseyaa/routing": "^0.1@alpha",
        "waaseyaa/search": "^0.1@alpha",
        "waaseyaa/ssr": "^0.1@alpha",
        "waaseyaa/state": "^0.1@alpha",
        "waaseyaa/taxonomy": "^0.1@alpha",
        "waaseyaa/typed-data": "^0.1@alpha",
        "waaseyaa/user": "^0.1@alpha",
        "waaseyaa/validation": "^0.1@alpha",
        "waaseyaa/workflows": "^0.1@alpha"
    },
    "require-dev": {
        "waaseyaa/testing": "^0.1@alpha",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Minoo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Minoo\\Tests\\": "tests/Minoo/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Minoo\\Provider\\I18nServiceProvider",
                "Minoo\\Provider\\EventServiceProvider",
                "Minoo\\Provider\\GroupServiceProvider",
                "Minoo\\Provider\\CulturalGroupServiceProvider",
                "Minoo\\Provider\\TeachingServiceProvider",
                "Minoo\\Provider\\CulturalCollectionServiceProvider",
                "Minoo\\Provider\\LanguageServiceProvider",
                "Minoo\\Provider\\IngestServiceProvider",
                "Minoo\\Provider\\SearchServiceProvider",
                "Minoo\\Provider\\PeopleServiceProvider",
                "Minoo\\Provider\\ElderSupportServiceProvider",
                "Minoo\\Provider\\CommunityServiceProvider",
                "Minoo\\Provider\\AuthServiceProvider",
                "Minoo\\Provider\\DashboardServiceProvider",
                "Minoo\\Provider\\MailServiceProvider",
                "Minoo\\Provider\\AccountServiceProvider",
                "Minoo\\Provider\\FlashServiceProvider",
                "Minoo\\Provider\\ChatServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-create-project-cmd": [
            "chmod +x bin/waaseyaa"
        ]
    },
    "minimum-stability": "alpha",
    "prefer-stable": true
}
