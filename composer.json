{
    "name": "waaseyaa/minoo",
    "description": "Indigenous knowledge platform powered by NorthCloud ingestion",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "geoip2/geoip2": "^3.0",
        "sendgrid/sendgrid": "^8.1",
        "waaseyaa/access": "^0.1.0-alpha.37",
        "waaseyaa/admin-surface": "^0.1.0-alpha.37",
        "waaseyaa/api": "^0.1.0-alpha.63",
        "waaseyaa/cache": "^0.1.0-alpha.37",
        "waaseyaa/cli": "^0.1.0-alpha.37",
        "waaseyaa/config": "^0.1.0-alpha.37",
        "waaseyaa/database-legacy": "^0.1.0-alpha.37",
        "waaseyaa/engagement": "^0.1.0-alpha.67",
        "waaseyaa/entity": "^0.1.0-alpha.37",
        "waaseyaa/entity-storage": "^0.1.0-alpha.37",
        "waaseyaa/field": "^0.1.0-alpha.32",
        "waaseyaa/foundation": "^0.1.0-alpha.63",
        "waaseyaa/geo": "^0.1.0-alpha.63",
        "waaseyaa/graphql": "^0.1.0-alpha.37",
        "waaseyaa/i18n": "^0.1.0-alpha.37",
        "waaseyaa/mail": "^0.1.0-alpha.64",
        "waaseyaa/mcp": "^0.1.0-alpha.37",
        "waaseyaa/media": "^0.1.0-alpha.63",
        "waaseyaa/menu": "^0.1.0-alpha.37",
        "waaseyaa/mercure": "^0.1.0-alpha.63",
        "waaseyaa/messaging": "^0.1.0-alpha.65",
        "waaseyaa/node": "^0.1.0-alpha.37",
        "waaseyaa/path": "^0.1.0-alpha.37",
        "waaseyaa/plugin": "^0.1.0-alpha.37",
        "waaseyaa/queue": "^0.1.0-alpha.37",
        "waaseyaa/routing": "^0.1.0-alpha.37",
        "waaseyaa/search": "^0.1.0-alpha.37",
        "waaseyaa/ssr": "^0.1.0-alpha.63",
        "waaseyaa/state": "^0.1.0-alpha.37",
        "waaseyaa/taxonomy": "^0.1.0-alpha.37",
        "waaseyaa/typed-data": "^0.1.0-alpha.37",
        "waaseyaa/user": "^0.1.0-alpha.64",
        "waaseyaa/validation": "^0.1.0-alpha.37",
        "waaseyaa/workflows": "^0.1.0-alpha.37"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "waaseyaa/testing": "^0.1.0-alpha.37"
    },
    "autoload": {
        "psr-4": {
            "Minoo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Minoo\\Tests\\": "tests/Minoo/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Minoo\\Provider\\I18nServiceProvider",
                "Minoo\\Provider\\EventServiceProvider",
                "Minoo\\Provider\\GroupServiceProvider",
                "Minoo\\Provider\\CulturalGroupServiceProvider",
                "Minoo\\Provider\\TeachingServiceProvider",
                "Minoo\\Provider\\CulturalCollectionServiceProvider",
                "Minoo\\Provider\\LanguageServiceProvider",
                "Minoo\\Provider\\IngestServiceProvider",
                "Minoo\\Provider\\SearchServiceProvider",
                "Minoo\\Provider\\PeopleServiceProvider",
                "Minoo\\Provider\\ElderSupportServiceProvider",
                "Minoo\\Provider\\CommunityServiceProvider",
                "Minoo\\Provider\\AuthServiceProvider",
                "Minoo\\Provider\\DashboardServiceProvider",
                "Minoo\\Provider\\IngestionDashboardServiceProvider",
                "Minoo\\Provider\\MailServiceProvider",
                "Minoo\\Provider\\AccountServiceProvider",
                "Minoo\\Provider\\FlashServiceProvider",
                "Minoo\\Provider\\ChatServiceProvider",
                "Minoo\\Provider\\FeaturedItemServiceProvider",
                "Minoo\\Provider\\RoleManagementServiceProvider",
                "Minoo\\Provider\\AdminServiceProvider",
                "Minoo\\Provider\\DialectRegionServiceProvider",
                "Minoo\\Provider\\OralHistoryServiceProvider",
                "Minoo\\Provider\\ContributorServiceProvider",
                "Minoo\\Provider\\EngagementServiceProvider",
                "Minoo\\Provider\\MessagingServiceProvider",
                "Minoo\\Provider\\FeedServiceProvider",
                "Minoo\\Provider\\FeedScoringServiceProvider",
                "Minoo\\Provider\\GameServiceProvider",
                "Minoo\\Provider\\BlockServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "chmod +x bin/waaseyaa"
        ]
    },
    "minimum-stability": "alpha",
    "prefer-stable": true
}
