{
    "name": "waaseyaa/minoo",
    "description": "Indigenous knowledge platform powered by NorthCloud ingestion",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "geoip2/geoip2": "^3.0",
        "sendgrid/sendgrid": "^8.1",
        "symfony/dotenv": "^7.0",
        "symfony/process": "^8.0",
        "waaseyaa/access": "^0.1",
        "waaseyaa/admin-surface": "^0.1",
        "waaseyaa/api": "^0.1",
        "waaseyaa/auth": "^0.1",
        "waaseyaa/cache": "^0.1",
        "waaseyaa/cli": "^0.1",
        "waaseyaa/config": "^0.1",
        "waaseyaa/database-legacy": "^0.1",
        "waaseyaa/engagement": "^0.1",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/entity-storage": "^0.1",
        "waaseyaa/field": "^0.1",
        "waaseyaa/foundation": "^0.1",
        "waaseyaa/geo": "^0.1",
        "waaseyaa/graphql": "^0.1",
        "waaseyaa/i18n": "^0.1",
        "waaseyaa/mail": "^0.1",
        "waaseyaa/mcp": "^0.1",
        "waaseyaa/media": "^0.1",
        "waaseyaa/menu": "^0.1",
        "waaseyaa/mercure": "^0.1",
        "waaseyaa/messaging": "^0.1",
        "waaseyaa/node": "^0.1",
        "waaseyaa/path": "^0.1",
        "waaseyaa/plugin": "^0.1",
        "waaseyaa/queue": "^0.1",
        "waaseyaa/routing": "^0.1",
        "waaseyaa/search": "^0.1",
        "waaseyaa/ssr": "^0.1",
        "waaseyaa/state": "^0.1",
        "waaseyaa/taxonomy": "^0.1",
        "waaseyaa/typed-data": "^0.1",
        "waaseyaa/user": "^0.1",
        "waaseyaa/validation": "^0.1",
        "waaseyaa/workflows": "^0.1"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "waaseyaa/testing": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "Minoo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Minoo\\Tests\\": "tests/Minoo/"
        }
    },
    "extra": {
        "waaseyaa": {
            "admin_path": "../waaseyaa/packages/admin",
            "providers": [
                "Minoo\\Provider\\I18nServiceProvider",
                "Minoo\\Provider\\EventServiceProvider",
                "Minoo\\Provider\\GroupServiceProvider",
                "Minoo\\Provider\\CulturalGroupServiceProvider",
                "Minoo\\Provider\\TeachingServiceProvider",
                "Minoo\\Provider\\CulturalCollectionServiceProvider",
                "Minoo\\Provider\\LanguageServiceProvider",
                "Minoo\\Provider\\IngestServiceProvider",
                "Minoo\\Provider\\SearchServiceProvider",
                "Minoo\\Provider\\PeopleServiceProvider",
                "Minoo\\Provider\\ElderSupportServiceProvider",
                "Minoo\\Provider\\CommunityServiceProvider",
                "Minoo\\Provider\\AuthServiceProvider",
                "Minoo\\Provider\\DashboardServiceProvider",
                "Minoo\\Provider\\IngestionDashboardServiceProvider",
                "Minoo\\Provider\\MailServiceProvider",
                "Minoo\\Provider\\AccountServiceProvider",
                "Minoo\\Provider\\FlashServiceProvider",
                "Minoo\\Provider\\ChatServiceProvider",
                "Minoo\\Provider\\FeaturedItemServiceProvider",
                "Minoo\\Provider\\RoleManagementServiceProvider",
                "Minoo\\Provider\\AdminServiceProvider",
                "Minoo\\Provider\\DialectRegionServiceProvider",
                "Minoo\\Provider\\OralHistoryServiceProvider",
                "Minoo\\Provider\\ContributorServiceProvider",
                "Minoo\\Provider\\EngagementServiceProvider",
                "Minoo\\Provider\\MessagingServiceProvider",
                "Minoo\\Provider\\FeedServiceProvider",
                "Minoo\\Provider\\FeedScoringServiceProvider",
                "Minoo\\Provider\\GameServiceProvider",
                "Minoo\\Provider\\BlockServiceProvider",
                "Minoo\\Provider\\NewsletterServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "PHP_CLI_SERVER_WORKERS=4 bin/waaseyaa serve -p ${APP_PORT:-8081} & SERVE_PID=$!; trap 'kill $SERVE_PID 2>/dev/null || true' EXIT INT TERM; NUXT_BACKEND_URL=http://127.0.0.1:${APP_PORT:-8081} bin/waaseyaa admin:dev"
        ],
        "audit-site": "./bin/waaseyaa-audit-site",
        "dev:wsl": [
            "Composer\\Config::disableProcessTimeout",
            "PHP_CLI_SERVER_WORKERS=4 bin/waaseyaa serve & npm --prefix ../waaseyaa/packages/admin run dev -- --host && kill $!"
        ],
        "post-create-project-cmd": [
            "chmod +x bin/waaseyaa bin/waaseyaa-version bin/verify-deploy-rsync bin/waaseyaa-audit-site",
            "php bin/post-create-setup.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
