{
    "name": "waaseyaa/minoo",
    "description": "Indigenous knowledge platform powered by NorthCloud ingestion",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../waaseyaa/packages/entity"
        },
        {
            "type": "path",
            "url": "../waaseyaa/packages/field"
        },
        {
            "type": "path",
            "url": "../waaseyaa/packages/genealogy"
        },
        {
            "type": "path",
            "url": "../waaseyaa/packages/foundation"
        },
        {
            "type": "path",
            "url": "../waaseyaa/packages/routing"
        }
    ],
    "require": {
        "php": ">=8.4",
        "geoip2/geoip2": "^3.0",
        "sendgrid/sendgrid": "^8.1",
        "symfony/dotenv": "^8.0",
        "symfony/process": "^8.0",
        "waaseyaa/access": "^0.1",
        "waaseyaa/admin-surface": "^0.1.0-alpha.153",
        "waaseyaa/api": "^0.1",
        "waaseyaa/auth": "^0.1",
        "waaseyaa/bimaaji": "0.1.0-alpha.153",
        "waaseyaa/cache": "^0.1",
        "waaseyaa/cli": "^0.1",
        "waaseyaa/config": "^0.1",
        "waaseyaa/database-legacy": "^0.1",
        "waaseyaa/engagement": "^0.1",
        "waaseyaa/entity": "^0.1.0-alpha.153",
        "waaseyaa/entity-storage": "^0.1.0-alpha.153",
        "waaseyaa/field": "^0.1.0-alpha.153",
        "waaseyaa/foundation": "^0.1.0-alpha.153",
        "waaseyaa/genealogy": "@dev",
        "waaseyaa/geo": "^0.1",
        "waaseyaa/graphql": "^0.1",
        "waaseyaa/groups": "^0.1.0-alpha.153",
        "waaseyaa/i18n": "^0.1",
        "waaseyaa/mail": "^0.1",
        "waaseyaa/mcp": "^0.1",
        "waaseyaa/media": "^0.1",
        "waaseyaa/menu": "^0.1",
        "waaseyaa/mercure": "^0.1",
        "waaseyaa/messaging": "^0.1",
        "waaseyaa/node": "^0.1",
        "waaseyaa/northcloud": "^0.1.0-alpha.153",
        "waaseyaa/path": "^0.1",
        "waaseyaa/plugin": "^0.1",
        "waaseyaa/queue": "^0.1",
        "waaseyaa/routing": "^0.1",
        "waaseyaa/search": "^0.1",
        "waaseyaa/ssr": "^0.1",
        "waaseyaa/state": "^0.1",
        "waaseyaa/taxonomy": "^0.1",
        "waaseyaa/typed-data": "^0.1",
        "waaseyaa/user": "^0.1",
        "waaseyaa/validation": "^0.1",
        "waaseyaa/workflows": "^0.1"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "waaseyaa/testing": "^0.1"
    },
    "suggest": {
        "ext-gd": "Required for dynamic Open Graph PNG images (GD + FreeType)."
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/App/"
        }
    },
    "extra": {
        "waaseyaa": {
            "admin_path": "../waaseyaa/packages/admin",
            "providers": [
                "App\\Provider\\MinooEntityStackProvider",
                "App\\Provider\\MinooRoutingStackProvider",
                "App\\Provider\\AppBootServiceProvider",
                "App\\Provider\\AppCommandServiceProvider",
                "App\\Provider\\BimaajiBridgeProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "audit": {
            "ignore": {
                "PKSA-5jz8-6tcw-pbk4": "PHPUnit argument-injection advisory (GHSA-qrr6-mg7r-m243). Dev-only dep; exploitation requires attacker-controlled -d INI flags. 10.5.x line is not backported; upgrade to ^12.5.22 tracked in #735."
            }
        }
    },
    "scripts": {
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "PHP_CLI_SERVER_WORKERS=4 bin/waaseyaa serve -p ${APP_PORT:-8081} & SERVE_PID=$!; trap 'kill $SERVE_PID 2>/dev/null || true' EXIT INT TERM; NUXT_BACKEND_URL=http://127.0.0.1:${APP_PORT:-8081} bin/waaseyaa admin:dev"
        ],
        "audit-site": "./bin/waaseyaa-audit-site",
        "dev:wsl": [
            "Composer\\Config::disableProcessTimeout",
            "PHP_CLI_SERVER_WORKERS=4 bin/waaseyaa serve & npm --prefix ../waaseyaa/packages/admin run dev -- --host && kill $!"
        ],
        "post-create-project-cmd": [
            "chmod +x bin/waaseyaa bin/waaseyaa-version bin/verify-deploy-rsync bin/waaseyaa-audit-site",
            "php bin/post-create-setup.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
