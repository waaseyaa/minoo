		-
			message: '#^Parameter \#2 \$openRequests of method App\\Http\\Controller\\Dashboard\\CoordinatorDashboardController\:\:buildRankedMap\(\) expects array\<Waaseyaa\\Entity\\ContentEntityBase\>, list\<Waaseyaa\\Entity\\EntityInterface\> given\.$#'
			identifier: argument.type
			count: 1
			path: src/Http/Controller/Dashboard/CoordinatorDashboardController.php

		-
			message: '#^Parameter \#3 \$volunteers of method App\\Http\\Controller\\Dashboard\\CoordinatorDashboardController\:\:buildRankedMap\(\) expects array\<Waaseyaa\\Entity\\ContentEntityBase\>, array\<int\|string, Waaseyaa\\Entity\\EntityInterface\> given\.$#'
			identifier: argument.type
			count: 1
			path: src/Http/Controller/Dashboard/CoordinatorDashboardController.php

		-
			message: '#^Parameter \#1 \$event of method App\\Http\\Controller\\Events\\EventController\:\:findSimilarUpcoming\(\) expects Waaseyaa\\Entity\\ContentEntityBase\|null, Waaseyaa\\Entity\\EntityInterface\|null given\.$#'
			identifier: argument.type
			count: 1
			path: src/Http/Controller/Events/EventController.php

		-
			message: '#^If condition is always true\.$#'
