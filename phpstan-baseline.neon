			message: '#^Parameter \#3 \$events of static method App\\Domain\\Events\\ValueObject\\CalendarMonth\:\:fromEvents\(\) expects list\<Waaseyaa\\Entity\\ContentEntityBase\>, list\<Waaseyaa\\Entity\\EntityInterface\> given\.$#'
			identifier: argument.type
